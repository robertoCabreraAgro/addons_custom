<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View rma.reason View List -->
    <record id="view_rma_reason_list" model="ir.ui.view">
        <field name="name">view.rma.reason.list</field>
        <field name="model">rma.reason</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- View rma.reason form -->
    <record id="view_rma_reason_form" model="ir.ui.view">
        <field name="name">view.rma.reason.form</field>
        <field name="model">rma.reason</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="sequence"/>
                            <field name="description"/>
                        </group>
                        <group>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View rma.reason search -->
    <record id="view_rma_reason_search" model="ir.ui.view">
        <field name="name">view.rma.reason.search</field>
        <field name="model">rma.reason</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
                <separator/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="1" string="Group By">
                    <filter string="Name" name="group_by_name" domain="[]" context="{'group_by':'name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action rma.reason -->
    <record id="action_rma_reason" model="ir.actions.act_window">
        <field name="name">Claim Reason</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">rma.reason</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no examples click here to add new Claim Reason.
            </p>
        </field>
    </record>

</odoo>
