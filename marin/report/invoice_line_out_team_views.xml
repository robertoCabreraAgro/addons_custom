<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record model="ir.ui.view" id="view_invoice_line_out_team_report_tree">
        <field name="name">invoice.line.out.team.report.tree</field>
        <field name="model">invoice.line.out.team.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="team_id" />
                <field name="partner_id" />
                <field name="product_id" />
                <field name="quarter" />
                <field name="total_qty_current_year" sum="Total" optional="show" />
                <field name="total_qty_last_year" sum="Total" optional="hide" />
                <field name="real_sale_variation" sum="Total" optional="hide" />
                <field name="real_sale_variation_percentage" avg="Average" optional="show" />
                <field name="average_real_cost_current_year" avg="Average" optional="show" />
                <field name="average_real_cost_last_year" avg="Average" optional="hide" />
                <field name="real_cost_variation" avg="Average" optional="hide" />
                <field name="real_cost_variation_percentage" avg="Average" optional="show" />
                <field name="average_abs_sale_price_current_year" avg="Average" optional="hide" />
                <field name="average_abs_sale_price_last_year" avg="Average" optional="hide" />
                <field name="average_sale_price_current_year" avg="Average" optional="show" />
                <field name="average_sale_price_last_year" avg="Average" optional="hide" />
                <field name="real_price_variation" avg="Average" optional="show" />
                <field name="real_price_variation_percentage" avg="Average" optional="show" />
                <field name="sale_price_total_current_year" sum="Total" optional="show" />
                <field name="sale_price_total_last_year" sum="Total" optional="hide" />
                <field name="sale_price_variation" sum="Total" optional="hide" />
                <field name="sale_price_variation_percentage" avg="Average" optional="show" />
                <field name="real_margin_value_current_year" sum="Total" optional="show" />
                <field name="real_margin_value_last_year" sum="Total" optional="hide" />
                <field name="real_margin_variation" sum="Total" optional="hide" />
                <field name="real_margin_variation_percentage" avg="Average" optional="show" />
            </list>
        </field>
    </record>

    <record model="ir.ui.view" id="view_invoice_line_out_team_report_form">
        <field name="name">invoice.line.out.team.report.form</field>
        <field name="model">invoice.line.out.team.report</field>
        <field name="arch" type="xml">
            <form>
                <header>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Name" />
                        <field name="name" />
                    </div>
                    <group name="name">
                        <field name="team_id" />
                        <field name="commercial_partner_id" />
                        <field name="partner_id" />
                        <field name="product_id" />
                        <field name="product_categ_id" />
                        <field name="quarter" />
                    </group>
                    <notebook>
                        <page name="values" string="Values">
                            <group>
                                <group string="Totals Current Year">
                                    <field name="total_qty_current_year" />
                                    <field name="sale_price_total_current_year" />
                                    <field name="cost_purchase_total_current_year" />
                                    <field name="real_margin_value_current_year" />
                                    <field name="average_real_cost_current_year" />
                                </group>
                                <group string="Totals Last Year">
                                    <field name="total_qty_last_year" />
                                    <field name="sale_price_total_last_year" />
                                    <field name="cost_purchase_total_last_year" />
                                    <field name="real_margin_value_last_year" />
                                    <field name="average_real_cost_last_year" />
                                </group>
                                <group string="Averages Current Year">
                                    <field name="average_real_cost_current_year" />
                                    <field name="average_abs_sale_price_current_year" />
                                    <field name="average_sale_price_current_year" />
                                </group>
                                <group string="Averages Last Year">
                                    <field name="average_real_cost_last_year" />
                                    <field name="average_abs_sale_price_last_year" />
                                    <field name="average_sale_price_last_year" />
                                </group>
                                <group string="Variations">
                                    <field name="real_sale_variation_percentage" />
                                    <field name="real_cost_variation_percentage" />
                                    <field name="real_price_variation_percentage" />
                                    <field name="sale_price_total_last_year" />
                                    <field name="real_margin_variation_percentage" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record model="ir.ui.view" id="view_invoice_line_out_team_report_pivot">
        <field name="name">invoice.line.out.team.report.pivot</field>
        <field name="model">invoice.line.out.team.report</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="total_qty_current_year" type="measure" />
                <field name="real_sale_variation_percentage" type="measure" />
                <field name="average_real_cost_current_year" type="measure" />
                <field name="real_cost_variation_percentage" type="measure" />
                <field name="average_sale_price_current_year" type="measure" />
                <field name="real_price_variation_percentage" type="measure" />
                <field name="sale_price_total_current_year" type="measure" />
                <field name="sale_price_variation_percentage" type="measure" />
                <field name="real_margin_value_current_year" type="measure" />
                <field name="real_margin_variation_percentage" type="measure" />
            </pivot>
        </field>
    </record>

    <record model="ir.ui.view" id="view_invoice_line_out_team_report_search_view">
        <field name="name">invoice.line.out.team.report.search.view</field>
        <field name="model">invoice.line.out.team.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="team_id" />
                <field name="product_id" />
                <field name="partner_id" />
                <field name="commercial_partner_id" />
                <field name="product_categ_id" />
                <separator />
                <filter domain="[('quarter', '=', 1)]" name="quarter_1" help="First Quarter" />
                <filter domain="[('quarter', '=', 2)]" name="quarter_2" help="Second Quarter" />
                <filter domain="[('quarter', '=', 3)]" name="quarter_3" help="Third Quarter" />
                <filter domain="[('quarter', '=', 4)]" name="quarter_4" help="Fourth Quarter" />
                <group expand="0" string="Group By">
                    <filter name="group_by_team_id" string="Team" context="{'group_by':'team_id'}" />
                    <filter
                        name="group_by_commercial_partner"
                        string="Commercial Partner"
                        context="{'group_by':'commercial_partner_id'}"
                    />
                    <filter name="group_by_partner" string="Partner" context="{'group_by':'partner_id'}" />
                    <separator />
                    <filter name="group_by_product" string="Product" context="{'group_by':'product_id'}" />
                    <filter
                        name="group_by_product_categ"
                        string="Product Category"
                        context="{'group_by':'product_categ_id'}"
                    />
                    <filter
                        name="group_by_parent_categ"
                        string="Parent Category"
                        context="{'group_by':'parent_categ_id'}"
                    />
                    <filter
                        name="group_by_root_categ"
                        string="Root Category"
                        context="{'group_by':'root_categ_id'}"
                    />
                    <separator />
                    <filter name="group_by_quarter" string="Quarter" context="{'group_by':'quarter'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_invoice_line_out_team_report" model="ir.actions.act_window">
        <field name="name">Invoice Line Out Team Report</field>
        <field name="res_model">invoice.line.out.team.report</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="context">{'group_by': ['root_categ_id', 'parent_categ_id', 'product_categ_id', 'product_id']}</field>
    </record>

    <menuitem
        id="menu_invoice_line_out_team_report"
        name="Invoice Line Out Team Report"
        parent="sale.menu_sale_report"
        groups="sales_team.group_sale_manager"
        action="action_invoice_line_out_team_report"
    />

</odoo>
