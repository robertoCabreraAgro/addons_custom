<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    
    <!-- Extend GPS Tracking Dashboard Template -->
    <t t-name="gps_tracking.gps_tracking_dashboard_template" t-inherit="gps_tracking.gps_tracking_dashboard_template" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class, 'card_body')]/div[@t-if='device.driver_name']" position="after">
            <div t-if="device.department_id" class="kanban_info">
                <span>Departamento: <t t-esc="device.department_id[1]"/></span>
            </div>
        </xpath>
    </t>

    <!-- Extend GPS Tracking Timeline Template -->
    <t t-name="gps_tracking.gps_tracking_timeline_template" t-inherit="gps_tracking.gps_tracking_timeline_template" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class, 'card_body')]/div[@t-if='device.driver_name']" position="after">
            <div t-if="device.department_id" class="kanban_info">
                <span>Departamento: <t t-esc="device.department_id[1]"/></span>
            </div>
        </xpath>
    </t>

</templates>