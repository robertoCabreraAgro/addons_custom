<odoo>
    <record id="pos_session_view_form" model="ir.ui.view">
        <field name="name">pos.session.view.form</field>
        <field name="model">pos.session</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_session_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_liquidity_transfers"
                    type="object" class="oe_stat_button"
                    icon="fa-dollar">
                    <field name="count_liquidity_transfer_payment" string="Cash Transfers" widget="statinfo" />
                </button>
            </xpath>
            <xpath expr="//field[@name='cash_register_balance_end_real']" position="before">
                <field name="original_cash_register_balance_end_real"
                    invisible="not cash_transfered" />
                <field name="cash_transfered"
                    invisible="not cash_transfered" />
             </xpath>
        </field>
    </record>
</odoo>
