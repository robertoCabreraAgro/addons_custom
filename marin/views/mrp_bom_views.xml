<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_mrp_bom_filter" model="ir.ui.view">
        <field name="name">mrp.bom.select</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.view_mrp_bom_filter" />
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='phantom']" position="after">
                <separator />
                <filter name="packaged" string="Packaged" domain="[('production_type', '=', 'packaged')]" />
                <filter name="formulated" string="Formulated" domain="[('production_type', '=', 'formulated')]" />
                <filter
                    name="reformulated"
                    string="Reformulated"
                    domain="[('production_type', '=', 'reformulated')]"
                />
                <filter
                    name="groupby_production_type"
                    string="Production Type"
                    context="{'group_by': 'production_type'}"
                />
            </xpath>
        </field>
    </record>

    <record id="mrp_bom_form_view" model="ir.ui.view">
        <field name="name">mrp.bom.select</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="after">
                <field
                    name="production_type"
                    widget="radio"
                    invisible="type == 'phantom'"
                    required="type == 'normal'"
                />
            </xpath>
        </field>
    </record>

</odoo>