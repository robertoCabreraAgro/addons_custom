<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_mrp_bom_filter" model="ir.ui.view">
        <field name="name">mrp.bom.select</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.view_mrp_bom_filter" />
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='phantom']" position="after">
                <separator/>
                <filter name="refill" string="Refill"
                    domain="[('x_type', '=', 'refill')]" />
                <filter name="formulate" string="Formulate"
                    domain="[('x_type', '=', 'formulate')]" />
                <filter name="groupby_x_type" string="Marin type"
                    context="{'group_by': 'x_type'}" />
            </xpath>
        </field>
    </record>

    <record id="mrp_bom_form_view" model="ir.ui.view">
        <field name="name">mrp.bom.select</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="after">
                <field name="x_type" widget="radio" />
            </xpath>
        </field>
    </record>
</odoo>
