<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="hr_payslip_run_kanban" model="ir.ui.view">
        <field name="name">hr.payslip.run.kanban</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_view_kanban" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_payment_report']" position="after">
                <button name="x_action_unlink_payslip" string="Unlink Payslips" 
                    type="object" class="btn btn-secondary"
                    invisible="state not in ('02_verify', '03_close') or not payslip_count" />
            </xpath>
        </field>
    </record>
</odoo>
