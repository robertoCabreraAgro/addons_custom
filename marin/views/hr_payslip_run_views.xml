<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="hr_payslip_run_form" model="ir.ui.view">
        <field name="name">hr.payslip.run.form</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_print_payroll_dispersion']" position="after">
                <button name="x_action_unlink_payslip" string="Unlink Payslips" 
                    type="object" class="oe_highlight"
                    invisible="state not in ['verify', 'close'] or not slip_ids"
                    groups="hr_bank_dispersion.allow_print_payslip_dispersion" />
            </xpath>
        </field>
    </record>
</odoo>
