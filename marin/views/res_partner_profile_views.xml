<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- Form View -->
    <record id="view_res_partner_profile_form" model="ir.ui.view">
        <field name="name">res.partner.profile.form</field>
        <field name="model">res.partner.profile</field>
        <field name="arch" type="xml">
            <form string="Partner Profile">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Profile Name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_ids" widget="many2many_tags" options="{'color_field': 'color'}" />
                            <field name="factor" widget="percentage" />
                            <field name="sequence" />
                        </group>
                        <group>
                            <field name="score_min" />
                            <field name="score_max" />
                            <field name="active" />
                            <field name="company_id" groups="base.group_multi_company" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_res_partner_profile_list" model="ir.ui.view">
        <field name="name">res.partner.profile.list</field>
        <field name="model">res.partner.profile</field>
        <field name="arch" type="xml">
            <list string="Partner Profiles" multi_edit="1">
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="category_ids" widget="many2many_tags" options="{'color_field': 'color'}" />
                <field name="score_min" />
                <field name="score_max" />
                <field name="factor" widget="percentage" />
                <field name="active" />
                <field name="company_id" groups="base.group_multi_company" />
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_res_partner_profile_search" model="ir.ui.view">
        <field name="name">res.partner.profile.search</field>
        <field name="model">res.partner.profile</field>
        <field name="arch" type="xml">
            <search string="Search Partner Profile">
                <field name="name" />
                <field name="category_ids" />
                <separator />
                <filter string="Active" name="active" domain="[('active', '=', True)]" />
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]" />
                <group expand="0" string="Group By">
                    <filter string="Company" name="company" domain="[]" context="{'group_by': 'company_id'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_res_partner_profile" model="ir.actions.act_window">
        <field name="name">Partner Profiles</field>
        <field name="res_model">res.partner.profile</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_res_partner_profile_search" />
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new partner profile
            </p>
            <p>
                Partner profiles allow you to classify customers through tags and
                apply percentage factors for calculating expected revenues and commercial targets.
            </p>
        </field>
    </record>

</odoo>
