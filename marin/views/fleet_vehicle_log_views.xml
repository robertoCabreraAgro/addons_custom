<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="fleet_vehicle_log_list_view" model="ir.ui.view">
        <field name="name">fleet.vehicle.log.list</field>
        <field name="model">fleet.vehicle.log</field>
        <field name="inherit_id" ref="fleet.view_list_fleet_vehicle_log" />
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="qty_fuel" optional="hidden" />
                <field name="efficiency" optional="hidden" />
            </xpath>
        </field>
    </record>
</odoo>
