<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="product_category_form_view" model="ir.ui.view">
        <field name="name">product.category.form</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view" />
        <field name="arch" type="xml">
            <field name="property_account_income_categ_id" position="after">
                <field name="property_account_income_refund_id" />
            </field>
            <field name="property_account_expense_categ_id" position="after">
                <field name="property_account_expense_refund_id" />
            </field>
            <group name="first" position="after">
                <group>
                    <field name="use_dose" />
                </group>
                <group string="Dates" name="expiry_and_lots"
                    invisible="not use_expiration_date"
                    groups="stock.group_production_lot">
                    <field name="use_expiration_date" />
                    <label for="expiration_time" invisible="not use_expiration_date"/>
                    <div invisible="not use_expiration_date">
                        <field name="expiration_time" class="oe_inline" />
                        <span> days after receipt</span>
                    </div>
                    <label for="use_time" invisible="not use_expiration_date"/>
                    <div invisible="not use_expiration_date">
                        <field name="use_time" class="oe_inline" />
                        <span> days before expiration date</span>
                    </div>
                    <label for="removal_time" invisible="not use_expiration_date"/>
                    <div invisible="not use_expiration_date">
                        <field name="removal_time" class="oe_inline" />
                        <span> days before expiration date</span>
                    </div>
                    <label for="alert_time" invisible="not use_expiration_date"/>
                    <div invisible="not use_expiration_date">
                        <field name="alert_time" class="oe_inline" />
                        <span> days before expiration date</span>
                    </div>
                </group>
            </group>
        </field>
    </record>
</odoo>
