<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="product_template_search_view" model="ir.ui.view">
        <field name="name">product.template.search</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="product_tag_ids" />
            </xpath>
        </field>
    </record>

    <record id="product_template_tree_view" model="ir.ui.view">
        <field name="name">product.template.list</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='list_price']" position="attributes">
                <attribute name="groups">marin.group_sale_readonly</attribute>
            </xpath>
            <xpath expr="//field[@name='standard_price']" position="attributes">
                <attribute name="groups">marin.group_product_cost_readonly</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_stock_product_template_tree" model="ir.ui.view">
        <field name="name">product.template.list</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.view_stock_product_template_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='responsible_id']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
        </field>
    </record>

    <record id="product_template_kanban_view" model="ir.ui.view">
        <field name="name">product.template.kanban</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_kanban_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='list_price']" position="attributes">
                <attribute name="groups">marin.group_sale_readonly</attribute>
            </xpath>
        </field>
    </record>

    <record id="product_template_form_view" model="ir.ui.view">
        <field name="name">product.template.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="priority" eval="20" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="user_purchase_readonly" invisible="1" />
                <field name="user_purchase_manager" invisible="1" />
                <field name="user_product_cost_readonly" invisible="1" />
                <field name="user_product_cost_manager" invisible="1" />
                <field name="user_sale_readonly" invisible="1" />
                <field name="user_sale_manager" invisible="1" />
                <field name="user_stock_readonly" invisible="1" />
                <field name="user_stock_manager" invisible="1" />
            </xpath>
            <xpath expr="//div[@name='options']//field[@name='sale_ok']" position="attributes">
                <attribute name="readonly">not user_sale_manager</attribute>
                <attribute name="groups">marin.group_sale_readonly</attribute>
            </xpath>
            <xpath expr="//div[@name='options']//label[@for='sale_ok']" position="attributes">
                <attribute name="groups">marin.group_sale_readonly</attribute>
            </xpath>
            <xpath expr="//div[@name='options']//field[@name='purchase_ok']" position="attributes">
                <attribute name="readonly">not user_purchase_manager</attribute>
                <attribute name="groups">marin.group_purchase_readonly</attribute>
            </xpath>
            <xpath expr="//div[@name='options']//label[@for='purchase_ok']" position="attributes">
                <attribute name="groups">marin.group_purchase_readonly</attribute>
            </xpath>
            <xpath expr="//div[@name='options']//field[@name='can_be_expensed']" position="attributes">
                <attribute name="readonly">not user_purchase_manager</attribute>
                <attribute name="groups">marin.group_purchase_readonly</attribute>
            </xpath>
            <xpath expr="//div[@name='options']//label[@for='can_be_expensed']" position="attributes">
                <attribute name="groups">marin.group_purchase_readonly</attribute>
            </xpath>
            <xpath expr="//div[@name='options']//field[@name='rent_ok']" position="attributes">
                <attribute name="readonly">not user_sale_manager</attribute>
                <attribute name="groups">marin.group_sale_readonly</attribute>
            </xpath>
            <xpath expr="//div[@name='options']//label[@for='rent_ok']" position="attributes">
                <attribute name="groups">marin.group_sale_readonly</attribute>
            </xpath>
            <xpath expr="//div[@name='options']//field[@name='available_in_pos']" position="attributes">
                <attribute name="readonly">not user_sale_manager</attribute>
                <attribute name="groups">marin.group_sale_readonly</attribute>
            </xpath>
            <xpath expr="//div[@name='options']//label[@for='available_in_pos']" position="attributes">
                <attribute name="groups">marin.group_sale_readonly</attribute>
            </xpath>
            <xpath expr="//field[@name='type']" position="attributes">
                <attribute name="readonly">not user_stock_manager</attribute>
            </xpath>
            <xpath expr="//label[@for='list_price']" position="attributes">
                <attribute name="groups">marin.group_sale_readonly</attribute>
            </xpath>
            <xpath expr="//div[@name='list_price_uom']" position="attributes">
                <attribute name="groups">marin.group_sale_readonly</attribute>
            </xpath>
            <xpath expr="//field[@name='list_price']" position="attributes">
                <attribute name="readonly">not user_sale_manager</attribute>
            </xpath>
            <xpath expr="//label[@for='standard_price']" position="attributes">
                <attribute name="groups">marin.group_product_cost_readonly</attribute>
            </xpath>
            <xpath expr="//div[@name='standard_price_uom']" position="attributes">
                <attribute name="groups">marin.group_product_cost_readonly</attribute>
            </xpath>
            <xpath expr="//field[@name='standard_price']" position="attributes">
                <attribute name="readonly">not user_product_cost_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='categ_id']" position="attributes">
                <attribute name="readonly">not user_stock_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='company_id']" position="attributes">
                <attribute name="readonly">not user_stock_manager</attribute>
            </xpath>
            <xpath expr="//page[@name='sales']" position="attributes">
                <attribute name="groups">marin.group_sale_readonly</attribute>
            </xpath>
            <xpath expr="//page[@name='purchase']" position="attributes">
                <attribute name="groups">marin.group_purchase_readonly</attribute>
            </xpath>
            <xpath expr="//page[@name='inventory']" position="attributes">
                <attribute name="groups">marin.group_stock_readonly</attribute>
            </xpath>
            <xpath expr="//field[@name='property_account_income_id']" position="after">
                <field name="property_account_income_refund_id" />
            </xpath>
            <xpath expr="//field[@name='property_account_expense_id']" position="after">
                <field name="property_account_expense_refund_id" />
            </xpath>
            <xpath expr="//field[@name='uom_id']" position="after">
                <field name="x_dose_x_ha" />
            </xpath>
            <xpath expr="//field[@name='seller_ids']" position="attributes">
                <!-- removed standard_price from context since it's in marin.group_product_cost_readonly causing 'Access Rights Inconsistency' (Task #5664) -->
                <attribute name="context">{'default_product_tmpl_id': id, 'product_template_invisible_variant': True, 'list_view_ref':'purchase.product_supplierinfo_tree_view2'}</attribute>
            </xpath>
        </field>
    </record>
</odoo>
