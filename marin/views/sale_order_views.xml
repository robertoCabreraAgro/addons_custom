<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_sales_order_filter_marin" model="ir.ui.view">
        <field name="name">sale.order.list.select.marin</field>
        <field name="model">sale.order</field>
        <field name="priority" eval="15" />
        <field name="arch" type="xml">
            <search string="Search Sale Orders">
                <field name="name" string="Order"
                    filter_domain="['|', '|', ('name', 'ilike', self), ('client_order_ref', 'ilike', self), ('partner_id', 'child_of', self)]"
                />
                <field name="partner_id" operator="child_of" />
                <field name="line_ids" string="Product"
                    filter_domain="[('line_ids.product_id', 'ilike', self)]" />
                <field name="tag_ids" string="Tag" />
                <field name="team_id" string="Sales Team" />
                <field name="user_id" />
                <field name="campaign_id" />
                <filter name="my_orders_filter" string="My Orders"
                    domain="[('user_id', '=', uid)]" />
                <separator />
                <filter string="Quotations" name="draft" 
                    domain="[('state', 'in', ('draft', 'sent'))]" />
                <filter string="Sale orders" name="sale" 
                    domain="[('state', 'in', ('sale', 'done'))]" />
                <separator />
                <filter name="to_invoice" string="To invoice"
                    domain="[('invoice_state', '=', 'to do')]" />
                <filter name="invoiced" string="Invoiced"
                    domain="[('invoice_state', '=', 'done')]" />
                <filter name="upselling" string="To upsell"
                    domain="[('invoice_state', '=', 'over done')]" />
                <separator />
                <filter name="pending" string="To deliver"
                    domain="[('transfer_state', '=', 'to do')]" />
                <filter name="partially_delivered" string="Partially delivered"
                    domain="[('transfer_state', '=', 'partially')]" />
                <filter name="full" string="Delivered"
                    domain="[('transfer_state', '=', 'done')]" />
                <filter name="over_full" string="Over Delivered"
                    domain="[('transfer_state', '=', 'over done')]" />
                <separator />
                <filter name="activities_overdue" string="Late Activities"
                    domain="[('my_activity_date_deadline', '&lt;', context_today().strftime('%Y-%m-%d'))]"
                    help="Show all records which has next action date is before today" />
                <filter name="activities_today" string="Today Activities"
                    domain="[('my_activity_date_deadline', '=', context_today().strftime('%Y-%m-%d'))]" />
                <filter name="activities_upcoming_all" string="Future Activities"
                    domain="[('my_activity_date_deadline', '&gt;', context_today().strftime('%Y-%m-%d'))]" />
                <group string="Group By" expand="0">
                    <filter name="commercial_partner_groupby" string="Customer Entity"
                        domain="[]"
                        context="{'group_by': 'commercial_partner_id'}" />
                    <filter name="customer" string="Customer"
                        domain="[]"
                        context="{'group_by': 'partner_id'}" />
                    <filter name="salesteam" string="Team"
                        domain="[]"
                        context="{'group_by': 'team_id'}" />
                    <filter name="salesperson" string="Salesperson"
                        domain="[]"
                        context="{'group_by': 'user_id'}" />
                    <filter name="order_date" string="Order Date"
                        domain="[]"
                        context="{'group_by': 'date_order'}" />
                    <filter name="invoice_state" string="Invoice status"
                        domain="[]"
                        context="{'group_by': 'invoice_state'}" />
                    <filter name="transfer_state" string="Delivery Status"
                        domain="[]"
                        context="{'group_by': 'transfer_state'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="view_sale_order_tree_marin" model="ir.ui.view">
        <field name="name">sale.order.list.marin</field>
        <field name="model">sale.order</field>
        <field name="priority">4</field>
        <field name="arch" type="xml">
            <list sample="1" decoration-info="invoice_state == 'to do'" decoration-muted="state == 'cancel'">
                <header>
                    <button name="action_assign_missing_seasons" 
                            string="Assign missing seasons" 
                            type="object" 
                            class="btn-primary"
                            groups="sales_team.group_sale_manager"/>
                </header>
                <field name="company_id" column_invisible="1" />
                <field name="currency_id" column_invisible="1" />
                <field name="state" column_invisible="1" />
                <field name="message_needaction" column_invisible="1" />
                <field name="name" string="Number" readonly="1" decoration-bf="1" />
                <field name="create_date" string="Creation Date" widget="date" optional="show" />
                <field name="date_order" string="Order Date" widget="date" optional="show" />
                <field name="date_commitment" widget="date" optional="hide" />
                <field name="date_planned" widget="date" optional="hide" />
                <field name="partner_id" readonly="1" />
                <field name="amount_untaxed" sum="Total tax excluded" widget="monetary" optional="hide" />
                <field name="amount_tax" sum="Tax Total" widget="monetary" optional="hide" />
                <field
                    name="amount_total"
                    sum="Total tax included"
                    widget="monetary"
                    decoration-bf="1"
                    optional="show"
                />
                <field name="team_id" optional="hide" />
                <field name="user_id" widget="many2one_avatar_user" optional="show" />
                <field name="activity_ids" widget="list_activity" optional="hide" />
                <field
                    name="state"
                    widget="badge"
                    optional="show"
                    decoration-info="state in ('draft', 'sent')"
                    decoration-success="state in ('sale', 'done')"
                />
                <field
                    name="transfer_state"
                    widget="badge"
                    optional="show"
                    decoration-danger="transfer_state == 'over done'"
                    decoration-warning="transfer_state == 'partially'"
                    decoration-info="transfer_state == 'to do'"
                    decoration-success="transfer_state == 'done'"
                />
                <field
                    name="invoice_state"
                    widget="badge"
                    optional="show"
                    decoration-danger="invoice_state == 'to do'"
                    decoration-warning="invoice_state == 'over done'"
                    decoration-info="invoice_state == 'no'"
                    decoration-success="invoice_state == 'done'"
                />
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" optional="hide" />
                <field name="season_id" optional="show" />
                <field name="warehouse_id" optional="show" />
                <field name="company_id" readonly="1" optional="show" groups="base.group_multi_company" />
            </list>
        </field>
    </record>

    <record id="view_order_form_marin" model="ir.ui.view">
        <field name="name">sale.order.form.marin</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="priority" eval="20" />
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button
                    name="action_view_order_lines"
                    string="Order Lines"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-list-ul"
                    invisible="not id"
                />
            </xpath>
            <xpath expr="//button[@name='action_view_picking']" position="attributes">
                <attribute name="groups">marin.group_stock_readonly,stock.group_stock_user</attribute>
            </xpath>
            <!-- group partner_details -->
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'always_reload': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_invoice_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'always_reload': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'always_reload': True}</attribute>
            </xpath>
            <!-- group order_details -->
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='journal_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='sale_order_template_id']" position="after">
                <field
                    name="warehouse_id"
                    options="{'no_create': True}"
                    readonly="state in ['sale', 'cancel']"
                    force_save="1"
                    groups="stock.group_stock_multi_locations"
                />
                <field name="route_id" groups="stock.group_adv_location" readonly="state != 'draft'" />
            </xpath>
            <xpath expr="//field[@name='pricelist_id']" position="attributes">
                <attribute name="required">state == 'draft'</attribute>
            </xpath>
            <xpath expr="//field[@name='payment_term_id']" position="attributes">
                <attribute name="required">state == 'draft'</attribute>
                <!-- This is a fix keep until Odoo fix this -->
                <attribute name="readonly">state in ['cancel', 'sale']</attribute>
            </xpath>
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field
                    name="journal_id"
                    required="state == 'draft'"
                    readonly="state in ['sale', 'cancel']"
                    options="{'no_create': True}"
                />
                <field
                    name="season_id"
                    readonly="state in ['sale', 'cancel']"
                    options="{'no_create': True}"
                />
            </xpath>
            <xpath expr="//page[@name='order_lines']//form//field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
            <xpath expr="//page[@name='order_lines']//form//field[@name='product_uom_id'][2]" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
            <xpath expr="//page[@name='order_lines']//list/field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_open': True, 'no_create': True}</attribute>
            </xpath>
            <xpath expr="//page[@name='order_lines']//list/field[@name='product_template_id']" position="attributes">
                <attribute name="options">{'no_open': True, 'no_create': True}</attribute>
            </xpath>
            <xpath expr="//page[@name='order_lines']//list/field[@name='product_uom_id'][2]" position="attributes">
                <attribute name="options">{'no_open': True, 'no_create': True}</attribute>
            </xpath>
            <xpath expr="//page/field[@name='line_ids']/list/field[@name='tax_ids']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//page/field[@name='line_ids']/list/field[@name='discount']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//page/field[@name='line_ids']/list/field[@name='qty_transfered']" position="attributes">
                <attribute name="decoration-danger">not display_type and transfer_state == 'over done'</attribute>
                <attribute name="decoration-warning">not display_type and transfer_state == 'partially'</attribute>
                <attribute name="decoration-info">not display_type and transfer_state == 'to do'</attribute>
                <attribute name="decoration-success">not display_type and transfer_state == 'done'</attribute>
            </xpath>
            <xpath expr="//page/field[@name='line_ids']/list/field[@name='qty_invoiced']" position="attributes">
                <attribute name="decoration-danger">not display_type and invoice_state == 'to do'</attribute>
                <attribute name="decoration-info">not display_type and invoice_state == 'over done'</attribute>
                <attribute name="decoration-success">not display_type and invoice_state == 'done'</attribute>
            </xpath>
            <xpath expr="//page/field[@name='line_ids']/list/field[@name='price_unit']" position="after">
                <field name="partner_id" column_invisible="1" />
                <field name="transfer_state" column_invisible="1" />
                <widget name="sale_line_price_history_widget" width="20px" />
            </xpath>
            <xpath expr="//page[@name='other_information']/group" position="inside">
                <group
                    name="clean"
                    string="Clean Up"
                    groups="sales_team.group_sale_manager"
                    invisible="state != 'sale'"
                >
                    <button name="action_clean_3_0" string="Clean 3-0" type="object" colspan="2" />
                </group>
            </xpath>
            <xpath expr="//page[@name='other_information']//field[@name='invoice_state']" position="replace">
                <label
                    string="Invoice status"
                    for="invoice_state"
                    class="fw-bold text-900"
                    invisible="state != 'sale'"
                />
                <div name="invoice_state_div" class="d-flex" invisible="state != 'sale'">
                    <div colspan="1">
                        <field name="invoice_state" />
                    </div>
                    <div colspan="2">
                        <button
                            name="action_recompute_invoice_state"
                            string="Update"
                            type="object"
                            groups="account.group_account_user"
                            class="oe_inline oe_button"
                        />
                        <button
                            name="action_force_invoice_state"
                            string="Force invoice status"
                            type="object"
                            invisible="invoice_state == 'done' or state != 'sale'"
                            groups="marin.group_sale_force_invoicing_status"
                            class="oe_inline oe_button"
                        />
                        <button
                            name="action_unforce_invoice_state"
                            string="Restore invoice status"
                            type="object"
                            invisible="invoice_state != 'done' or state != 'sale'"
                            groups="marin.group_sale_force_invoicing_status"
                            class="oe_inline oe_button"
                        />
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <record id="view_order_form_inherit_sale_stock_marin" model="ir.ui.view">
        <field name="name">sale.order.form.sale.stock</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_stock.view_order_form_inherit_sale_stock" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='transfer_state']" position="replace">
                <label
                    string="Delivery Status"
                    for="transfer_state"
                    class="fw-bold text-900"
                    invisible="state != 'sale'"
                />
                <div name="transfer_state_div" class="d-flex" invisible="state != 'sale'">
                    <div colspan="1">
                        <field name="transfer_state" />
                    </div>
                    <div colspan="2">
                        <button
                            name="action_force_transfer_state"
                            string="Force delivery done"
                            type="object"
                            invisible="transfer_state == 'done' or state != 'sale'"
                            groups="marin.group_sale_force_transfer_state"
                            class="oe_inline oe_button"
                        />
                        <button
                            name="action_unforce_transfer_state"
                            string="Unforce delivery done"
                            type="object"
                            invisible="transfer_state != 'done' or state != 'sale'"
                            groups="marin.group_sale_force_transfer_state"
                            class="oe_inline oe_button"
                        />
                    </div>
                </div>
            </xpath>
        </field>
    </record>

   <record id="sale_margin_sale_order_marin" model="ir.ui.view">
        <field name="name">sale.order.line.margin.view.form.marin</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_margin.sale_margin_sale_order" />
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('d-flex')]" position="attributes">
                <attribute name="groups">marin.group_product_cost_readonly</attribute>
            </xpath>
        </field>
    </record>

    <record id="sale_margin_sale_order_line_marin" model="ir.ui.view">
        <field name="name">sale.order.line.margin.view.form.marin</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_margin.sale_margin_sale_order_line" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='purchase_price']" position="attributes">
                <attribute name="groups">marin.group_product_cost_readonly</attribute>
            </xpath>
        </field>
    </record>

    <record id="sale_margin_sale_order_line_form_marin" model="ir.ui.view">
        <field name="name">sale.order.line.list.margin.view.form.marin</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_margin.sale_margin_sale_order_line_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='purchase_price']" position="attributes">
                <attribute name="groups">marin.group_product_cost_readonly</attribute>
            </xpath>
            <xpath expr="//field[@name='margin']" position="attributes">
                <attribute name="groups">marin.group_product_cost_readonly</attribute>
            </xpath>
            <xpath expr="//field[@name='margin_percent']" position="attributes">
                <attribute name="groups">marin.group_product_cost_readonly</attribute>
            </xpath>
        </field>
    </record>

    <record id="l10n_mx_edi_sale.sale_order_form_inherit_l10n_mx_edi_website_sale" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.l10n_mx_edi_website_sale</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field
                    name="l10n_mx_edi_cfdi_to_public"
                    invisible="country_code != 'MX'"
                    readonly="state in ['sale', 'cancel']"
                />
                <field
                    name="l10n_mx_edi_payment_method_id"
                    invisible="country_code != 'MX'"
                    readonly="state in ['sale', 'cancel']"
                />
                <field
                    name="l10n_mx_edi_usage"
                    invisible="country_code != 'MX'"
                    readonly="state in ['sale', 'cancel']"
                />
            </xpath>
        </field>
    </record>

    <record id="action_orders_marin" model="ir.actions.act_window">
        <field name="name">Sale orders</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
        <field name="view_id" ref="view_sale_order_tree_marin" />
        <field name="search_view_id" ref="view_sales_order_filter_marin" />
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new quotation, the first step of a new sale!
            </p><p>
                Once the quotation is confirmed, it becomes a sales order.<br
                /> You will be able to create an invoice and collect the payment.
            </p>
        </field>
    </record>

    <record id="action_quotation_new" model="ir.actions.act_window">
        <field name="name">Quotation</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">form,list,graph</field>
        <field name="domain">[('opportunity_id', '=', active_id)]</field>
        <field name="context">{'search_default_opportunity_id': active_id, 'default_opportunity_id': active_id}</field>
    </record>

    <record id="action_sale_order_authorize_debt" model="ir.actions.server">
        <field name="name">Authorize debt</field>
        <field name="model_id" ref="sale.model_sale_order" />
        <field name="binding_model_id" ref="sale.model_sale_order" />
        <field name="binding_view_types">list</field>
        <field name="group_ids" eval="[
            Command.link(ref('group_account_debt_manager')),
        ]" />
        <field name="state">code</field>
        <field name="code">if records:
    action = records.action_sale_authorize_debt()</field>
    </record>

    <!-- Create readonly-friendly window actions instead of server actions -->
    <record id="action_picking_tree_incoming_readonly" model="ir.actions.act_window">
        <field name="name">Receipts</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_picking_type_code': 'incoming', 'search_default_available': 1}</field>
        <field name="domain">[('picking_type_code', '=', 'incoming')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No receipts yet! Here you can see all incoming receipts.
            </p>
        </field>
    </record>

    <record id="action_picking_tree_outgoing_readonly" model="ir.actions.act_window">
        <field name="name">Delivery Orders</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_picking_type_code': 'outgoing', 'search_default_available': 1}</field>
        <field name="domain">[('picking_type_code', '=', 'outgoing')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No delivery orders yet! Here you can see all outgoing deliveries.
            </p>
        </field>
    </record>

    <record id="action_picking_tree_internal_readonly" model="ir.actions.act_window">
        <field name="name">Internal Transfers</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_picking_type_code': 'internal', 'search_default_available': 1}</field>
        <field name="domain">[('picking_type_code', '=', 'internal')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No internal transfers yet! Here you can see all internal movements.
            </p>
        </field>
    </record>

</odoo>
