<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_res_config_settings_inherit_marin" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.marin</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='orderlines_seq_cart']" position="after">
                <setting id="load_all_partners_by_company"
                    string="Load All Partners by Company"
                    help="If enabled, all customers filtered by company will be loaded instead of using limited scroll-based loading.">
                    <field name="pos_load_all_partners_by_company" />
                </setting>
            </xpath>
        </field>
    </record>
    <record id="view_res_config_settings_inherit_accounting" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.accounting.marin</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <div class="app_settings_block" title="Validación SAT CFDI">
                    <h2>Configuraciones de validación SAT</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="sat_batch_size" />
                                <field name="sat_batch_size" />
                                <div class="text-muted">Número máximo de facturas procesadas por
                                    ejecución.</div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="sat_status_max_days" />
                                <field name="sat_status_max_days" />
                                <div class="text-muted">Días hábiles máximos hacia atrás para
                                    revisión SAT.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="app_settings_block" title="Customer Merge Policies">
                    <h2>Customer Merge Policies</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="customer_merge_active" />
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="customer_merge_active" />
                                <div class="text-muted">Automatically merge inactive customers with the general public partner based on configured policies</div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box" invisible="not customer_merge_active">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="customer_merge_general_partner_id" />
                                <field name="customer_merge_general_partner_id" placeholder="Select general public partner..." />
                                <div class="text-muted">Partner to merge inactive customers with</div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box" invisible="not customer_merge_active">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Evaluation Period</span>
                                <div class="d-flex">
                                    <field name="customer_merge_interval_number" class="me-2" style="width: 100px;" />
                                    <field name="customer_merge_interval_type" />
                                </div>
                                <div class="text-muted">Time period to evaluate customer activity</div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box" invisible="not customer_merge_active">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="customer_merge_min_orders" />
                                <field name="customer_merge_min_orders" />
                                <div class="text-muted">Minimum number of orders required to keep a customer active</div>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box" invisible="not customer_merge_active">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="customer_merge_required_fields" />
                                <field name="customer_merge_required_fields" widget="many2many_tags" placeholder="Select required fields..." />
                                <div class="text-muted">Fields that must be completed for a customer to remain active (e.g., phone, email, tags)</div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
