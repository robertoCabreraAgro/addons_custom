<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_project_kpi_form2" model="ir.ui.view">
        <field name="name">project.project.form.kpi</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project" />
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_time_managment']" position="inside">
                <div>
                    <setting
                        class="col-lg-12"
                        id="project_kpi_setting"
                        help="Compare task execution times before and after process changes."
                    >
                        <field name="use_kpi_optime" />
                    </setting>
                </div>
            </xpath>
            <xpath expr="//group[@name='group_sales_invoicing']" position="inside">
                <div>
                    <setting
                        class="col-lg-12"
                        id="sales_features_container"
                        help="Allow creating quotations from tasks in this project."
                    >
                        <field name="sales_features" />
                    </setting>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
