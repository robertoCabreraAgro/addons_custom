<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_stock_move_line_detailed_operation_tree" model="ir.ui.view">
        <field name="name">stock.move.line.operations.list</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='quantity']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='product_uom_id']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='location_dest_id']" position="after">
                <field name="product_id" context="{'default_detailed_type': 'product'}" required="1" readonly="state == 'done' or move_id" options="{'no_create': True}"/>
                <field name="quantity" readonly="state in ('done', 'cancel') and is_locked" force_save="1"/>
                <field name="product_uom_id" string="UoM" force_save="1" readonly="state != 'draft' and id" groups="uom.group_uom" optional="hide"/>
            </xpath>
            <xpath expr="//field[@name='lot_id']" position="attributes">
                <attribute name="string">Lot/SN</attribute>
                <attribute name="options">{"no_create": True}</attribute>
            </xpath>
            <xpath expr="//field[@name='result_package_id'][2]" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='owner_id']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
        </field>
    </record>


 </odoo>