<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">res.partner.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="priority" eval="100" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_type']" position="after">
                <field name="user_account_user" invisible="1" />
                <field name="user_debt_manager" invisible="1" />
                <field name="user_hr_user" invisible="1" />
                <field name="user_hr_manager" invisible="1" />
                <field name="user_purchase_manager" invisible="1" />
                <field name="user_sale_manager" invisible="1" />
                <field name="user_stock_user" invisible="1" />
                <field name="user_stock_manager" invisible="1" />
            </xpath>
            <xpath expr="//field[@name='company_type']" position="attributes">
                <attribute name="readonly">id and not user_account_user</attribute>
            </xpath>
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="readonly">id and not user_account_user</attribute>
            </xpath>
            <xpath expr="//field[@name='parent_id']" position="attributes">
                <attribute name="readonly">id and not user_account_user</attribute>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]" position="after">
                <div name="options">
                    <span id="customer_span" class="d-inline-block">
                        <field name="customer" readonly="not user_sale_manager" />
                        <label for="customer" />
                    </span>
                    <span id="competitor_span" class="d-inline-block">
                        <field name="competitor" readonly="not user_sale_manager" />
                        <label for="competitor" />
                    </span>
                    <span id="employee_span" class="d-inline-block">
                        <field name="employee" readonly="not user_hr_user" />
                        <label for="employee" />
                    </span>
                    <span id="manufacturer_span" class="d-inline-block">
                        <field name="manufacturer" readonly="not user_stock_user" />
                        <label for="manufacturer" />
                    </span>
                    <span id="supplier_span" class="d-inline-block">
                        <field name="supplier" readonly="not user_purchase_manager" />
                        <label for="supplier" />
                    </span>
                    <span id="auto_merge_span" class="d-inline-block" invisible="not customer">
                        <field name="auto_merge" groups="sales_team.group_sale_manager" />
                        <label for="auto_merge" />
                    </span>
                </div>
            </xpath>
            <xpath expr="//field[@name='vat']" position="attributes">
                <attribute name="readonly">parent_id or id and not user_account_user</attribute>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
            <xpath expr="//page[@name='sales_purchases']//group[@name='sale']" position="attributes">
                <attribute name="groups">marin.group_sale_readonly</attribute>
            </xpath>
            <xpath expr="//page[@name='sales_purchases']//field[@name='user_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
                <attribute name="readonly">not user_sale_manager</attribute>
            </xpath>
            <xpath expr="//page[@name='sales_purchases']//field[@name='user_id']" position="after">
                <field name="team_id" readonly="not user_sale_manager" />
                <field name="social_style_color" readonly="not user_sale_manager" />
                <field name="hectares"/>
                <field name="profile_id" readonly="1"/>
                <field name="factor" readonly="1"/>
            </xpath>
            <xpath expr="//page[@name='sales_purchases']//field[@name='social_style_color']" position="after">
                <field name="recent_orders_count" invisible="not customer" readonly="1" />
                <field name="days_since_last_order" invisible="not customer" readonly="1" />
            </xpath>
            <xpath expr="//page[@name='sales_purchases']//group[@name='purchase']" position="attributes">
                <attribute name="groups">marin.group_purchase_readonly</attribute>
            </xpath>
            <!-- Fix this, add the correct security group -->
            <!--<xpath expr="//page[@name='sales_purchases']//group[@name='misc']" position="attributes">
                <attribute name="groups">marin.group_account_readonly</attribute>
            </xpath>-->
            <xpath expr="//page[@name='sales_purchases']//field[@name='industry_id']" position="after">
                <field name="b2x" />
            </xpath>
<!--             <xpath expr="//page[@name='accounting']" position="attributes">
                <attribute name="groups">marin.group_sale_readonly</attribute>
            </xpath>
 -->            <xpath expr="//page[@name='accounting']//field[@name='property_account_receivable_id']" position="attributes">
                <attribute name="required">False</attribute>
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
            <xpath expr="//page[@name='accounting']//field[@name='property_account_payable_id']" position="attributes">
                <attribute name="required">False</attribute>
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
            <xpath expr="//page[@name='internal_notes']" position="before">
                <page
                    name="personal_information_page"
                    string="Private information"
                    invisible="is_company"
                    groups="sales_team.group_sale_manager"
                >
                    <group>
                        <group name="personal_information_group">
                            <field name="gender" />
                            <field name="birthdate" />
                            <field name="age" invisible="not birthdate" />
                        </group>
                        <group>
                            <field name="age_range_id" invisible="not birthdate" />
                        </group>
                    </group>
                </page>
                <page
                    name="profile_classification_page"
                    string="Client Classification"
                    invisible="not is_company"
                    groups="sales_team.group_sale_manager"
                >
                    <group>
                        <group string="Current Classification">
                            <field name="profile_id" readonly="1"/>
                            <field name="factor" readonly="1"/>
                            <field name="score_total" readonly="1"/>
                            <field name="profile_change_count" readonly="1"/>
                            <field name="last_profile_change" readonly="1"/>
                        </group>
                        <group string="Score Breakdown">
                            <field name="score_hectares" readonly="1"/>
                            <field name="score_categories" readonly="1"/>
                            <field name="hectares"/>
                        </group>
                    </group>
                    <group string="Profile Change History">
                        <field name="profile_history_ids" nolabel="1">
                            <list string="Profile Changes" create="false" edit="false" delete="false">
                                <field name="change_date"/>
                                <field name="old_profile_id"/>
                                <field name="new_profile_id"/>
                                <field name="old_score_total"/>
                                <field name="new_score_total"/>
                                <field name="change_trigger"/>
                                <field name="user_id"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_partner_property_form_marin" model="ir.ui.view">
        <field name="name">res.partner.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.view_partner_property_form" />
        <field name="priority" eval="100" />
        <field name="arch" type="xml">
            <xpath expr="//group[@name='credit_limits']" position="attributes">
                <attribute name="groups">account.group_account_readonly,marin.group_account_debt_manager,sales_team.group_sale_salesman_all_leads</attribute>
            </xpath>
            <xpath expr="//field[@name='use_partner_credit_limit']" position="attributes">
                <attribute name="readonly">not user_debt_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='credit_limit']" position="attributes">
                <attribute name="invisible">not use_partner_credit_limit</attribute>
                <attribute name="readonly">not user_debt_manager</attribute>
                <attribute name="required">use_partner_credit_limit</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_res_partner_filter_customer_merge" model="ir.ui.view">
        <field name="name">res.partner.search.customer.merge</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter" />
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="after">
                <separator/>
                <filter string="Auto-merge Enabled" name="auto_merge_enabled" domain="[('auto_merge', '=', True)]" help="Customers with auto-merge enabled"/>
            </xpath>
        </field>
    </record>
    
    <!-- Sale Target Wizard -->
    <record id="view_sale_target_wizard_form" model="ir.ui.view">
        <field name="name">sale.target.wizard.form</field>
        <field name="model">sale.target.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Sale Targets">
                <sheet>
                    <div class="oe_title">
                        <h1>Generate Sale Targets</h1>
                    </div>
                    <group>
                        <group string="Target Configuration">
                            <field name="template_id" required="1"/>
                            <field name="date_from" readonly="1"/>
                            <field name="date_to" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Selected Clients"/>
                    <field name="partner_ids" nolabel="1">
                        <list>
                            <field name="name"/>
                            <field name="hectares"/>
                            <field name="profile_id"/>
                            <field name="factor"/>
                        </list>
                    </field>
                    <group string="Validation" invisible="not validation_errors">
                        <field name="validation_errors" nolabel="1" widget="text" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_generate_targets" 
                            string="Generate Targets" 
                            type="object" 
                            class="btn-primary"
                            invisible="validation_errors"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    
    <!-- Partner Category List View Extension -->
    <record id="view_partner_category_list_scoring" model="ir.ui.view">
        <field name="name">res.partner.category.list.scoring</field>
        <field name="model">res.partner.category</field>
        <field name="inherit_id" ref="base.view_partner_category_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='color']" position="after">
                <field name="score_value" string="Score" invisible="not scoring_active"/>
                <field name="scoring_active" string="Scoring Active" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>
    
    <!-- Hectares Range Views -->
    <record id="view_res_partner_hectares_range_form" model="ir.ui.view">
        <field name="name">res.partner.hectares.range.form</field>
        <field name="model">res.partner.hectares.range</field>
        <field name="arch" type="xml">
            <form string="Hectares Range">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="name" placeholder="e.g., Small Producer"/>
                            <field name="score_value" required="1"/>
                        </group>
                        <group string="Hectares Range">
                            <field name="min_hectares" required="1"/>
                            <field name="max_hectares"/>
                        </group>
                    </group>
                    <group>
                        <group string="Settings">
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group></group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_res_partner_hectares_range_list" model="ir.ui.view">
        <field name="name">res.partner.hectares.range.list</field>
        <field name="model">res.partner.hectares.range</field>
        <field name="arch" type="xml">
            <list string="Hectares Ranges" multi_edit="1">
                <field name="name"/>
                <field name="min_hectares"/>
                <field name="max_hectares"/>
                <field name="score_value"/>
                <field name="active"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="action_res_partner_hectares_range" model="ir.actions.act_window">
        <field name="name">Hectares Ranges</field>
        <field name="res_model">res.partner.hectares.range</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new hectares range
            </p>
        </field>
    </record>
    
    <!-- Profile History Views -->
    <record id="view_res_partner_profile_history_list" model="ir.ui.view">
        <field name="name">res.partner.profile.history.list</field>
        <field name="model">res.partner.profile.history</field>
        <field name="arch" type="xml">
            <list string="Profile History" create="false" edit="false" delete="false">
                <field name="change_date"/>
                <field name="partner_id"/>
                <field name="old_profile_id"/>
                <field name="new_profile_id"/>
                <field name="old_score_total"/>
                <field name="new_score_total"/>
                <field name="change_trigger"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="action_res_partner_profile_history" model="ir.actions.act_window">
        <field name="name">Profile History</field>
        <field name="res_model">res.partner.profile.history</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="partner_view_buttons_marin" model="ir.ui.view">
        <field name="name">res.partner.form.buttons.marin</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.partner_view_buttons" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_view_partner_invoices']" position="attributes">
                <attribute name="groups" separator="," add="sales_team.group_sale_salesman_all_leads" />
            </xpath>
        </field>
    </record>

</odoo>
