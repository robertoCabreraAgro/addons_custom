<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- TODO: Temporarily commented out - transfer_state field no longer exists in Odoo 18.4
         Need to review what replaced this field for purchase order reception status tracking
    <record id="purchase_order_view_search_marin" model="ir.ui.view">
        <field name="name">purchase.order.select.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_view_search" />
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='starred']" position="after">
                <separator />
                <filter name="to_receive" string="To receive"
                    domain="[('transfer_state', '=', 'to do')]" />
                <filter name="partially_received" string="Partially received"
                    domain="[('transfer_state', '=', 'partially')]" />
                <filter name="received" string="Received"
                    domain="[('transfer_state', '=', 'done')]" />
                <filter name="over_received" string="Over Received"
                    domain="[('transfer_state', '=', 'over done')]" />
                <separator />
            </xpath>
            <xpath expr="//group/filter[@name='order_date']" position="after">
                <separator />
                <filter name="status" string="Status"
                    domain="[]" context="{'group_by': 'state'}" />
                <filter name="invoice_state" string="Billing Status"
                    domain="[]" context="{'group_by': 'invoice_state'}" />
                <filter name="transfer_state" string="Reception Status"
                    domain="[]" context="{'group_by': 'transfer_state'}" />
            </xpath>
        </field>
    </record>
    -->

    <record id="purchase_order_view_list" model="ir.ui.view">
        <field name="name">purchase.order.view.list</field>
        <field name="model">purchase.order</field>
        <field name="arch" type="xml">
            <list
                string="Purchase Order"
                decoration-info="state in ['draft', 'sent']"
                decoration-muted="state == 'cancel'"
                class="o_purchase_order"
                sample="1"
            >
                <header>
                    <button name="action_create_invoice" type="object" string="Create Bills" />
                </header>
                <field
                    name="company_id"
                    column_invisible="True"
                    readonly="state in ['cancel', 'done', 'purchase']"
                    groups="!base.group_multi_company"
                />
                <field name="state" column_invisible="True" />
                <field name="priority" widget="priority" nolabel="1" optional="show" />
                <field
                    name="name"
                    string="Reference"
                    readonly="1"
                    decoration-bf="1"
                    decoration-info="state in ('draft','sent')"
                />
                <field name="partner_id" readonly="state in ['cancel', 'done', 'purchase']" />
                <field name="partner_ref" optional="hide" />
                <field name="origin" optional="hide" />
                <field
                    name="date_order"
                    column_invisible="not context.get('quotation_only', False)"
                    readonly="state in ['cancel', 'done', 'purchase']"
                    optional="show"
                />
                <field
                    name="date_approve"
                    widget="date"
                    column_invisible="context.get('quotation_only', False)"
                    optional="show"
                />
                <field name="date_planned" column_invisible="context.get('quotation_only', False)" optional="show" />
                <field
                    name="amount_untaxed"
                    sum="Total untaxed amount"
                    string="Untaxed"
                    widget="monetary"
                    optional="hide"
                />
                <field name="amount_total" sum="Total amount" widget="monetary" optional="show" decoration-bf="1" />
                <field name="currency_id" column_invisible="True" readonly="state in ['cancel', 'done', 'purchase']" />
                <field name="user_id" widget="many2one_avatar_user" optional="show" />
                <field name="activity_ids" widget="list_activity" optional="hide" />
                <field name="activity_exception_decoration" widget="activity_exception" />
                <field
                    name="state"
                    widget="badge"
                    decoration-success="state == 'purchase'"
                    decoration-info="state == 'draft'"
                    decoration-warning="state == 'to approve'"
                    optional="show"
                />
                <!-- TODO: Temporarily commented out - transfer_state field no longer exists in Odoo 18.4
                <field
                    name="transfer_state"
                    widget="badge"
                    decoration-success="transfer_state=='done'"
                    decoration-info="transfer_state!='to do'"
                    decoration-warning="transfer_state!='partially'"
                    decoration-danger="transfer_state!='over done'"
                    optional="show"
                />
                -->
                <field
                    name="invoice_status"
                    widget="badge"
                    decoration-success="invoice_status == 'invoiced'"
                    decoration-info="invoice_status == 'to invoice'"
                    optional="show"
                />
                <field name="payment_term_id" optional="hide" />
                <field
                    name="company_id"
                    options="{'no_create': True}"
                    readonly="state in ['cancel', 'done', 'purchase']"
                    optional="show"
                    groups="base.group_multi_company"
                />
            </list>
        </field>
    </record>

    <record id="purchase_order_form_marin" model="ir.ui.view">
        <field name="name">purchase.order.form.marin</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form" />
        <field name="priority" eval="100" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_view_invoice']" position="after">
                <button name="action_view_approval"
                    type="object" class="oe_stat_button"
                    icon="fa-credit-card"
                    invisible="count_approval == 0"
                    groups="base_approval.group_approval_user">
                    <field name="count_approval" string="Approval"
                        groups="base_approval.group_approval_user" widget="statinfo" />
                </button>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
            <!-- TODO: journal_id field removed - was a custom field that no longer exists
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="journal_id"
                    required="state == 'draft'"
                    readonly="state in ['purchase', 'cancel']"
                    options="{'no_create': True}" />
            </xpath>
            -->
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
                <attribute name="readonly">not is_user_id_editable</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
            <xpath expr="//page/field[@name='order_line']/list/field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
            <xpath expr="//page/field[@name='order_line']/list/field[@name='product_uom_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
            <xpath
                expr="//page/field[@name='order_line']/list/field[@name='price_unit']"
                position="after"
            >
                <field name="partner_id" column_invisible="1" />
                <widget name="purchase_line_price_history_widget" width="20px" />
            </xpath>
            <!-- TODO: Temporarily commented out - transfer_state field no longer exists in Odoo 18.4
            <xpath expr="//page/field[@name='line_ids']/list/field[@name='qty_invoiced']" position="after">
                <field name="transfer_state" column_invisible="1" />
            </xpath>
            -->
	    <!--<xpath expr="//page/field[@name='line_ids']/list/field[@name='qty_invoiced']" position="attributes">
                <attribute name="decoration-danger">not display_type and invoice_state == 'over done'</attribute>
                <attribute name="decoration-warning">not display_type and invoice_state == 'to do'</attribute>
                <attribute name="decoration-success">not display_type and invoice_state == 'done'</attribute>
            </xpath>
            <xpath expr="//page/field[@name='line_ids']/list/field[@name='qty_transfered']" position="attributes">
                <attribute name="decoration-danger">not display_type and transfer_state == 'to do'</attribute>
                <attribute name="decoration-warning">not display_type and transfer_state == 'partially'</attribute>
                <attribute name="decoration-info">not display_type and transfer_state == 'over done'</attribute>
                <attribute name="decoration-success">not display_type and transfer_state == 'done'</attribute>
	    </xpath>-->
            <field name="user_id" position="before">
                <field name="is_user_id_editable" invisible="1" />
            </field>
        </field>
    </record>

    <!-- TODO: Temporarily commented out - transfer_state field no longer exists in Odoo 18.4
         Need to review what replaced this field for purchase order reception status tracking
    <record id="purchase_order_view_form_inherit_marin" model="ir.ui.view">
        <field name="name">purchase.order.form</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase_stock.purchase_order_view_form_inherit" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='transfer_state']" position="replace">
                <label for="transfer_state" invisible="state not in ('purchase', 'done')" />
                <div name="transfer_state_div" class="d-flex" invisible="state not in ('purchase', 'done')">
                    <field name="transfer_state" />
                    <button
                        name="action_force_transfer_state"
                        string="Force reception done"
                        type="object"
                        class="btn-link d-block"
                        invisible="transfer_state == 'done' or state not in ('purchase', 'done')"
                        groups="marin.group_purchase_force_transfer_state"
                    />
                    <button
                        name="action_unforce_transfer_state"
                        string="Unforce reception done"
                        type="object"
                        class="btn-link d-block"
                        invisible="transfer_state != 'done'"
                        groups="marin.group_purchase_force_transfer_state"
                    />
                </div>
            </xpath>
        </field>
    </record>
    -->

    <record id="purchase_form_action" model="ir.actions.act_window">
        <field name="name">Purchase Orders</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">list,kanban,form,pivot,graph,calendar,activity</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('marin.purchase_order_view_list')}),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('purchase.purchase_order_view_kanban_without_dashboard')}),
        ]"
        />
        <field name="search_view_id" ref="purchase.purchase_order_view_search" />
        <field name="context">{}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            No purchase order found. Let's create one!
          </p><p>
            Once you ordered your products to your supplier, confirm your request for quotation and it will turn into a purchase order.
          </p>
        </field>
    </record>
</odoo>
