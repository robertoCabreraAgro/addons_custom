<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Form view -->
    <record id="view_stock_picking_tracker_form" model="ir.ui.view">
        <field name="name">stock.picking.tracker.form</field>
        <field name="model">stock.picking.tracker</field>
        <field name="arch" type="xml">
            <form string="Picking Route Tracker">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_done" string="Done" type="object" class="btn-primary" invisible="state != 'in_progress'"/>
                    <button name="action_draft" string="Set to Draft" type="object" class="btn-secondary" invisible="state != 'cancel'"/>
                    <button name="action_cancel" string="Cancel" type="object" class="btn-danger" invisible="state in ['done', 'cancel']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_pickings"
                            string="Pickings"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-truck">
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="scheduled_date" readonly="state != 'draft'"/>
                            <field name="picking_type_id" readonly="state != 'draft'"/>
                            <field name="user_id" readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company" invisible="1"/>
                        </group>
                        <group>
                            <field name="vehicle_id" readonly="state != 'draft'" required="state != 'draft'"/>
                            <field name="driver_id" readonly="state != 'draft'" required="state != 'draft'"/>
                            <field name="driver_department_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Transfers" name="transfers">
                            <field name="allowed_picking_ids" invisible="1" />
                            <field name="picking_ids" readonly="state != 'draft'" widget="many2many">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="location_id"/>
                                    <field name="location_dest_id"/>
                                    <field name="scheduled_date"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Route Information" name="route_info">
                            <group>
                                <group string="Start Data">
                                    <field name="date_start" readonly="state != 'draft'"/>
                                    <label for="odometer_start"/>
                                    <div class="o_row">
                                        <field name="odometer_start" readonly="state != 'draft'"/>
                                        <field name="odometer_uom_id"/>
                                        <button name="action_update_odometer_start" type="object" class="btn-link" string="⟳ Update" invisible="state != 'draft'"/>
                                    </div>
                                    <label for="fuel_start"/>
                                    <div class="o_row">
                                        <field name="fuel_start" readonly="state != 'draft'"/>
                                        <span>%</span>
                                        <button name="action_update_fuel_start" type="object" class="btn-link" string="⟳ Update" invisible="state != 'draft'"/>
                                    </div>
                                </group>
                                <group string="End Data">
                                    <field name="date_end" readonly="state != 'in_progress'"/>
                                    <label for="odometer_end"/>
                                    <div class="o_row">
                                        <field name="odometer_end" readonly="state != 'in_progress'"/>
                                        <field name="odometer_uom_id"/>
                                        <button name="action_update_odometer_end" type="object" class="btn-link" string="⟳ Update" invisible="state != 'in_progress'"/>
                                    </div>
                                    <label for="fuel_end"/>
                                    <div class="o_row">
                                        <field name="fuel_end" readonly="state != 'in_progress'"/>
                                        <span>%</span>
                                        <button name="action_update_fuel_end" type="object" class="btn-link" string="⟳ Update" invisible="state != 'in_progress'"/>
                                    </div>
                                </group>
                            </group>
                        </page>
                        <page string="Analytics" name="analytics">
                            <group>
                                <group string="Distance">
                                    <label for="odometer_difference"/>
                                    <div class="o_row">
					<field name="odometer_difference" />
                                        <field name="odometer_uom_id"/>
                                    </div>
                                    <label for="empty_distance"/>
                                    <div class="o_row">
                                    	<field name="empty_distance"/>
                                        <field name="odometer_uom_id"/>
                                    </div>
                                </group>
                                <group string="Fuel">
                                    <label for="fuel_consumption"/>
                                    <div class="o_row">
                                        <field name="fuel_consumption" />
                                        <field name="fuel_uom_id"/>
                                    </div>
			            <label for="empty_fuel" />
                                    <div class="o_row">
                                        <field name="empty_fuel" />
                                        <field name="fuel_uom_id"/>
                                    </div>
                                    <label for="fuel_efficiency"/>
                                    <div class="o_row">
                                        <field name="fuel_efficiency" />
                                        <field name="fuel_efficiency_uom_id"/>
                                    </div> 
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Add notes here..."/>
                        </page>
                    </notebook>
                </sheet>
		<chatter />
            </form>
        </field>
    </record>

    <!-- List view (previously tree view) -->
    <record id="view_stock_picking_tracker_list" model="ir.ui.view">
        <field name="name">stock.picking.tracker.list</field>
        <field name="model">stock.picking.tracker</field>
        <field name="arch" type="xml">
            <list decoration-info="state=='draft'" decoration-muted="state=='cancel'" decoration-warning="state=='in_progress'" decoration-success="state=='done'">
                <field name="name"/>
                <field name="scheduled_date"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="picking_type_id"/>
                <field name="odometer_difference"/>
                <field name="fuel_consumption"/>
                <field name="fuel_efficiency"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_stock_picking_tracker_search" model="ir.ui.view">
        <field name="name">stock.picking.tracker.search</field>
        <field name="model">stock.picking.tracker</field>
        <field name="arch" type="xml">
            <search string="Search Route Trackers">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="picking_type_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="In Progress" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancel')]"/>
                <separator/>
                <filter string="Today" name="today" domain="[('date_start', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="this_week" domain="[('date_start', '&gt;=', (context_today() + relativedelta(days=-6, weekday=0)).strftime('%Y-%m-%d'))]"/>
                <filter string="This Month" name="this_month" domain="[('date_start', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="status" context="{'group_by': 'state'}"/>
                    <filter string="Vehicle" name="vehicle" context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Driver" name="driver" context="{'group_by': 'driver_id'}"/>
                    <filter string="Operation Type" name="picking_type" context="{'group_by': 'picking_type_id'}"/>
                    <filter string="Date" name="date" context="{'group_by': 'date_start:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_stock_picking_tracker" model="ir.actions.act_window">
        <field name="name">Picking Route Trackers</field>
        <field name="res_model">stock.picking.tracker</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_draft': 1, 'search_default_in_progress': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new picking route tracker
            </p>
            <p>
                Track your routes, analyze fuel efficiency, and optimize delivery paths.
            </p>
        </field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_stock_picking_tracker"
        name="Route Tracking"
        parent="stock.menu_stock_transfers"
        action="action_stock_picking_tracker"
        groups="group_stock_picking_tracker_manager"
        sequence="50"/>

</odoo>
