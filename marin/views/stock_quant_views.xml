<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="quant_search_view" model="ir.ui.view">
        <field name="name">stock.quant.search</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.quant_search_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='productcategorygroup']" position="after">
                <field name="product_id" string="Manufacturer"
                    filter_domain="[('product_id.product_tmpl_id.manufacturer_id','ilike',self)]" />
                <field name="product_id" string="Tags"
                    filter_domain="[('product_id.product_tmpl_id.product_tag_ids','ilike',self)]" />
            </xpath>
            <xpath expr="//filter[@name='productgroup']" position="before">
                <filter name="warehousegroup" string='Warehouse'
                    context="{'group_by': 'warehouse_id'}" />
            </xpath>
        </field>
    </record>

    <!-- Location Report view -->
    <record id="view_stock_quant_tree_editable" model="ir.ui.view">
        <field name="name">stock.quant.inventory.list.marin</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_editable" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_uom_id']" position="after">
                <field name="value_standard" optional="hidden" sum="Total Value" />
            </xpath>
        </field>
    </record>

    <!-- Inventory Adjustments + Update Quantity (via product) view -->
    <record id="view_stock_quant_tree_inventory_editable" model="ir.ui.view">
        <field name="name">stock.quant.inventory.list.editable</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_inventory_editable" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_stock_quant_lot_update" string="Change Lot"
                    type="object"
                    groups="marin.group_stock_inventory_adjustment_lot" />
            </xpath>
            <xpath expr="//field[@name='package_id']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='owner_id']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='product_uom_id']" position="after">
                <field name="value_standard" optional="hidden" sum="Total Value" />
            </xpath>
            <xpath expr="//button[@name='action_apply_inventory']" position="attributes">
                <attribute name="groups">marin.group_stock_inventory_adjustment</attribute>
            </xpath>
            <xpath expr="//button[@name='stock.action_stock_inventory_adjustement_name']"
                position="attributes">
                <attribute name="groups">marin.group_stock_inventory_adjustment</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_stock_quant_tree_simple" model="ir.ui.view">
        <field name="name">stock.quant.inventory.list.marin</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_simple" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='package_id']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='owner_id']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
        </field>
    </record>

</odoo>