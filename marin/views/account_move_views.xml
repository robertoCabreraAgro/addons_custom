<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_account_move_filter" model="ir.ui.view">
        <field name="name">account.move.select</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_move_filter" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="invoice_line_ids" string="Product"
                    filter_domain="[('invoice_line_ids.product_id', 'ilike', self)]" />
                <field name="invoice_line_ids" string="Account"
                    filter_domain="[('invoice_line_ids.account_id', 'ilike', self)]" />
            </xpath>
            <xpath expr="//filter[@name='posted']" position="after">
                <separator />
                <filter name="real" string="Real"
                    domain="[('journal_id.x_treatment', 'in', ('not_fiscal_real', 'fiscal_real'))]" />
                <filter name="fiscal" string="Fiscal"
                    domain="[('journal_id.x_treatment', 'in', ('fiscal_real', 'fiscal_simulated'))]" />
                <filter name="not_fiscal" string="Not Fiscal"
                    domain="[('journal_id.x_treatment', 'in', ('not_fiscal_real', 'not_fiscal_simulated'))]" />
                <separator />
                <filter name="to_store" string="To store"
                    domain="[('x_stored', '=', False)]" />
            </xpath>
            <xpath expr="//group/filter[@name='partner']" position="before">
                <filter name="groupby_commercial_partner" string="Commercial Partner"
                    context="{'group_by':'commercial_partner_id'}" />
            </xpath>
        </field>
    </record>

    <record id="view_account_invoice_filter" model="ir.ui.view">
        <field name="name">account.invoice.select</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="invoice_line_ids" string="Product"
                    filter_domain="[('invoice_line_ids.product_id', 'ilike', self)]" />
                <field name="invoice_line_ids" string="Account"
                    filter_domain="[('invoice_line_ids.account_id', 'ilike', self)]" />
            </xpath>
            <xpath expr="//filter[@name='late']" position="after">
                <separator />
                <filter name="real" string="Real"
                    domain="[('journal_id.x_treatment', 'in', ('not_fiscal_real', 'fiscal_real'))]" />
                <filter name="fiscal" string="Fiscal"
                    domain="[('journal_id.x_treatment', 'in', ('fiscal_real', 'fiscal_simulated'))]" />
                <filter name="not_fiscal" string="Not Fiscal"
                    domain="[('journal_id.x_treatment', 'in', ('not_fiscal_real', 'not_fiscal_simulated'))]" />
            </xpath>
            <xpath expr="//group/filter[@name='salesperson']" position="before">
                <filter name="groupby_commercial_partner" string="Commercial Partner"
                    context="{'group_by':'commercial_partner_id'}" />
                <filter name="groupby_partner" string="Partner" context="{'group_by':'partner_id'}" />
                <filter name="groupby_journal" string="Journal" context="{'group_by':'journal_id'}" />
            </xpath>
        </field>
    </record>

    <record id="view_invoice_tree" model="ir.ui.view">
        <field name="name">account.invoice.list</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree" />
        <field name="priority" eval="100" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <field name="journal_id" optional="hide" />
            </xpath>
            <xpath expr="//field[@name='company_id']" position="replace">
            </xpath>
            <xpath expr="//field[@name='move_type']" position="after">
                <field name="invoice_payment_term_id" optional="hide" />
                <field name="company_id" optional="hide" />
            </xpath>
            <xpath expr="//field[@name='amount_untaxed_in_currency_signed']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_total_in_currency_signed']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_residual_signed']" position="attributes">
                <attribute name="optional">show</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_date_due']" position="attributes">
                <attribute name="invisible">
                    payment_state in ['paid', 'in_payment', 'reversed'] or state == 'cancel'
                </attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_origin']" position="after">
                <field name="l10n_mx_edi_cfdi_origin" optional="hide" />
            </xpath>
        </field>
    </record>

    <record id="view_move_form" model="ir.ui.view">
        <field name="name">account.invoice.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="priority" eval="100" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='button_cancel'][1]" position="attributes">
                <attribute name="groups">marin.group_account_move_cancel</attribute>
            </xpath>
            <xpath expr="//button[@name='button_cancel'][2]" position="attributes">
                <attribute name="groups">marin.group_account_move_cancel</attribute>
            </xpath>
            <xpath expr="//button[@name='button_draft']" position="attributes">
                <attribute name="groups">marin.group_account_move_draft</attribute>
            </xpath>
            <xpath expr="//button[@name='button_set_checked']" position="after">
                <button
                    name="button_set_stored"
                    string="Stored"
                    type="object"
                    invisible="x_stored"
                    groups="marin.group_account_customer_invoice"
                />
            </xpath>
            <xpath expr="//header" position="inside">
                <field name="count_purchase_order" invisible="1" />
                <button
                    name="action_cash_discount_wizard"
                    string="Cash Discount"
                    type="object"
                    class="oe_highlight"
                    invisible="move_type != 'out_invoice' or state not in ['posted', 'draft'] or payment_state in ['paid', 'in_payment']"
                    groups="marin.group_account_move_cash_discount" />
                <button
                    name="create_purchase_order"
                    string="Create Purchase"
                    type="object"
                    class="oe_highlight"
                    invisible="move_type != 'in_invoice' or state != 'posted' or count_purchase_order != 0" />
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_move_lines" string="Move Lines"
                    type="object" class="oe_stat_button"
                    icon="fa-list-ul"
                    invisible="not id" />
                <button name="action_view_approval"
                    type="object" class="oe_stat_button"
                    icon="fa-credit-card"
                    invisible="count_approval == 0"
                    groups="base_approval.group_approval_user">
                    <field name="count_approval" string="Approval" widget="statinfo"
                        groups="base_approval.group_approval_user" />
                </button>
            </xpath>
            <xpath expr="//button[@name='action_view_source_purchase_orders']" position="attributes">
                <attribute name="groups" separator="," add="account.group_account_user" />
            </xpath>
            <xpath expr="//field[@name='id']" position="after">
                <field name="journal_type" invisible="1" />
                <field name="show_update_line_account" invisible="1" />
            </xpath>
            <xpath expr="//group[@id='header_left_group']/label[@for='partner_id']" position="after">
                <label for="partner_id" string="Partner" style="font-weight:bold;" invisible="move_type != 'entry'" />
            </xpath>
            <xpath expr="//group[@id='header_left_group']/div[hasclass('o_col')]" position="attributes">
                <attribute name="invisible">False</attribute>
            </xpath>
            <xpath expr="//group[@id='header_left_group']//field[@name='partner_id']" position="after">
                <attribute name="invisible">False</attribute>
            </xpath>
            <xpath expr="//group[@id='header_right_group']/field[@name='date']" position="attributes">
                <attribute name="invisible">False</attribute>
            </xpath>
            <xpath expr="//group[@id='header_right_group']//field[@name='partner_bank_id']" position="attributes">
                <attribute
                    name="invisible"
                >move_type not in ['in_invoice', 'in_refund', 'in_receipt'] or journal_type not in ['bank', 'cash']</attribute>
                <attribute name="readonly">state != 'draft'</attribute>
            </xpath>
            <xpath
                expr="//group[@id='header_right_group']//field[@name='invoice_payment_term_id']"
                position="attributes"
            >
                <attribute name="options">{"no_create": True}</attribute>
            </xpath>
            <xpath
                expr="//group[@id='header_right_group']//field[@name='journal_id']"
                position="after"
            >
                <button name="action_update_line_account" string="Update Lines"
                    type="object" class="btn-link mb-1 px-0" icon="fa-refresh"
                    invisible="not show_update_line_account or state in ['posted', 'cancel']"
                    confirm="This will update the accounts of all lines based on the new journal."
                    help="Recompute all accounts based on this journal" />
            </xpath>
            <xpath
                expr="//page[@id='invoice_tab']/field[@name='invoice_line_ids']/list/field[@name='product_id']"
                position="attributes"
            >
                <attribute name="options">{"no_create": True}</attribute>
            </xpath>
            <xpath
                expr="//page[@id='invoice_tab']/field[@name='invoice_line_ids']/list/field[@name='product_uom_id'][1]"
                position="attributes"
            >
                <attribute name="options">{"no_create": True}</attribute>
            </xpath>
            <xpath
                expr="//page[@id='invoice_tab']/field[@name='invoice_line_ids']/list/field[@name='price_unit']"
                position="after"
            >
                <widget name="invoice_line_price_history_widget" width="20px" />
            </xpath>
            <xpath expr="//group[hasclass('oe_subtotal_footer')]/field[@name='margin']" position="attributes">
                <attribute name="invisible">move_type not in ['out_invoice', 'out_refund', 'out_receipt']</attribute>
                <attribute name="groups">marin.group_product_cost_readonly</attribute>
            </xpath>
            <xpath expr="//page[@id='aml_tab']//list//field[@name='account_id']" position="attributes">
                <attribute name="options">{"no_create": True}</attribute>
            </xpath>
            <xpath expr="//page[@id='other_tab']//group[@name='sale_info_group']" position="attributes">
                <attribute name="invisible">False</attribute>
            </xpath>
            <xpath expr="//page[@id='other_tab']//field[@name='invoice_origin']" position="attributes">
                <attribute name="invisible">False</attribute>
            </xpath>
            <xpath expr="//page[@id='other_tab']//field[@name='checked']" position="after">
                <field name="x_stored" />
            </xpath>
            <xpath
                expr="//field[@name='invoice_line_ids']/list/field[@name='l10n_mx_edi_qty_umt']"
                position="attributes"
            >
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath
                expr="//field[@name='invoice_line_ids']/list/field[@name='l10n_mx_edi_umt_aduana_id']"
                position="attributes"
            >
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath
                expr="//field[@name='invoice_line_ids']/list/field[@name='l10n_mx_edi_customs_number']"
                position="attributes"
            >
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//label[@name='invoice_vendor_bill_id_label']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_vendor_bill_id']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='tax_ids']" position="after">
                <field name="allowed_sale_line_ids" column_invisible="True" />
                <field
                    name="sale_line_ids"
                    domain="[['id', 'in', allowed_sale_line_ids]]"
                    options="{'no_create': True, 'no_open': True', no_edit':True}"
                    readonly="parent.state != 'draft'"
                    widget="many2many_tags"
                    column_invisible="parent.move_type != 'out_invoice'"
                    optional="show"
                    groups="account.group_account_user"
                />
            </xpath>
        </field>
    </record>

    <record id="account_move_form_inherit_l10n_mx_edi" model="ir.ui.view">
        <field name="name">account.move.form.inherit.l10n_mx_edi</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_mx_edi.account_move_form_inherit_l10n_mx_edi" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='l10n_mx_edi_payment_policy']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
            <xpath expr="//field[@name='l10n_mx_edi_payment_policy']" position="after">
                <field name="force_payment_policy_pue"
                    invisible="l10n_mx_edi_payment_policy in ('PUE', False)" />
            </xpath>
        </field>
    </record>

    <record id="view_move_form_2" model="ir.ui.view">
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account_invoice_margin.view_move_form" />
        <field name="arch" type="xml">
            <xpath
                expr="//field[@name='purchase_price']"
                position="attributes"
            >
                <attribute name="column_invisible">parent.move_type not in ['out_invoice','out_refund']</attribute>
                <attribute name="optional">hide</attribute>
                <attribute name="groups">marin.group_product_cost_readonly</attribute>
            </xpath>
            <xpath
                expr="//field[@name='purchase_price'][1]"
                position="attributes"
            >
                <attribute name="groups">marin.group_product_cost_readonly</attribute>
            </xpath>
        </field>
    </record>

    <!-- This is a fix, remove when Odoo notices -->
    <record id="view_l10n_mx_edi_invoice_form_inherit" model="ir.ui.view">
        <field name="model">account.move</field>
        <field name="inherit_id" ref="l10n_mx_edi_extended.view_l10n_mx_edi_invoice_form_inherit" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='l10n_mx_edi_qty_umt']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='l10n_mx_edi_umt_aduana_id']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='l10n_mx_edi_customs_number']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='l10n_mx_edi_qty_umt'][1]" position="attributes">
                <attribute name="column_invisible">parent.l10n_mx_edi_external_trade_type not in ['02', '03']</attribute>
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='l10n_mx_edi_umt_aduana_id'][1]" position="attributes">
                <attribute name="column_invisible">parent.l10n_mx_edi_external_trade_type not in ['02', '03']</attribute>
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='l10n_mx_edi_customs_number'][1]" position="attributes">
                <attribute name="column_invisible">parent.move_type not in ('out_invoice', 'out_refund')</attribute>
                <attribute name="optional">hide</attribute>
            </xpath>

        </field>
    </record>
</odoo>
