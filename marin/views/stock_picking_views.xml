<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_picking_tree_marin" model="ir.ui.view">
        <field name="name">stock.picking.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_assign']" position="after">
                <button name="action_view_moves" string="View Moves" type="object"  />
            </xpath>
        </field>
    </record>

    <record id="view_picking_form" model="ir.ui.view">
        <field name="name">stock.picking.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="after">
                <div invisible="1">
                    <field name="purchase_id" invisible="1" />
                    <field name="sale_id" invisible="1" />
                    <field name="show_purchase_lines" invisible="True" />
                    <field name="show_sale_lines" invisible="True" />
                    <field name="show_mark_as_todo" invisible="True" />
                    <field name="show_validate" invisible="True" />
                    <field name="suitable_product_ids" invisible="True" />
                </div>
            </xpath>
            <xpath expr="//button[@name='action_confirm']" position="attributes">
                <attribute name="invisible">not show_mark_as_todo</attribute>
            </xpath>
            <xpath expr="//button[@name='button_validate']" position="attributes">
                <attribute name="invisible">not show_validate</attribute>
            </xpath>
            <xpath expr="//button[@name='button_validate'][2]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='button_validate'][2]" position="after">
                <button name="do_unreserve" string="Unreserve"
                    type="object" class="o_highlight"
                    invisible="state not in ('confirmed', 'assigned')"
                    groups="stock.group_stock_user" />
                <button name="action_draft" string="Draft"
                    type="object" class="o_highlight"
                    data-hotkey="d"
                    invisible="state != 'cancel'"
                    groups="stock.group_stock_user" />
            </xpath>
<!--             <xpath expr="//button[@name='do_print_picking']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='%(stock.action_report_delivery)d']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
 -->            <xpath expr="//header" position="after">
                <div class="alert alert-warning" role="alert" invisible="waiting_warning == ''">
                    <field name="waiting_warning" />
                </div>
            </xpath>
            <xpath expr="//field[@name='picking_type_id']" position="after">
                <field name="all_product_ids"
                    invisible="picking_type_code != 'internal'" />
            </xpath>
            <xpath expr="//page[@name='operations']/field[@name='move_ids_without_package']/list/field[@name='product_id']" position="attributes">
                <attribute name="options">{"no_create": True}</attribute>
                <attribute name="domain">[('id', 'in', (parent.suitable_product_ids))]</attribute>
            </xpath>
        </field>
    </record>

