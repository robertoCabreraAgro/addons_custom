<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_asset_log_list_view" model="ir.ui.view">
        <field name="name">product.asset.log.list</field>
        <field name="model">product.asset.log</field>
        <field name="inherit_id" ref="product_asset.view_list_product_asset_log" />
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="qty_fuel" optional="hidden" />
                <field name="efficiency" optional="hidden" />
                <field name="vendor_id" optional="hidden" />
            </xpath>
            <xpath expr="//field[@name='operator_id']" position="attributes">
                <attribute name="invisible" />
            </xpath>
        </field>
    </record>
</odoo>
