<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="approval_request_view_tree" model="ir.ui.view">
        <field name="name">approval.request.tree.inherit</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="base_approval.approval_request_view_tree" />
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="vehicle_id"
                    optional="hide" />
                <field name="odometer" string="Odometer"
                    optional="hide" />
            </xpath>
        </field>
    </record>

    <record id="approval_request_view_form" model="ir.ui.view">
        <field name="name">approval.request.form.inherit</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="base_approval.approval_request_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='can_change_request_owner']" position="after">
                <field name="has_vehicle" invisible="1" />
                <field name="has_odometer" invisible="1" />
            </xpath>
            <xpath expr="//button[@name='action_get_attachment_view']" position="after">
                <button name="action_view_account_move"
                    type="object" class="oe_stat_button"
                    icon="fa-credit-card"
                    invisible="count_account_move == 0"
                    groups="account.group_account_basic">
                    <field name="count_account_move" string="Journal Entries"
                        widget="statinfo"
                        groups="account.group_account_basic"/>
                </button>
                <button name="action_view_purchase_order"
                    type="object" class="oe_stat_button"
                    icon="fa-credit-card"
                    invisible="count_purchase_order == 0"
                    groups="purchase.group_purchase_user">
                    <field name="count_purchase_order" string="Purchase Orders"
                        widget="statinfo"
                        groups="purchase.group_purchase_user" />
                </button>
                <button name="action_view_fleet_vehicle_log" string="Logs"
                    type="object" class="oe_stat_button"
                    icon="fa-credit-card"
                    invisible="not log_ids" />
            </xpath>
            <xpath expr="//button[@name='action_confirm']" position="after">
                <button name="action_create_account_moves" string="Create Journal Entry"
                    type="object" class="btn-primary"
                    data-hotkey="g"
                    invisible="approval_type not in ('in_invoice', 'in_refund', 'out_invoice', 'out_refund', 'entry') or request_status != 'approved' or count_account_move &gt; 0"
                    groups="account.group_account_basic" />
                <button name="action_create_purchase_orders" string="Create RFQ's"
                    type="object" class="btn-primary"
                    data-hotkey="g"
                    invisible="approval_type != 'purchase' or request_status != 'approved' or count_purchase_order &gt; 0"
                    groups="purchase.group_purchase_user" />
                <button name="action_create_fleet_vehicle_log" string="Create Log"
                    type="object" class="btn-primary"
                    data-hotkey="g"
                    invisible="approval_type != 'fleet_vehicle_log' or request_status != 'approved' or log_ids"
                    groups="purchase.group_purchase_user" />
            </xpath>
            <xpath expr="//group[@name='request_main']" position="inside">
                <field name="vehicle_id"
                    required="has_vehicle == 'required'"
                    readonly="request_status != 'new'"
                    invisible="has_vehicle == 'no'" />
                <field name="odometer"
                    required="has_odometer == 'required'"
                    readonly="request_status != 'new'"
                    invisible="has_odometer == 'no'" />
            </xpath>
        </field>
    </record>
</odoo>
