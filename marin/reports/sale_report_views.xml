<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- Inherit search view to add profile fields -->
    <record id="view_order_product_search_inherit" model="ir.ui.view">
        <field name="name">sale.report.search.inherit</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.view_order_product_search" />
        <field name="arch" type="xml">
            <!-- Add profile field to search fields -->
            <field name="product_category_id" position="after">
                <field name="profile_id" />
            </field>

            <!-- Add profile filters -->
            <filter name="fully_invoiced" position="after">
                <separator />
                <filter name="filter_with_profile" string="With Profile" domain="[('profile_id', '!=', False)]" />
                <filter name="filter_without_profile" string="Without Profile" domain="[('profile_id', '=', False)]" />
            </filter>

            <!-- Add profile grouping -->
            <filter name="Customer" position="before">
                <filter
                    name="profile"
                    string="Customer Profile"
                    context="{'group_by': 'profile_id'}"
                    groups="sales_team.group_sale_manager"
                />
            </filter>
        </field>
    </record>

    <!-- Inherit pivot view to add profile measures -->
    <record id="view_order_product_pivot_inherit" model="ir.ui.view">
        <field name="name">sale.report.pivot.inherit</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.view_order_product_pivot" />
        <field name="arch" type="xml">
            <field name="team_id" position="replace" />
            <field name="price_subtotal" position="replace">
                <field name="hectares" type="measure" groups="sales_team.group_sale_manager" />
                <field name="score_hectares" type="measure" groups="sales_team.group_sale_manager" />
                <field name="score_categories" type="measure" groups="sales_team.group_sale_manager" />
                <field name="score_total" type="measure" groups="sales_team.group_sale_manager" />
            </field>
        </field>
    </record>

    <!-- Inherit list view to add profile fields -->
    <record id="sale_report_view_tree_inherit" model="ir.ui.view">
        <field name="name">sale.report.view.list.inherit</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.sale_report_view_tree" />
        <field name="arch" type="xml">
            <!-- Add profile fields to tree view -->
            <field name="team_id" position="after">
                <field name="profile_id" optional="show" groups="sales_team.group_sale_manager" />
                <field name="hectares" optional="hide" sum="Sum of Hectares" groups="sales_team.group_sale_manager" />
                <field name="score_total" optional="hide" avg="Average Score" groups="sales_team.group_sale_manager" />
            </field>
        </field>
    </record>

    <!-- Inherit existing Sales Analysis By Customers action -->
    <record id="sale.action_order_report_customers" model="ir.actions.act_window">
        <field name="name">Sales Analysis By Customers</field>
        <field name="view_mode">pivot,graph</field>
        <field name="context">{
            'search_default_profile': 1,
            'search_default_Customer': 1,
        }</field>
    </record>
</odoo>
