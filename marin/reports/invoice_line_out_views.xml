<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_invoice_line_out_report_search_view" model="ir.ui.view">
        <field name="name">invoice.line.out.report.search.view</field>
        <field name="model">invoice.line.out.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id" operator="child_of" />
                <field name="product_id" />
                <field name="product_category_id"
                    filter_domain="[('product_category_id', 'child_of', self)]" />
                <field name="manufacturer_id" />
                <field name="move_id" />
                <field name="journal_id" />
                <filter name="out_invoices"
                    domain="[('move_type', '=', 'out_invoice')]"
                    help="Invoices" />
                <filter name="out_refunds"
                    domain="[('move_type', '=', 'out_refund')]"
                    help="Credit Notes" />
                <separator />
                <filter name="fiscal" string="Fiscal"
                    domain="[('x_treatment', 'in', ('fiscal_real', 'fiscal_simulated'))]" />
                <filter name="not_fiscal" string="Not fiscal"
                    domain="[('x_treatment', 'in', ('not_fiscal_real', 'not_fiscal_simulated'))]" />
                <separator />
                <filter name="paid_invoices"
                    domain="[('payment_state', '=', 'paid')]"
                    help="Paid Invoices" />
                <filter name="in_payment_invoices"
                    domain="[('payment_state', '=', 'in_payment')]"
                    help="In Payment Invoices" />
                <separator />
                <filter name="invoice_date" string="Invoice date"
                    date="invoice_date" />
                <filter name="later_than_a_year_ago" string="Invoice date: Last 365 days"
                    domain="[('invoice_date', '&gt;=', (datetime.datetime.combine(context_today() + relativedelta(days=-365), datetime.time(0,0,0))).strftime('%Y-%m-%d %H:%M:%S'))]" />
                <group expand="1" string="Group By">
                    <filter name="group_by_team" string="Team"
                        context="{'group_by': 'team_id'}" />
                    <filter name="group_by_user" string="Salesperson"
                        context="{'group_by': 'invoice_user_id'}" />
                    <filter name="group_by_partner" string="Partner"
                        context="{'group_by': 'partner_id'}" />
                    <filter name="group_by_commercial_partner" string="Commercial Partner"
                        context="{'group_by': 'commercial_partner_id'}" />
                    <separator />
                    <filter name="group_by_product_categ" string="Product Category"
                        context="{'group_by': 'product_category_id'}" />
                    <filter name="group_by_parent_categ" string="Parent Category"
                        context="{'group_by': 'parent_categ_id'}" />
                    <filter name="group_by_root_categ" string="Root Category"
                        context="{'group_by': 'root_categ_id'}" />
                    <filter name="group_by_move_product" string="Product"
                        context="{'group_by': 'product_id'}" />
                    <separator />
                    <filter name="group_by_move_type" string="Invoice Type"
                        context="{'group_by': 'move_type'}" />
                    <filter name="group_by_payment_state" string="Payment State"
                        context="{'group_by': 'payment_state'}" />
                    <filter name="group_by_move" string="Invoice"
                        context="{'group_by': 'move_id'}" />
                    <filter name="group_by_journal" string="Journal"
                        context="{'group_by': 'journal_id'}" />
                    <separator />
                    <filter name="group_by_invoice_date" string="Invoice date"
                        context="{'group_by': 'invoice_date'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="view_invoice_line_out_report_pivot" model="ir.ui.view">
        <field name="name">invoice.line.out.report.pivot</field>
        <field name="model">invoice.line.out.report</field>
        <field name="arch" type="xml">
            <pivot string="Invoices Analysis" sample="1">
                <field name="invoice_date" type="row" />
                <field name="quantity" type="measure" />
                <field name="price_unit" type="measure" />
                <field name="price_subtotal" type="measure" />
                <field name="price_total" type="measure" />
                <field name="purchase_price" type="measure" />
                <field name="purchase_price_total" type="measure" />
                <field name="margin" type="measure" />
            </pivot>
        </field>
    </record>

    <record id="view_invoice_line_out_report_graph" model="ir.ui.view">
        <field name="name">invoice.line.out.report.graph</field>
        <field name="model">invoice.line.out.report</field>
        <field name="arch" type="xml">
            <graph string="Invoices Analysis" type="line" sample="1">
                <field name="invoice_date" interval="day" />
                <field name="price_subtotal" type="measure" operator="+" />
                <field name="margin" type="measure" operator="+" />
            </graph>
        </field>
    </record>

    <record id="view_invoice_line_out_report_tree" model="ir.ui.view">
        <field name="name">invoice.line.out.report.tree</field>
        <field name="model">invoice.line.out.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="invoice_date" optional="show" />
                <field name="journal_id" optional="show" />
                <field name="move_type" optional="hide" />
                <field name="move_id" optional="show" />
                <field name="partner_id" optional="show" />
                <field name="manufacturer_id" optional="hide" />
                <field name="product_category_id" optional="hide" />
                <field name="product_id" optional="show" />
                <field name="quantity" sum="Total qty" optional="show" />
                <field name="collected_quantity" optional="hide" />
                <field name="price_unit" avg="Avg price" optional="show" />
                <field name="discount" string="Disc(%)" avg="Avg discount" optional="hide" />
                <field name="price_subtotal" sum="Subtotal" optional="show" />
                <field name="collected_price_subtotal" optional="hide" />
                <field name="price_total" sum="Total" optional="show" />
                <field name="collected_price_total" optional="show" />
                <field name="purchase_price" avg="Avg cost" optional="hide" />
                <field name="purchase_price_total" sum="Total purchase" optional="hide" />
                <field name="collected_purchase_price_total" optional="hide" />
                <field name="margin" sum="Total margin" optional="show" />
                <field name="collected_margin" optional="show" />
                <field name="margin_percent" avg="Avg margin" optional="show" />
                <field name="invoice_payment_term_id" optional="hide" />
                <field name="payment_state" widget="badge" optional="hide" />
                <field name="invoice_user_id" optional="hide" widget="many2one_avatar_user" />
                <field name="company_id" optional="hide" groups="base.group_multi_company" />
            </list>
        </field>
    </record>

    <record id="view_invoice_line_out_report_form" model="ir.ui.view">
        <field name="name">invoice.line.out.report.form</field>
        <field name="model">invoice.line.out.report</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- <field name="state" widget="statusbar" readonly="1"/> -->
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                    </div>
                    <group name="name">
                        <group>
                            <field name="move_id" />
                            <field name="journal_id" />
                            <field name="x_treatment" />
                            <field name="partner_id" />
                        </group>
                        <group>
                            <field name="company_id" />
                            <field name="invoice_payment_term_id" />
                        </group>
                    </group>
                    <notebook>
                        <page name="values" string="Values">
                            <group>
                                <group string="Invoice">
                                    <field name="invoice_date" />
                                    <field name="quantity" />
                                    <field name="price_unit" />
                                    <field name="price_subtotal" />
                                    <field name="price_total" />
                                    <field name="discount" />
                                    <field name="move_type" />
                                    <field name="payment_state" />
                                    <field name="purchase_price" />
                                    <field name="purchase_price_total" />
                                    <field name="margin" />
                                    <field name="margin_percent" />
                                </group>
                                <group string="Product">
                                    <field name="product_id" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_invoice_line_out_report" model="ir.actions.act_window">
        <field name="name">Invoices Analysis</field>
        <field name="res_model">invoice.line.out.report</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>

    <menuitem
        id="menu_invoice_line_out_report"
        name="Invoice Line Out Report"
        parent="sale.menu_sale_report"
        action="action_invoice_line_out_report"
        groups="sales_team.group_sale_manager" />
</odoo>