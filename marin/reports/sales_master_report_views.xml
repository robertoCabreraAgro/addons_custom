<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search View - CLEAN VERSION WITH EXISTING FIELDS ONLY -->
    <record id="view_sales_master_report_search" model="ir.ui.view">
        <field name="name">sales.master.report.search</field>
        <field name="model">sales.master.report</field>
        <field name="arch" type="xml">
            <search string="Sales Master Report">
                <field name="product_id" />
                <field name="partner_id" />
                <field name="team_id" />
                <field name="user_id" />
                <field name="move_id" />
                <field name="company_id" />
                <separator />
                <!-- Date Filter -->
                <filter name="filter_invoice_date" string="Invoice Date"
                    date="invoice_date" default_period="month"/>
                <!-- Channel Filters -->
                <filter name="invoices" string="Invoices"
                    domain="[('sale_channel', '=', 'invoice')]" />
                <filter name="pos" string="POS"
                    domain="[('sale_channel', '=', 'pos')]" />
                <separator />
                <!-- Treatment Filters -->
                <filter name="fiscal" string="Fiscal"
                    domain="[('x_treatment', '=', 'fiscal_real')]" />
                <filter name="non_fiscal" string="Non Fiscal"
                    domain="[('x_treatment', '=', 'not_fiscal_real')]" />
                <separator />
                <!-- Payment Status -->
                <filter name="paid" string="Paid"
                    domain="[('payment_state', '=', 'paid')]" />
                <filter name="not_paid" string="Not Paid"
                    domain="[('payment_state', '=', 'not_paid')]" />
                <filter name="partial" string="Partial"
                    domain="[('payment_state', '=', 'partial')]" />
                <group expand="0" string="Group by">
                    <filter string="Company" name="group_company"
                        context="{'group_by': 'company_id'}" />
                    <filter string="Product" name="group_product"
                        context="{'group_by': 'product_id'}" />
                    <filter string="Partner" name="group_partner"
                        context="{'group_by': 'partner_id'}" />
                    <filter string="Sales Team" name="group_team"
                        context="{'group_by': 'team_id'}" />
                    <filter string="Salesperson" name="group_user"
                        context="{'group_by': 'user_id'}" />
                    <filter string="Channel" name="group_channel"
                        context="{'group_by': 'sale_channel'}" />
                    <filter string="Payment Status" name="group_payment"
                        context="{'group_by': 'payment_state'}" />
                    <filter string="Treatment" name="group_treatment"
                        context="{'group_by': 'x_treatment'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- List View -->
    <record id="view_sales_master_report_list" model="ir.ui.view">
        <field name="name">sales.master.report.list</field>
        <field name="model">sales.master.report</field>
        <field name="arch" type="xml">
            <list string="Sales Master Report" create="false" edit="false" delete="false">
                <!-- 1-4: Business Context -->
                <field name="invoice_date" string="Invoice Date" optional="show" />
                <field name="sale_channel" string="Channel" optional="hide" />
                <field name="x_treatment" string="Treatment" optional="hide" />
                <field name="move_id" string="Entry" optional="show" />

                <!-- 5-7: Commercial Relationship -->
                <field name="partner_id" string="Partner" optional="show" />
                <field name="user_id" string="Salesperson" optional="show" />
                <field name="team_id" string="Sales Team" optional="show" />

                <!-- 8-9: Product Hierarchy -->
                <field name="manufacturer_id" string="Manufacturer"
                    optional="hide" />
                <field name="product_id" string="Product"
                    optional="show" />

                <!-- 10-14: Operational Numbers -->
                <field name="quantity" string="Quantity" sum="Total Quantity"
                    optional="show" />
                <field name="purchase_price" string="Purchase Price"
                    optional="show" />
                <field name="price_unit" string="Price Unit"
                    optional="show" />
                <field name="discount" string="Avg Discount"
                    optional="show" />

                <!-- 22-23: Financial Totals -->
                <field name="cost_purchase_total" string="Cost Purchase Total"
                    sum="Total Cost"
                    optional="show" />
                <field name="sale_price_total" string="Sale Price Total" sum="Total Sales"
                    optional="show" />
                <field name="invoice_amount_total" string="Invoice Total" sum="Total Invoiced"
                    optional="show" />

                <!-- 17-21: Payment Management -->
                <field name="amount_due" string="Amount Due" sum="Total Due"
                    optional="show" />
                <field name="amount_paid" string="Amount Paid" sum="Total Paid"
                    optional="show" />
                <field name="payment_state" string="Payment Status"
                    optional="show" />
                <field name="collection_percentage" string="Collection %" optional="show" />

                <!-- 15-16: Profitability -->
                <field name="margin" string="Total Margin" sum="Total Margin"
                    optional="show" />
                <field name="margin_percent" string="Margin %"
                    optional="show" />
                <field name="collected_margin" string="Margin Collected"
                    sum="Total Margin Collected"
                    optional="show" />

                <field name="company_id" string="Company" optional="show" />
            </list>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_sales_master_report_pivot" model="ir.ui.view">
        <field name="name">sales.master.report.pivot</field>
        <field name="model">sales.master.report</field>
        <field name="arch" type="xml">
            <pivot string="Sales Master Report">
                <field name="partner_id" type="row" />
                <field name="product_id" type="row" />
                <field name="invoice_date" type="col" interval="month" />
                <field name="sale_price_total" type="measure" />
                <field name="margin" type="measure" />
                <field name="quantity" type="measure" />
                <field name="invoice_amount_total" type="measure" />
                <field name="amount_paid" type="measure" />
                <field name="amount_due" type="measure" />
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_sales_master_report_graph" model="ir.ui.view">
        <field name="name">sales.master.report.graph</field>
        <field name="model">sales.master.report</field>
        <field name="arch" type="xml">
            <graph string="Sales Master Report" type="bar">
                <field name="product_id" type="row" />
                <field name="sale_price_total" type="measure" />
                <field name="margin" type="measure" />
                <field name="invoice_amount_total" type="measure" />
                <field name="amount_paid" type="measure" />
                <field name="collection_percentage" type="measure" />
            </graph>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_sales_master_report_form" model="ir.ui.view">
        <field name="name">sales.master.report.form</field>
        <field name="model">sales.master.report</field>
        <field name="arch" type="xml">
            <form string="Sales Master Report" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group string="Business Context">
                            <field name="invoice_date" />
                            <field name="move_id" />
                            <field name="company_id" />
                            <field name="sale_channel" />
                            <field name="x_treatment" />
                        </group>
                        <group string="Commercial Relationship">
                            <field name="partner_id" />
                            <field name="team_id" />
                            <field name="user_id" />
                        </group>
                        <group string="Product Information">
                            <field name="manufacturer_id" />
                            <field name="product_id" />
                            <field name="quantity" />
                        </group>
                        <group string="Pricing and Costs">
                            <field name="purchase_price" />
                            <field name="price_unit" />
                            <field name="cost_purchase_total" />
                            <field name="discount" />
                        </group>
                        <group string="Profitability">
                            <field name="margin_percent" />
                            <field name="margin" />
                            <field name="sale_price_total" />
                        </group>
                        <group string="Collection Management">
                            <field name="payment_state" />
                            <field name="invoice_amount_total" />
                            <field name="amount_paid" />
                            <field name="amount_due" />
                            <field name="collection_percentage" />
                            <field name="collected_margin" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sales_master_report" model="ir.actions.act_window">
        <field name="name">Sales Analysis Report</field>
        <field name="res_model">sales.master.report</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="context">{'search_default_year_2025': 1}</field>
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Sales Analysis Report
            </p>
            <p>
                Analyze your sales performance with year-over-year comparisons,
                team analysis, and detailed margin calculations.
            </p>
        </field>
    </record>

</odoo>