<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ir_cron_partner_age_range" model="ir.cron">
        <field name="name">Contact: Update Age Range</field>
        <field name="model_id" ref="model_res_partner" />
        <field name="state">code</field>
        <field name="code">model._cron_update_age_range_id()</field>
        <field name="user_id" ref="base.user_root" />
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
    </record>

    <record id="ir_cron_update_invoice_line_in_report" model="ir.cron">
        <field name="name">Invoice Line In Report: Update view</field>
        <field name="model_id" ref="model_invoice_line_in_report" />
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="user_id" ref="base.user_root" />
        <field name="state">code</field>
        <field name="code">model.refresh_concurrently()</field>
    </record>

    <record id="ir_cron_initialize_invoice_line_in_report" model="ir.cron">
        <field name="name">Invoice Line In Report: Initialize view</field>
        <field name="model_id" ref="model_invoice_line_in_report" />
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="user_id" ref="base.user_root" />
        <field name="state">code</field>
        <field name="active" eval="False" />
        <field name="code">model.init()</field>
    </record>

    <record id="ir_cron_update_invoice_line_out_report" model="ir.cron">
        <field name="name">Invoice Line Out Report: Update views</field>
        <field name="model_id" ref="model_invoice_line_out_report" />
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="user_id" ref="base.user_root" />
        <field name="state">code</field>
        <field name="code">model.refresh_concurrently()
env["invoice.line.out.team.report"].refresh_concurrently()
env["invoice.line.out.team.yearly.report"].refresh_concurrently()
env["invoice.line.out.pos.report"].refresh_concurrently()</field>
    </record>

    <record id="ir_cron_initialize_invoice_line_out_report" model="ir.cron">
        <field name="name">Invoice Line Out Report: Initialize views</field>
        <field name="model_id" ref="model_invoice_line_out_report" />
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="user_id" ref="base.user_root" />
        <field name="state">code</field>
        <field name="active" eval="False" />
        <field name="code">model.init()
env["invoice.line.out.team.report"].init()
env["invoice.line.out.team.yearly.report"].init()
env["invoice.line.out.pos.report"].init()</field>
    </record>

    <record id="ir_cron_update_pos_line_report" model="ir.cron">
        <field name="name">PoS Line Report: Update views</field>
        <field name="model_id" ref="model_pos_line_report" />
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="user_id" ref="base.user_root" />
        <field name="state">code</field>
        <field name="code">model.refresh_concurrently()
env["pos.line.report"].refresh_concurrently()
env["pos.line.product.report"].refresh_concurrently()</field>
    </record>

    <record id="ir_cron_initialize_pos_line_report" model="ir.cron">
        <field name="name">PoS Line Report: Initialize views</field>
        <field name="model_id" ref="model_pos_line_report" />
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="user_id" ref="base.user_root" />
        <field name="state">code</field>
        <field name="active" eval="False" />
        <field name="code">model.init()
env["pos.line.report"].init()
env["pos.line.product.report"].init()</field>
    </record>

    <record id="ir_cron_update_stock_need_report" model="ir.cron">
        <field name="name">Stock Need Report: Update view</field>
        <field name="model_id" ref="model_stock_need_report" />
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="user_id" ref="base.user_root" />
        <field name="state">code</field>
        <field name="code">model.refresh_concurrently()</field>
    </record>

    <record id="ir_cron_initialize_stock_need_report" model="ir.cron">
        <field name="name">Stock Need Report: Initialize view</field>
        <field name="model_id" ref="model_stock_need_report" />
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="user_id" ref="base.user_root" />
        <field name="state">code</field>
        <field name="active" eval="False" />
        <field name="code">model.init()</field>
    </record>
</odoo>
