        <field name="categ_id" ref="marin.product_category_fuel" />
        <field name="type">service</field>
	    <field name="vehicle_service" eval="True" />
    </record>

    <record id="product_product_fuel_credit" model="product.product">
        <field name="uom_id" ref="uom.product_uom_unit"/>
