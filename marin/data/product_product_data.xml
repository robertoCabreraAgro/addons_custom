        <field name="categ_id" ref="marin.product_category_highway_toll" />
        <field name="type">service</field>
	    <field name="vehicle_service" eval="True" />
    </record>

    <record id="product_product_highway_credit" model="product.product">
        <field name="uom_id" ref="uom.product_uom_unit"/>
        <field name="name">Highway credit</field>
        <field name="categ_id" ref="marin.product_category_highway_toll" />
        <field name="type">service</field>
	    <field name="vehicle_service" eval="True" />
    </record>

</odoo>
