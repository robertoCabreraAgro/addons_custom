<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="wizard_pos_cash_transfer_form_view" model="ir.ui.view">
        <field name="name">wizard.pos.cash.transfer.form.view</field>
        <field name="model">pos.cash.transfer.wizard</field>
        <field name="arch" type="xml">
            <form>
                <field name="session_id" />
                <field name="currency_id" />
                <group>
                    <group name="group_origin" string="Origin">
                        <field name="journal_id" force_save="1" nolabel="1"/>
                    </group>
                    <group name="group_destination" string="Destination">
                        <field name="destination_journal_id" nolabel="1" />
                    </group>
                </group>
                <field name="amount" />
                <footer>
                    <button name="action_create_cash_transfer" string="Generate Cash Transfer"
                        type="object" class="oe_highlight"
                        data-hotkey="q" />
                    <button special="cancel" string="Cancel" class="btn btn-secondary" data-hotkey="z" />
                </footer>
            </form>
        </field>
    </record>

    <record id="pos_cash_transfer_wizard" model="ir.actions.act_window">
        <field name="name">PoS Cash Transfer</field>
        <field name="res_model">pos.cash.transfer.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
