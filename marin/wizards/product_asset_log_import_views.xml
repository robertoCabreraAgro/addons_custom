<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Form View for the Import Wizard -->
    <record id="view_product_asset_log_import_form" model="ir.ui.view">
        <field name="name">product.asset.log.import.form</field>
        <field name="model">product.asset.log.import</field>
        <field name="arch" type="xml">
            <form string="Import Asset Logs">
                <sheet>
                    <group>
                        <field
                            name="vehicle_ids"
                            widget="many2many_tags"
                            options="{'no_create_edit': True, 'no_quick_create': True}"
                            placeholder="Import logs for all vehicles"
                        />
                    </group>
                    <group>
                        <group>
                            <field name="parser" widget="radio" />
                        </group>
                        <group>
                            <field name="file" filename="filename" />
                            <field name="filename" invisible="1" />
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert" invisible="parser != 'effectivale'">
                        <p><strong>Note:</strong> Only XLS files are accepted.</p>
                        <p>For <strong
                            >Effectivale</strong> imports, please ensure your file contains the following columns:</p>
                        <ul>
                            <li>Cuenta</li>
                            <li>Fecha</li>
                            <li>Cargo</li>
                            <li>Abono</li>
                            <li>Km FIN</li>
                            <li>Concepto</li>
                            <li>Litros</li>
                            <li>Rendimiento</li>
                        </ul>
                    </div>
                    <div class="alert alert-info" role="alert" invisible="parser != 'i_d_cross'">
                        <p><strong>Note:</strong> Only CSV files are accepted.</p>
                        <p>For <strong>I+D Mexico Crossings</strong> imports, please ensure your file contains the following columns:</p>
                        <ul>
                            <li>Tag</li>
                            <li>No.Economico</li>
                            <li>Fecha</li>
                            <li>Hora</li>
                            <li>Caseta</li>
                            <li>Carril</li>
                            <li>Clase</li>
                            <li>Importe</li>
                            <li>Saldo</li>
                            <li>Fecha Aplicacion</li>
                            <li>Hora Aplicacion</li>
                            <li>Consecar</li>
                        </ul>
                    </div>
                    <div class="alert alert-info" role="alert" invisible="parser != 'i_d_recharges'">
                        <p><strong>Note:</strong> Only CSV files are accepted.</p>
                        <p>For <strong>I+D Mexico Recharges</strong> imports, please ensure your file contains the following columns:</p>
                        <ul>
                            <li>Fecha</li>
                            <li>Hora</li>
                            <li>Folio</li>
                            <li>Referencia</li>
                            <li>Importe</li>
                            <li>Movimiento</li>
                        </ul>
                    </div>
                    <group>
                        <field name="test_mode" widget="boolean_toggle" />
                    </group>
                    <group>
                        <group>
                            <field name="test_display" widget="radio" invisible="not test_mode" />
                        </group>
                        <group>
                            <field name="test_limit" invisible="not test_mode or test_display != 'limit'" />
                        </group>
                    </group>
               </sheet>
                <footer>
                    <button
                        string="Test"
                        name="action_import"
                        type="object"
                        class="btn-primary"
                        invisible="not test_mode"
                    />
                    <button
                        string="Import"
                        name="action_import"
                        type="object"
                        class="btn-primary"
                        invisible="test_mode"
                    />
                    <button string="Cancel" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the Import Wizard -->
    <record id="action_product_asset_log_import" model="ir.actions.act_window">
        <field name="name">Import Asset Logs</field>
        <field name="res_model">product.asset.log.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="stock.model_stock_lot" />
    </record>
</odoo>
