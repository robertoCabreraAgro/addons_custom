<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_res_config_settings_inherit_marin" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.marin</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='orderlines_seq_cart']" position="after">
                <setting id="load_all_partners_by_company"
                    string="Load All Partners by Company"
                    help="If enabled, all customers filtered by company will be loaded instead of using limited scroll-based loading.">
                    <field name="pos_load_all_partners_by_company" />
                </setting>
            </xpath>
        </field>
    </record>

    <record id="view_res_config_settings_inherit_accounting" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.accounting.marin</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">

            <xpath expr="//form" position="inside">
                <!-- SAT CFDI Validation Settings -->
                <app name="sat_validation" string="SAT CFDI">
                    <block name="sat_settings" title="SAT Validation Configuration">
                        <setting name="sat_batch_size"
                            help="Maximum number of invoices processed per execution">
                            <field name="sat_batch_size" />
                        </setting>
                        <setting name="sat_status_max_days"
                            help="Maximum business days backwards for SAT review">
                            <field name="sat_status_max_days" />
                        </setting>
                    </block>
                </app>
            </xpath>

            <xpath expr="//block[@name='contacts_setting_container']" position="after">
                <!-- Contact Management -->
                <block name="contact_restrictions" title="Contact Management">
                    <setting name="restricted_contact_creation"
                        string="Restricted Contact Creation"
                        help="Restrict users in the 'Restricted Contact Creation' group from creating or editing contacts unless all mandatory fields are completed">
                        <field name="restricted_contact_creation" />
                    </setting>

                    <setting name="restricted_contact_required_fields"
                        help="Select the fields that must be completed when users in the 'Restricted Contact Creation' group create or edit contacts. Common fields include: Tax ID (vat), Fiscal Regime, Tags, Phone, Email, Address fields"
                        invisible="not restricted_contact_creation">
                        <field name="restricted_contact_required_fields"
                            widget="many2many_tags"
                            options="{'no_create': True}"
                            domain="[('model', '=', 'res.partner'), ('store', '=', True), ('ttype', 'not in', ['binary', 'reference', 'many2many_reference'])]"
                            placeholder="Select mandatory fields..." />
                    </setting>
                </block>

                <!-- Customer Merge Policies -->
                <block name="merge_policies" title="Customer Merge Policies">
                    <setting name="customer_merge_active"
                        string="Enable Customer Merge"
                        help="Automatically merge inactive customers with the general public partner based on configured policies">
                        <field name="customer_merge_active" />
                    </setting>

                    <setting name="customer_merge_general_partner"
                        help="Partner to merge inactive customers with"
                        invisible="not customer_merge_active">
                        <div class="row">
                            <div class="col-12">
                                <label for="customer_merge_general_partner_id"
                                    string="General Public Partner" />
                                <field name="customer_merge_general_partner_id"
                                    placeholder="Select general public partner..." />
                            </div>
                        </div>
                    </setting>

                    <setting name="customer_merge_evaluation_period"
                        help="Time period to evaluate customer activity"
                        invisible="not customer_merge_active">
                        <div class="row">
                            <div class="col-6">
                                <label for="customer_merge_interval_number"
                                    string="Evaluation Period" />
                                <field name="customer_merge_interval_number" />
                            </div>
                            <div class="col-6">
                                <label for="customer_merge_interval_type" string="Period Type" />
                                <field name="customer_merge_interval_type" />
                            </div>
                        </div>
                    </setting>

                    <setting name="customer_merge_min_orders"
                        help="Minimum number of orders required to keep a customer active"
                        invisible="not customer_merge_active">
                        <field name="customer_merge_min_orders" />
                    </setting>

                    <setting name="customer_merge_required_fields"
                        help="Fields that must be completed for a customer to remain active (e.g., phone, email, tags)"
                        invisible="not customer_merge_active">
                        <field name="customer_merge_required_fields"
                            widget="many2many_tags"
                            placeholder="Select required fields..." />
                    </setting>
                </block>

            </xpath>
        </field>
    </record>

    <record id="view_res_config_settings_inherit_planning_mrp" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.planning.mrp.marin</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="mrp.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='security_lead_time']" position="after">
                <setting id="module_planning_mrp"
                    title="Enable the integration of Planning and Manufacturing modules."
                    help="Enable the integration of Planning and Manufacturing modules">
                    <field name="module_planning_mrp" widget="upgrade_boolean" />
                </setting>
            </xpath>
        </field>
    </record>

</odoo>