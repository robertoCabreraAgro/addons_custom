<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="1">

    <record id="sale_order_salesteam_rule" model="ir.rule">
        <field name="name">Salesteam Orders</field>
        <field name="model_id" ref="sale.model_sale_order" />
        <field name="domain_force"
        >['|', ('user_id', 'in', (False, user.id)), ('team_id', 'in', user.crm_team_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('marin.group_sale_salesman_team'))]" />
    </record>

    <record id="sale_order_line_salesteam_rule" model="ir.rule">
        <field name="name">Salesteam Order Lines</field>
        <field name="model_id" ref="sale.model_sale_order_line" />
        <field name="domain_force"
        >['|', ('user_id', 'in', (False, user.id)), ('order_id.team_id', 'in', user.crm_team_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('marin.group_sale_salesman_team'))]" />
    </record>

    <record id="sale_order_report_salesteam_rule" model="ir.rule">
        <field name="name">Salesteam Orders Analysis</field>
        <field name="model_id" ref="sale.model_sale_report" />
        <field name="domain_force"
        >['|', ('user_id', 'in', (False, user.id)), ('team_id', 'in', user.crm_team_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('marin.group_sale_salesman_team'))]" />
    </record>

    <record id="account_invoice_report_rule_see_salesteam" model="ir.rule">
        <field name="name">Salesteam Invoices Analysis</field>
        <field name="model_id" ref="account.model_account_invoice_report" />
        <field name="domain_force"
        >['|', ('invoice_user_id', 'in', (False, user.id)), ('team_id', 'in', user.crm_team_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('marin.group_sale_salesman_team'))]" />
    </record>


    <record id="account_invoice_rule_see_salesteam" model="ir.rule">
        <field name="name">Salesteam Invoices</field>
        <field name="model_id" ref="account.model_account_move" />
        <field name="domain_force"
        >[('move_type', 'in', ('out_invoice', 'out_refund')), '|', ('invoice_user_id', 'in', (False, user.id)), ('team_id', 'in', user.crm_team_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('marin.group_sale_salesman_team'))]" />
    </record>

    <record id="account_invoice_line_rule_see_salesteam" model="ir.rule">
        <field name="name">Salesteam Invoice Lines</field>
        <field name="model_id" ref="account.model_account_move_line" />
        <field name="domain_force"
        >[('move_id.move_type', 'in', ('out_invoice', 'out_refund')), '|', ('move_id.invoice_user_id', 'in', (False, user.id)), ('move_id.team_id', 'in', user.crm_team_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('marin.group_sale_salesman_team'))]" />
    </record>

    <!-- Sales Master Report Rules -->
    <record id="sales_master_report_rule_manager" model="ir.rule">
        <field name="name">Sales Master Report: Manager</field>
        <field name="model_id" ref="model_sales_master_report"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman_all_leads'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="sales_master_report_rule_team_leader" model="ir.rule">
        <field name="name">Sales Master Report: Team Leader</field>
        <field name="model_id" ref="model_sales_master_report"/>
        <field name="domain_force">[('team_id.user_id', 'in', (False, user.id))]</field>
        <field name="groups" eval="[(4, ref('marin.group_sale_salesman_team'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="sales_master_report_rule_salesperson" model="ir.rule">
        <field name="name">Sales Master Report: Salesperson</field>
        <field name="model_id" ref="model_sales_master_report"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <!-- Fleet Manager Rule for Account Moves with Vehicle Lines -->
    <record id="account_move_fleet_manager_rule" model="ir.rule">
        <field name="name">Fleet Manager: Account Moves with Vehicle Lines</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="domain_force">[('line_ids.vehicle_id', '!=', False)]</field>
        <field name="groups" eval="[(4, ref('fleet.fleet_group_manager'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

</odoo>
