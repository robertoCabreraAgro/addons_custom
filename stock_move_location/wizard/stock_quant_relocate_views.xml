<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock_quant_relocate_form" model="ir.ui.view">
        <field name="name">stock.quant.relocate.form</field>
        <field name="model">stock.quant.relocate</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box" />
                    <div class="row">
                        <!-- Columna Izquierda -->
                        <div class="col-md-6">
                            <div>
                                <label for="exclude_reserved_qty">
                                    Exclude Reserved Quantities
                                </label>
                                <field name="exclude_reserved_qty" widget="boolean_toggle" style="margin-left: 10px;" />
                            </div>
                    
                            <div>
                                <label for="skip_picking">
                                    Skip Picking
                                </label>
                                <field name="skip_picking" widget="boolean_toggle" style="margin-left: 10px;" />
                            </div>
                            
                            <!-- Campo condicional que depende de 'skip_picking' -->
                            <group name="picking_type" invisible="skip_picking">
                                <field name="picking_type_id" />
                            </group>
                        </div>
                    
                        <!-- Columna Derecha -->
                        <div class="col-md-6">
                            <div>
                                <label for="edit_locations">
                                    Edit Origin Location
                                </label>
                                <field name="edit_locations" widget="boolean_toggle" style="margin-left: 10px;" />
                            </div>
                    
                            <group name="main">
                                <div>
                                    <label for="location_origin_id">
                                        Origin Location
                                    </label>
                                    <field name="location_origin_id" readonly="location_origin_readonly" />
                                
                                    <label for="location_destination_id">
                                        Destination Location
                                    </label>
                                    <field name="location_destination_id" readonly="location_destination_readonly" />
                                </div>
                            </group>
                        </div>
                    </div>
                    
                    <group name="lines">
                        <field name="line_ids"
                            nolabel="1"
                            mode="tree,kanban"
                            colspan="2">
                            <list
                                editable="bottom"
                                decoration-info="move_quantity != max_quantity"
                                decoration-danger="(move_quantity &lt; 0) or (move_quantity > max_quantity)"
                                create="0">
                                <field name="product_id"
                                    domain="[('type','=','product')]" />
                                <field name="product_uom_id"
                                    string="UoM"
                                    groups="uom.group_uom" />
                                <field name="location_origin_id"
                                    readonly="1"
                                />
                                <field name="location_destination_id"
                                    readonly="1"
                                    force_save="1" />
                                <field name="lot_id"
                                    domain="[('product_id', '=', product_id)]"
                                    context="{'default_product_id': product_id}"
                                    options="{'no_create': True}"
                                    groups="stock.group_production_lot" />
                                <field name="package_id"
                                    domain="[('location_id', '=', location_origin_id)]"
                                    options="{'no_create': True}" />
                                <field name="owner_id"
                                    options="{'no_create': True}" />
                                <field name="move_quantity" />
                                <field name="custom" invisible="1" />
                                <field name="max_quantity"
                                    readonly="not custom"
                                    force_save="1" />
                                <field name="reserved_quantity"
                                    readonly="1"
                                    force_save="1" />
                                <field name="total_quantity"
                                    readonly="1"
                                    force_save="1" />
                            </list>
                            <kanban class="o_kanban_mobile">
                                <templates>
                                    <t t-name="kanban-box">
                                        <div t-attf-class="oe_kanban_global_click">
                                            <div class="o_kanban_record_body">
                                                <field name="product_id" />
                                                <field name="product_uom_id" />
                                                <field name="lot_id"
                                                    groups="stock.group_production_lot" />
                                                <field name="location_origin_id" />
                                                <field name="location_destination_id" />
                                            </div>
                                            <div class="o_kanban_record_bottom">
                                                <div class="oe_kanban_bottom_right">
                                                    <span>
                                                        <field name="move_quantity" />
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </templates>
                            </kanban>
                        </field>
                    </group>
                    <footer>
                        <button
                            name="action_move_location"
                            string="Transfer"
                            type="object"
                            class="btn-primary" />
                        <!-- <button
                            name="action_move_location"
                            string="Planned Transfer"
                            type="object"
                            class="btn-primary"
                            context="{'planned': True}" /> -->
                        <button special="cancel" string="Cancel" class="btn-default" />
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="stock_quant_relocate_action" model="ir.actions.act_window">
        <field name="name">Quant relocate</field>
        <field name="res_model">stock.quant.relocate</field>
        <field name="view_id" ref="stock_quant_relocate_form" />
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{}</field>
    </record>

    <menuitem
        id="menuitem_move_location"
        name="Move from location..."
        parent="stock.menu_stock_warehouse_mgmt"
        action="stock_quant_relocate_action"
        sequence="99" />
</odoo>