<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_move_form" model="ir.ui.view">
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_title')]//div[1]"
                position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]//field[@name='name']"
                position="attributes">
                <attribute name="invisible">name == '/'</attribute>
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]//h1//span"
                position="attributes">
                <attribute name="invisible">state != 'draft'</attribute>
            </xpath>
        </field>
    </record>
</odoo>
