<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form" model="ir.ui.view">
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_title')]"
                position="replace">
                <div class="oe_title">
                    <span class="o_form_label">
                        <field name="move_type"
                            nolabel="1"
                            readonly="1"
                            invisible="move_type == 'entry'" />
                    </span>
                    <div class="text-warning" invisible="1">
                        The current highest number is <field name="highest_name" class="oe_inline" />. 
                        You might want to put a higher number here.
                    </div>
                    <h1>
                        <field name="name"
                            readonly="True"
                            options="{'placeholder_field': 'name_placeholder'}"
                            invisible="name == '/'" />
                        <span invisible="state != 'draft'">Draft</span>
                    </h1>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
