<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form" model="ir.ui.view">
        <field name="name">account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_open_business_doc']" position="before">
                <button name="action_view_approval"
                    type="object" class="oe_stat_button"
                    icon="fa-credit-card"
                    invisible="count_approval == 0"
                    groups="approvals.group_approval_user">
                    <field name="count_approval" string="Approval" widget="statinfo"
                        groups="approvals.group_approval_user" />
                </button>
            </xpath>
        </field>
    </record>

</odoo>
