<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="hr_attendance_view_form_inherit" model="ir.ui.view">
        <field name="name">hr.attendance.form.inherit</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='check_in']" position="after">
                <field name="lunch_out" />
                <field name="lunch_in" />
            </xpath>
            <xpath expr="//field[@name='worked_hours']" position="before">
                <field name="lunch_hours" widget="float_time" />
            </xpath>
        </field>
    </record>
    <record id="hr_attendance_view_list_inherit" model="ir.ui.view">
        <field name="name">hr.attendance.list.inherit</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.view_attendance_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='check_in']" position="after">
                <field name="lunch_out" optional="show" />
                <field name="lunch_in" optional="show" />
            </xpath>
            <xpath expr="//field[@name='worked_hours']" position="before">
                <field name="lunch_hours" widget="float_time" />
            </xpath>
        </field>
    </record>
</odoo>
