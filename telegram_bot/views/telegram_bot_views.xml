<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_telegram_bot_form" model="ir.ui.view">
        <field name="name">telegram.bot.form</field>
        <field name="model">telegram.bot</field>
        <field name="arch" type="xml">
            <form string="Telegram Bot">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="token" password="True" />
                        <field name="payment_approval_category_id" />
                    </group>
                    <notebook>
                        <page string="Chats Vinculados">
                            <field name="chat_ids">
                                <list editable="top" create="False">
                                    <field name="chat_id" />
                                    <field name="telegram_username" />
                                    <field name="partner_id" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_telegram_bot_list" model="ir.ui.view">
        <field name="name">telegram.bot.list</field>
        <field name="model">telegram.bot</field>
        <field name="arch" type="xml">
            <list string="Telegram Bots">
                <field name="name" />
            </list>
        </field>
    </record>

    <record id="action_telegram_bot" model="ir.actions.act_window">
        <field name="name">Telegram Bots</field>
        <field name="res_model">telegram.bot</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_telegram_root"
        name="Telegram"
        sequence="10"
        web_icon="telegram_bot,static/description/icon.png"
    />

    <menuitem
        id="menu_telegram_bots"
        name="Bots"
        parent="menu_telegram_root"
        action="action_telegram_bot"
        sequence="10"
    />
</odoo>
