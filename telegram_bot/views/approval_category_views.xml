<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="approval_category_view_form_inherit_accounting_link" model="ir.ui.view">
        <field name="name">approval.category.form.inherit.accounting</field>
        <field name="model">approval.category</field>
        <field name="inherit_id" ref="base_approval.approval_category_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//group[@name='option_settings']" position="inside">
                <field name="has_bsl" widget="radio" options="{'horizontal': true}" />
                <field name="has_operation_type" widget="radio" options="{'horizontal': true}" />
            </xpath>
        </field>
    </record>

</odoo>
