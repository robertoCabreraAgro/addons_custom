<odoo>
    <record id="view_account_move_line_filter_operation" model="ir.ui.view">
        <field name="name">account.move.line.search.operation</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_account_move_line_filter" />
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="operation_id" />
            </field>
            <group position="inside">
                <filter name="operation_groupby" string="Move Operation"
                    context="{'group_by': 'operation_id'}" />
            </group>
        </field>
    </record>
</odoo>