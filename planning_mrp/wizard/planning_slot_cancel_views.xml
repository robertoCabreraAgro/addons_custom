<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View planning.slot.cancel View List -->
    <record id="view_planning_slot_cancel_list" model="ir.ui.view">
        <field name="name">view.planning.slot.cancel.list</field>
        <field name="model">planning.slot.cancel</field>
        <field name="arch" type="xml">
            <list>
                <field name="cancel_reason_id"/>
            </list>
        </field>
    </record>

    <!-- View planning.slot.cancel form -->
    <record id="view_planning_slot_cancel_form" model="ir.ui.view">
        <field name="name">view.planning.slot.cancel.form</field>
        <field name="model">planning.slot.cancel</field>
        <field name="arch" type="xml">
            <form string="Planning Slot Cancel">
                <sheet>
                    <group>
                        <field name="slot_ids" invisible="1"/>
                        <field name="cancel_reason_id" placeholder="Cancel reason"/>
                        <field name="cancel_details"/>
                        <field name="notify_employee"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_cancel"
                        string="Confirm"
                        type="object"
                        class="btn-primary" />
                    <button special="cancel"
                        string="Cancel"
                        class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <!-- View planning.slot.cancel search -->
    <record id="view_planning_slot_cancel_search" model="ir.ui.view">
        <field name="name">view.planning.slot.cancel.search</field>
        <field name="model">planning.slot.cancel</field>
        <field name="arch" type="xml">
            <search>
                <group expand="1" string="Group By">
                    <filter string="cancel_reason_id" name="name" domain="[]" context="{'group_by':'cancel_reason_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action planning.slot.cancel -->
    <record id="action_planning_slot_cancel" model="ir.actions.act_window">
        <field name="name">Planning Slot Cancel</field>
        <field name="res_model">planning.slot.cancel</field>
        <field name="view_mode">form</field>
        <field name="binding_model_id" ref="planning.model_planning_slot" />
        <field name="target">new</field>
        <field name="binding_view_types">list</field>
    </record>

</odoo>
