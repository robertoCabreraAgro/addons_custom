<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form view for planning.slot with the new fields -->
    <record id="planning_slot_view_form_inherit" model="ir.ui.view">
        <field name="name">planning.slot.view.form.inherit</field>
        <field name="model">planning.slot</field>
        <field name="inherit_id" ref="planning.planning_view_form"/>
        <field name="arch" type="xml">
            <field name="role_id" position="after">
                <field name="workcenter_id"/>
                <field name="product_id"/>
            </field>
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="statusbar_visible">draft,published,cancelled</attribute>
            </xpath>
            <xpath expr="//sheet" position="after">
                <chatter/>
            </xpath>
            <xpath expr="//button[@name='action_send'][1]" position="attributes">
                <attribute name="invisible">context.get('my_planning_action') or (state in ['published','cancelled'] or resource_type == 'material')</attribute>
            </xpath>
            <xpath expr="//button[@name='action_send'][2]" position="attributes">
                <attribute name="invisible">context.get('my_planning_action') or (state in ['published','cancelled'] or resource_type == 'material')</attribute>
            </xpath>
            <xpath expr="//button[@name='action_unpublish']" position="attributes">
                <attribute name="invisible">context.get('my_planning_action') or (state in ['published','cancelled'] or resource_type == 'material')</attribute>
            </xpath>
            <xpath expr="//button[@name='auto_plan_id']" position="attributes">
                <attribute name="invisible">context.get('my_planning_action') or resource_id or (state == 'cancelled')</attribute>
            </xpath>
            <xpath expr="//header" position="inside">
                <button
                    name="%(planning_mrp.action_planning_slot_cancel)d"
                    string="Cancel Shift"
                    type="action"
                    class="oe_stat_button"
                    invisible="state in ['published','cancelled']"
                />
            </xpath>
            <xpath expr="//group[@name='slot_info_right']" position="after">
                <group string="Cancellation information" invisible="state != 'cancelled'">
                    <field name="cancel_reason_id" readonly="1"/>
                    <field name="cancel_details" readonly="1"/>
                    <field name="cancel_date" readonly="1"/>
                    <field name="cancelled_by" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- List view for planning.slot with the new fields -->
    <record id="planning_slot_view_list_inherit" model="ir.ui.view">
        <field name="name">planning.slot.view.list.inherit</field>
        <field name="model">planning.slot</field>
        <field name="inherit_id" ref="planning.planning_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="cancel_details" optional="hide"/>
                <field name="cancel_date" optional="hide"/>
                <field name="cancelled_by" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Search view for planning.slot with the new fields -->
    <record id="planning_slot_view_search_inherit" model="ir.ui.view">
        <field name="name">planning.slot.view.search.inherit</field>
        <field name="model">planning.slot</field>
        <field name="inherit_id" ref="planning.planning_view_search_base"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='published_shifts']" position="after">
                <filter name="cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
            </xpath>
            <xpath expr="//filter[@name='group_by_end_datetime']" position="after">
                <filter name="group_cancel_reason" string="Cancel Reason" context="{'group_by': 'cancel_reason_id'}"/>
            </xpath>
        </field>
    </record>

    <!-- Gantt view grouped by workcenter -->
    <record id="planning_slot_view_gantt_workcenter" model="ir.ui.view">
        <field name="name">planning.slot.gantt.workcenter</field>
        <field name="model">planning.slot</field>
        <field name="arch" type="xml">
            <gantt
                js_class="planning_gantt"
                form_view_id="%(planning.planning_view_form_in_gantt)d"
                date_start="start_datetime"
                date_stop="end_datetime"
                default_group_by="workcenter_id"
                string="Planning by Workcenter"
                default_range="week"
                default_scale="week"
                color="color"
                plan="false"
                total_row="True"
                scales="day,week,month,year"
                precision="{'day': 'hour:full', 'week': 'day:full', 'month': 'day:full', 'year': 'day:full'}"
                decoration-info="state == 'draft'"
                decoration-warning="publication_warning or (request_to_switch and not is_past and not allow_self_unassign)"
                decoration-danger="overlap_slot_count > 0"
                display_unavailability="1"
                sample="1"
                progress_bar="resource_id"
                pill_label="True">

                <field name="workcenter_id"/>
                <field name="product_id"/>
                <field name="resource_id"/>
                <field name="allocated_hours"/>
                <field name="recurrency_id" />
                <field name="repeat" invisible="1"/>
                <field name="state"/>
                <field name="publication_warning"/>
                <field name="request_to_switch"/>
                <field name="allow_self_unassign"/>
                <field name="is_past"/>
                <field name="resource_type"/>
                <field name="overlap_slot_count"/>
                <field name="allocated_percentage"/>
                <field name="name"/>
                <templates>
                    <div t-name="gantt-popover">
                        <div id="allocated_hours"><strong>Allocated Time — </strong> <t t-esc="allocatedHoursFormatted"/> <t t-if="resource_type == 'user'"> (<t t-esc="allocatedPercentageFormatted"/>%)</t></div>
                        <div>
                            <t t-esc="start_datetime.toFormat('f ')"/>
                            <i class="fa fa-long-arrow-right" title="Arrow"/>
                            <t t-esc="end_datetime.toFormat(' f')"/>
                        </div>
                        <p class="mt-2 mb-0" t-if="name"><t t-esc="name.slice(0, 200) + (name.length > 200?'…':'')" /></p>
                        <p t-if="publication_warning and !overlap_slot_count" class="text-warning mt-2 mb-0">
                            Some changes were made since this shift was published.
                        </p>
                        <p t-if="request_to_switch and !is_past and !allow_self_unassign" class="text-warning mt-2 mb-0">
                            <span>The employee assigned would like to switch shifts with someone else.</span>
                        </p>
                        <p t-if="overlap_slot_count" class="text-danger mt-2 mb-0">
                            <t t-esc="overlap_slot_count"/> other shift(s) in conflict.
                        </p>
                    </div>
                </templates>
            </gantt>
        </field>
    </record>

