    </record>

    <!-- Actions by Workcenter -->
    <record id="action_planning_slot_by_workcenter" model="ir.actions.act_window">
        <field name="name">Planning by Workcenter</field>
        <field name="res_model">planning.slot</field>
        <field name="view_mode">gantt,calendar,list,form,kanban,pivot,graph</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'gantt', 'view_id': ref('planning_slot_view_gantt_workcenter')}),
            (0, 0, {'view_mode': 'calendar'}),
            (0, 0, {'view_mode': 'list'}),
            (0, 0, {'view_mode': 'form'}),
            (0, 0, {'view_mode': 'kanban'}),
            (0, 0, {'view_mode': 'pivot'}),
            (0, 0, {'view_mode': 'graph'})]"/>
        <!-- <field name="context">{'search_default_workcenter_id': active_id}</field> -->
        <field name="domain">[('workcenter_id', '!=', False)]</field>
    </record>

    <record id="action_server_planning_slot_by_workcenter" model="ir.actions.server">
        <field name="name">Planning by Workcenter</field>
        <field name="model_id" ref="planning.model_planning_slot"/>
        <field name="state">code</field>
        <field name="code">
            action = model.get_action_planning_slot_by_workcenter()
        </field>
    </record>

