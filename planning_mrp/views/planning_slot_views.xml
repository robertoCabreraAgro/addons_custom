            (0, 0, {'view_mode': 'calendar'}),
            (0, 0, {'view_mode': 'list'}),
            (0, 0, {'view_mode': 'form'}),
            (0, 0, {'view_mode': 'kanban'}),
            (0, 0, {'view_mode': 'pivot'}),
            (0, 0, {'view_mode': 'graph'})]"/>
        <field name="domain">[('product_id', '!=', False)]</field>
    </record>

    <record id="action_server_planning_slot_by_product" model="ir.actions.server">
        <field name="name">Planning by Product</field>
