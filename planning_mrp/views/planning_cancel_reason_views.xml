<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- View planning.cancel.reason View List -->
    <record id="view_planning_cancel_reason_list" model="ir.ui.view">
        <field name="name">view.planning.cancel.reason.list</field>
        <field name="model">planning.cancel.reason</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="description" />
            </list>
        </field>
    </record>

    <!-- View planning.cancel.reason form -->
    <record id="view_planning_cancel_reason_form" model="ir.ui.view">
        <field name="name">view.planning.cancel.reason.form</field>
        <field name="model">planning.cancel.reason</field>
        <field name="arch" type="xml">
            <form string="Planning Cancel Reason">
                <sheet>
                    <div class="oe_title">
                        <label for="name" />
                        <h1>
                            <field name="name" placeholder="Name..." />
                        </h1>
                    </div>
                    <group>
                        <field name="description" />
                        <field name="sequence" />
                    </group>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <!-- View planning.cancel.reason search -->
    <record id="view_planning_cancel_reason_search" model="ir.ui.view">
        <field name="name">view.planning.cancel.reason.search</field>
        <field name="model">planning.cancel.reason</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <group expand="1" string="Group By">
                    <filter string="Name" name="name" domain="[]" context="{'group_by':'name'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Action planning.cancel.reason -->
    <record id="action_planning_cancel_reason" model="ir.actions.act_window">
        <field name="name">Planning Cancel Reason</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">planning.cancel.reason</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no examples click here to add new Planning Cancel Reason.
            </p>
        </field>
    </record>

</odoo>
