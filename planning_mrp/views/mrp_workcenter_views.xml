<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="mrp_workcenter_view_kanban_inherit" model="ir.ui.view">
        <field name="name">mrp.workcenter.kanban.inherit</field>
        <field name="model">mrp.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_workcenter_kanban" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='workorder_count']" position="after">
                <field name="planning_slot_count" />
            </xpath>
            <xpath expr="//div[@name='o_wo']" position="inside">
                <button
                    t-if="record.planning_slot_count.raw_value &gt; 0"
                    class="btn btn-info"
                    name="action_planning_action_workcenter_schedule"
                    type="object"
                    context="{'search_default_workcenter_id': id}"
                    groups="mrp.group_mrp_user,planning.group_planning_user"
                >
                    <span>ACTIVE SHIFTS</span>
                </button>
                <button
                    t-if="record.planning_slot_count.raw_value &lt;= 0"
                    class="btn btn-secondary"
                    name="action_planning_action_workcenter_schedule"
                    type="object"
                    context="{'search_default_workcenter_id': id}"
                    groups="mrp.group_mrp_user,planning.group_planning_user"
                >
                    <span>NO SHIFTS</span>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
