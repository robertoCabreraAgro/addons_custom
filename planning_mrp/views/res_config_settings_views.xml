<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_res_config_settings_inherit_planning_manufacturing" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.planning.manufacturing</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="mrp.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='security_lead_time']" position="after">
                <setting id="default_mrp_project" help="Select the default project for manufacturing planning.">
                    <field name="module_project" />
                    <div class="content-group">
                        <div class="content-group" invisible="not module_project">
                            <div class="mt16">
                                <label for="planning_mrp_project_id" class="mr8" string="Default Project" />
                                <field name="planning_mrp_project_id" />
                            </div>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
