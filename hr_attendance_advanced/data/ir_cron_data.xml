<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="1">
    <record id="ir_cron_generate_absences" model="ir.cron">
        <field name="name">Generate automatic absences for delay in attendance</field>
        <field name="model_id" ref="model_hr_leave" />
        <field name="state">code</field>
        <field name="code">model.generate_absences_for_missing_attendance()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field
            name="nextcall"
            eval="(
            datetime.now().replace(hour=8, minute=0, second=0, microsecond=0) + timedelta(days=1)
            ).astimezone(pytz.utc).strftime('%Y-%m-%d %H:%M:%S')"
        />
    </record>
</odoo>
