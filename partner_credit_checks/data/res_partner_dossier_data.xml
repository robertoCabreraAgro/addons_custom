<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
  
    <!-- Highly Reliable Partner -->
    <record id="dossier_highly_reliable" model="res.partner.dossier">
        <field name="name">Highly Reliable</field>
        <field name="description">
        Clients with impeccable credit history, updated documents and no incidents. 
        Access to the highest credit limits and preferential conditions. 
        Require minimal collateral and are usually strategic or long-standing partners.
        </field>
        <field name="active">True</field>
    </record>
  
    <record id="rule_highly_reliable_id" model="res.partner.dossier.rule">
        <field name="name">ID Document</field>
        <field name="dossier_id" ref="dossier_highly_reliable"/>
        <field name="document_tag_id" ref="doc_tag_id_document"/>
        <field name="document_expires">False</field>
        <field name="is_guarantor">False</field>
        <field name="requires_amount">False</field>
        <field name="requires_collateral_amount">False</field>
        <field name="min_quantity">1</field>
        <field name="max_quantity">1</field>
    </record>

    <record id="rule_highly_reliable_contract" model="res.partner.dossier.rule">
        <field name="name">Contract</field>
        <field name="dossier_id" ref="dossier_highly_reliable"/>
        <field name="document_tag_id" ref="doc_tag_contract"/>
        <field name="document_expires">True</field>
        <field name="is_guarantor">False</field>
        <field name="requires_amount">True</field>
        <field name="requires_collateral_amount">False</field>
        <field name="min_quantity">1</field>
        <field name="max_quantity">1</field>
    </record>

    <!-- Reliable Partner -->
    <record id="dossier_reliable" model="res.partner.dossier">
        <field name="name">Reliable</field>
        <field name="description">
        Clients with good payment history and documentation in order, but with certain exposure limits. 
        Require periodic reviews and standard guarantees. 
        Ideal for recurring clients with moderate operations.
        </field>
        <field name="active">True</field>
    </record>
  
    <record id="rule_reliable_id" model="res.partner.dossier.rule">
        <field name="name">ID Document</field>
        <field name="dossier_id" ref="dossier_reliable"/>
        <field name="document_tag_id" ref="doc_tag_id_document"/>
        <field name="document_expires">False</field>
        <field name="is_guarantor">False</field>
        <field name="requires_amount">False</field>
        <field name="requires_collateral_amount">False</field>
        <field name="min_quantity">1</field>
        <field name="max_quantity">1</field>
    </record>

    <record id="rule_reliable_contract" model="res.partner.dossier.rule">
        <field name="name">Contract</field>
        <field name="dossier_id" ref="dossier_reliable"/>
        <field name="document_tag_id" ref="doc_tag_contract"/>
        <field name="document_expires">True</field>
        <field name="is_guarantor">False</field>
        <field name="requires_amount">True</field>
        <field name="requires_collateral_amount">False</field>
        <field name="min_quantity">1</field>
        <field name="max_quantity">1</field>
    </record>

    <record id="rule_reliable_promissory_note" model="res.partner.dossier.rule">
        <field name="name">Promissory Note</field>
        <field name="dossier_id" ref="dossier_reliable"/>
        <field name="document_tag_id" ref="doc_tag_promissory_note"/>
        <field name="document_expires">True</field>
        <field name="is_guarantor">False</field>
        <field name="requires_amount">True</field>
        <field name="requires_collateral_amount">False</field>
        <field name="min_quantity">1</field>
        <field name="max_quantity">1</field>
    </record>

    <!-- Low Reliability Partner -->
    <record id="dossier_low_reliability" model="res.partner.dossier">
        <field name="name">Low Reliability</field>
        <field name="description">
        New customers, with limited history or previous incidences (delinquency, overdue documents). 
        Restricted credits or advance payments. 
        Require additional guarantees and frequent validations to mitigate risks.
        </field>
        <field name="active">True</field>
    </record>
  
    <record id="rule_low_reliability_id" model="res.partner.dossier.rule">
        <field name="name">ID Document</field>
        <field name="dossier_id" ref="dossier_low_reliability"/>
        <field name="document_tag_id" ref="doc_tag_id_document"/>
        <field name="document_expires">False</field>
        <field name="is_guarantor">False</field>
        <field name="requires_amount">False</field>
        <field name="requires_collateral_amount">False</field>
        <field name="min_quantity">1</field>
        <field name="max_quantity">1</field>
    </record>
  
    <record id="rule_low_reliability_id_guarantee" model="res.partner.dossier.rule">
        <field name="name">ID Document (guarantee)</field>
        <field name="dossier_id" ref="dossier_low_reliability"/>
        <field name="document_tag_id" ref="doc_tag_id_document"/>
        <field name="document_expires">False</field>
        <field name="is_guarantor">True</field>
        <field name="requires_amount">False</field>
        <field name="requires_collateral_amount">False</field>
        <field name="min_quantity">1</field>
        <field name="max_quantity">1</field>
    </record>

    <record id="rule_low_reliability_contract" model="res.partner.dossier.rule">
        <field name="name">Contract</field>
        <field name="dossier_id" ref="dossier_low_reliability"/>
        <field name="document_tag_id" ref="doc_tag_contract"/>
        <field name="document_expires">True</field>
        <field name="is_guarantor">False</field>
        <field name="requires_amount">True</field>
        <field name="requires_collateral_amount">False</field>
        <field name="min_quantity">1</field>
        <field name="max_quantity">1</field>
    </record>

    <record id="rule_low_reliability_promissory_note" model="res.partner.dossier.rule">
        <field name="name">Promissory Note</field>
        <field name="dossier_id" ref="dossier_low_reliability"/>
        <field name="document_tag_id" ref="doc_tag_promissory_note"/>
        <field name="document_expires">True</field>
        <field name="is_guarantor">False</field>
        <field name="requires_amount">True</field>
        <field name="requires_collateral_amount">False</field>
        <field name="min_quantity">1</field>
        <field name="max_quantity">1</field>
    </record>

    <record id="rule_low_reliability_warranty" model="res.partner.dossier.rule">
        <field name="name">Warrany</field>
        <field name="dossier_id" ref="dossier_low_reliability"/>
        <field name="document_tag_id" ref="doc_tag_warranty"/>
        <field name="document_expires">True</field>
        <field name="is_guarantor">False</field>
        <field name="requires_amount">True</field>
        <field name="requires_collateral_amount">True</field>
        <field name="min_quantity">2</field>
        <field name="max_quantity">0</field>  <!-- 0 means no maximum limit -->
    </record>
</odoo>
