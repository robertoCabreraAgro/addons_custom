<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Document Type Form View -->
    <record id="view_document_type_form" model="ir.ui.view">
        <field name="name">document.type.form</field>
        <field name="model">document.type</field>
        <field name="arch" type="xml">
            <form string="Document Type">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_documents" type="object" class="oe_stat_button"
                            icon="fa-file-text-o">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="document_count" />
                                </span>
                                <span class="o_stat_text">Documents</span>
                            </div>
                        </button>
                        <button name="action_view_documents" type="object" class="oe_stat_button"
                            icon="fa-exclamation-triangle" invisible="expired_document_count == 0">
                            <div class="o_field_widget o_stat_info text-danger">
                                <span class="o_stat_value">
                                    <field name="expired_document_count" />
                                </span>
                                <span class="o_stat_text">Expired</span>
                            </div>
                        </button>
                        <button name="action_view_documents" type="object" class="oe_stat_button"
                            icon="fa-clock-o" invisible="expiring_soon_count == 0">
                            <div class="o_field_widget o_stat_info text-warning">
                                <span class="o_stat_value">
                                    <field name="expiring_soon_count" />
                                </span>
                                <span class="o_stat_text">Expiring Soon</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Document Type" />
                        <h1>
                            <field name="name" placeholder="e.g., Contract, Certificate, License" />
                        </h1>
                    </div>
                    <group>
                        <group name="basic_info" string="Basic Information">
                            <field name="code" />
                            <field name="active" widget="boolean_toggle" />
                            <field name="sequence" />
                        </group>
                        <group name="compliance" string="Compliance">
                            <field name="is_mandatory" />
                            <field name="is_renewable" />
                            <field name="requires_original" />
                        </group>
                        <group name="validity" string="Validity">
                            <field name="has_expiration" />
                            <field name="default_validity_days" invisible="not has_expiration" />
                            <field name="auto_renew_days_before" invisible="not is_renewable" />
                        </group>
                        <group name="notifications" string="Notifications">
                            <field name="notification_days" placeholder="30,7,1" />
                            <field name="notification_partner_ids" widget="many2many_tags" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Organization" name="organization">
                            <group>
                                <field name="folder_id" />
                                <field name="tag_ids" widget="many2many_tags" />
                            </group>
                        </page>
                        <page string="Template &amp; Instructions" name="template">
                            <group>
                                <field name="template_attachment_id" />
                            </group>
                            <separator string="Instructions" />
                            <field name="instructions" nolabel="1" />
                        </page>
                        <page string="Description" name="description">
                            <field name="description" nolabel="1" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Document Type List View -->
    <record id="view_document_type_list" model="ir.ui.view">
        <field name="name">document.type.list</field>
        <field name="model">document.type</field>
        <field name="arch" type="xml">
            <list string="Document Types" editable="bottom">
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="code" />
                <field name="is_mandatory" />
                <field name="is_renewable" />
                <field name="has_expiration" />
                <field name="default_validity_days" optional="hide" />
                <field name="document_count" sum="Total" />
                <field name="expired_document_count" sum="Total"
                    decoration-danger="expired_document_count > 0" />
                <field name="expiring_soon_count" sum="Total"
                    decoration-warning="expiring_soon_count > 0" />
                <field name="active" widget="boolean_toggle" />
            </list>
        </field>
    </record>

    <!-- Document Type Search View -->
    <record id="view_document_type_search" model="ir.ui.view">
        <field name="name">document.type.search</field>
        <field name="model">document.type</field>
        <field name="arch" type="xml">
            <search string="Document Types">
                <field name="name" string="Document Type" />
                <field name="code" />
                <separator />
                <filter string="Mandatory" name="mandatory" domain="[('is_mandatory', '=', True)]" />
                <filter string="Renewable" name="renewable" domain="[('is_renewable', '=', True)]" />
                <filter string="Has Expiration" name="has_expiration"
                    domain="[('has_expiration', '=', True)]" />
                <separator />
                <filter string="Active" name="active" domain="[('active', '=', True)]" />
                <filter string="Archived" name="archived" domain="[('active', '=', False)]" />
                <group>
                    <filter string="Mandatory" name="group_mandatory" domain="[]"
                        context="{'group_by': 'is_mandatory'}" />
                    <filter string="Has Expiration" name="group_has_expiration" domain="[]"
                        context="{'group_by': 'has_expiration'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Action for Document Types -->
    <record id="action_document_type" model="ir.actions.act_window">
        <field name="name">Document Types</field>
        <field name="res_model">document.type</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_document_type_search" />
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define Document Types
            </p>
            <p>
                Create different document types for categorization and compliance tracking,
                such as contracts, certificates, licenses, policies, etc.
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem
        id="menu_document_type"
        name="Document Types"
        parent="documents.Config"
        action="action_document_type"
        sequence="50" />

</odoo>