<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- GPS Tracking User Group -->
    <record id="group_iot_gps_user" model="res.groups">
        <field name="name">GPS Tracking User</field>
        <field name="category_id" ref="iot.module_category_iot" />
        <field name="implied_ids" eval="[(4, ref('iot.group_iot_user'))]" />
        <field name="comment">User can view GPS tracking data and device positions</field>
    </record>

    <!-- GPS Tracking Manager Group -->
    <record id="group_iot_gps_manager" model="res.groups">
        <field name="name">GPS Tracking Manager</field>
        <field name="category_id" ref="iot.module_category_iot" />
        <field name="implied_ids" eval="[(4, ref('group_iot_gps_user'))]" />
        <field name="comment">Manager can configure GPS devices, create geofences, and manage alerts</field>
    </record>

    <!-- Record Rules -->

    <!-- GPS Tracking Points - Users can see all points from their company or multi-company -->
    <record id="iot_gps_tracking_point_company_rule" model="ir.rule">
        <field name="name">GPS Tracking Points: company rule</field>
        <field name="model_id" ref="model_iot_gps_tracking_point" />
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_iot_gps_user'))]" />
    </record>

    <!-- GPS Configurations - Company rule -->
    <record id="iot_gps_config_company_rule" model="ir.rule">
        <field name="name">GPS Configurations: company rule</field>
        <field name="model_id" ref="model_iot_gps_config" />
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_iot_gps_user'))]" />
    </record>

    <!-- GPS Geofences - Company rule -->
    <record id="iot_gps_geofence_company_rule" model="ir.rule">
        <field name="name">GPS Geofences: company rule</field>
        <field name="model_id" ref="model_iot_gps_geofence" />
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_iot_gps_user'))]" />
    </record>

</odoo>