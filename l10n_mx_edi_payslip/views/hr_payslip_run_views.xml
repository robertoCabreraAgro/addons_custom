<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- Extend the form view to add Mexican fields -->
    <record id="hr_payslip_run_form" model="ir.ui.view">
        <field name="name">view.hr.payslip.run.form.inherit.l10n_mx</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='schedule_pay']" position="after">
                <field name="country_id" invisible="1" />
                <field name="country_code" invisible="1" />
                <field name="l10n_mx_edi_payment_date" invisible="country_code != 'MX'" />
                <field name="l10n_mx_edi_productivity_bonus" invisible="country_code != 'MX'" />
            </xpath>
        </field>
    </record>

    <!-- Extend the kanban view to add Mexican buttons -->
    <record id="hr_payslip_run_view_kanban" model="ir.ui.view">
        <field name="name">view.hr.payslip.run.kanban.inherit.l10n_mx</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_view_kanban" />
        <field name="arch" type="xml">
            <!-- Add hidden fields for Mexican functionality -->
            <xpath expr="//field[@name='payment_report_filename']" position="after">
                <field name="country_code"/>
            </xpath>
            <!-- Add Mexican buttons to the menu -->
            <xpath expr="//button[@name='action_payment_report']" position="after">
                <button
                    name="action_validate"
                    type="object"
                    invisible="state != '02_verify'"
                    string="Confirm payslips"
                    class="btn btn-secondary"
                />
            </xpath>
        </field>
    </record>

</odoo>
