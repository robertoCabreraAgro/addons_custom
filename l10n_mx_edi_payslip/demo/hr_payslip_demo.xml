    <function model="hr.payslip" name="compute_sheet" context="{'allowed_company_ids': [ref('base.demo_company_mx')]}">
        <value
            model="hr.payslip"
            eval="[
                ref('hr_payslip_mlc_cfdi0'),
                ref('hr_payslip_felix_demo'),
                ref('hr_payslip_berenice_demo'),
                ref('hr_payslip_test_cesar_demo')
            ]"
        />
    </function>

