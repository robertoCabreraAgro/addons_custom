<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_journal_form_emitter_regime" model="ir.ui.view">
        <field name="name">account.journal.form.emitter.regime</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form" />
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_edi_config']" position="after">
                <group name="security" string="Fiscal Information">
                    <field
                        name="l10n_mx_edi_fiscal_regime_ids"
                        widget="many2many_tags"
                        placeholder="Select emitter fiscal regimes..."
                        options="{'no_create': True, 'no_open': True}"
                        groups="base.group_system"
                        invisible="1" />
                    <field name="l10n_mx_edi_fiscal_regime_id"
                        options="{'no_create': True, 'no_open': True}"
                        invisible="type not in '(sale, purchase)'" />
                </group>
            </xpath>
        </field>
    </record>
</odoo>

            