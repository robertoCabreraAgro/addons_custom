<odoo>

    <record model="ir.ui.view" id="abc_sale_stock_level_history_search_view">
        <field name="name">abc.classification.product.level.history.search</field>
        <field name="model">abc.classification.product.level.history</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_id" />
                <field name="profile_id" string="Profile" />
                <field name="warehouse_id" string="Warehouse" />
                <field name="computed_level_id" string="ABC Level" />
                <separator />
                <filter
                    string="This Year"
                    name="thisyear"
                    domain="['|', ('to_date', '=', False), '&amp;',('to_date','&lt;=', time.strftime('%%Y-12-31')),('to_date','&gt;=',time.strftime('%%Y-01-01'))]"
                    help="Data collected this year"
                />
                <filter string="Level A" name="level_a" domain="[('computed_level_id.name', '=', 'A')]"/>
                <filter string="Level B" name="level_b" domain="[('computed_level_id.name', '=', 'B')]"/>
                <filter string="Level C" name="level_c" domain="[('computed_level_id.name', '=', 'C')]"/>
                <separator />
                <separator />
                <filter string="Seasonal Star" name="seasonal_star" domain="[('strategic_segment', '=', 'seasonal_star')]"/>
                <filter string="Business Pillar" name="business_pillar" domain="[('strategic_segment', '=', 'business_pillar')]"/>
                <filter string="Seasonal Niche" name="seasonal_niche" domain="[('strategic_segment', '=', 'seasonal_niche')]"/>
                <filter string="Marginal Product" name="marginal_product" domain="[('strategic_segment', '=', 'marginal_product')]"/>
                <group expand="1" string="Group By">
                    <filter
                        string="Warehouse"
                        name="group_by_warehouse"
                        domain="[]"
                        context="{'group_by': 'warehouse_id'}"
                    />
                    <filter
                        string="ABC Level"
                        name="group_by_level"
                        domain="[]"
                        context="{'group_by': 'computed_level_id'}"
                    />
                    <filter
                        string="Profile"
                        name="group_by_profile"
                        domain="[]"
                        context="{'group_by': 'profile_id'}"
                    />
                    <filter
                        string="Strategic Segment"
                        name="group_by_strategic_segment"
                        domain="[]"
                        context="{'group_by': 'strategic_segment'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <record model="ir.ui.view" id="abc_sale_stock_level_history_tree_view">
        <field name="name">abc.classification.product.level.history.tree</field>
        <field name="model">abc.classification.product.level.history</field>
        <field name="arch" type="xml">
            <list default_order="ranking ASC, to_date DESC">
                <field name="from_date" />
                <field name="to_date" />
                <field name="product_id" />
                <field name="computed_level_id" />
                <field name="ranking" />
                <field name="number_so_lines" />
                <field name="total_so_lines" invisible="1" />
                <field name="percentage" />
                <field name="cumulated_percentage" />
                <field name="cumulated_percentage_products" />
                <field name="sum_cumulated_percentages" />
                <field name="season_id" />
                <field name="classification_variance" />
                <field name="season_performance" />
                <field name="strategic_segment" />
            </list>
        </field>
    </record>

    <record model="ir.ui.view" id="abc_classification_history_pivot_view">
        <field name="name">abc.classification.product.level.history.pivot</field>
        <field name="model">abc.classification.product.level.history</field>
        <field name="arch" type="xml">
            <pivot string="ABC Seasonal Analysis">
                <field name="warehouse_id" type="row"/>
                <field name="strategic_segment" type="row"/>
                <field name="product_id" type="row"/>
                <field name="season_id" type="col"/>
                <field name="computed_level_id" type="col"/>
                <field name="number_so_lines" type="measure"/>
                <field name="percentage" type="measure"/>
                <field name="classification_variance" type="measure"/>
                <field name="season_performance" type="measure"/>
            </pivot>
        </field>
    </record>

    <record model="ir.ui.view" id="abc_classification_history_graph_view">
        <field name="name">abc.classification.product.level.history.graph</field>
        <field name="model">abc.classification.product.level.history</field>
        <field name="arch" type="xml">
            <graph string="ABC Seasonal Performance" type="bar">
                <field name="season_id" type="row"/>
                <field name="computed_level_id" type="col"/>
                <field name="number_so_lines" type="measure"/>
            </graph>
        </field>
    </record>

    <record model="ir.actions.act_window" id="abc_sale_stock_level_history_act_window">
        <field name="name">ABC Classification History</field>
        <field name="res_model">abc.classification.product.level.history</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_thisyear': 1, 'search_default_group_by_profile': 1}</field>
    </record>

    <record model="ir.ui.menu" id="abc_sale_stock_level_history_menu">
        <field name="name">ABC Classification History</field>
        <field name="parent_id" ref="stock.menu_warehouse_report" />
        <field name="action" ref="abc_sale_stock_level_history_act_window" />
        <field name="sequence" eval="99" />
    </record>

</odoo>
