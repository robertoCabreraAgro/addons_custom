<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="team_sales_department" model="work.team">
        <field name="name">Sales</field>
        <field name="sequence">0</field>
        <field name="company_id" eval="False" />
    </record>

    <record id="work_team_member_admin_sales" model="work.team.member" forcecreate="0">
        <field name="work_team_id" ref="team_sales_department" />
        <field name="user_id" ref="base.user_admin" />
    </record>

    <record id="salesteam_website_sales" model="work.team">
        <field name="name">Website</field>
        <field name="company_id" eval="False" />
        <field name="active" eval="False" />
    </record>

    <record id="pos_sales_team" model="work.team">
        <field name="name">Point of Sale</field>
        <field name="company_id" eval="False" />
        <field name="active" eval="False" />
    </record>

    <function
        model="work.team"
        name="message_unsubscribe"
        eval="[
                ref('work_team.team_sales_department'),
                ref('work_team.salesteam_website_sales'),
                ref('work_team.pos_sales_team')],
                [ref('base.partner_root')
        ]" />
</odoo>
