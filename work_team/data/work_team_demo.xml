<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="base.user_demo" model="res.users">
        <field name="group_ids"
            eval="[
                (3, ref('work_team.group_sale_manager')),
                (3, ref('work_team.group_sale_salesman_all_leads')),
                (4, ref('work_team.group_sale_salesman'))]" />
    </record>

    <record id="team_sales_department" model="work.team">
        <field name="name">Sales</field>
    </record>

    <record id="work_team_1" model="work.team">
        <field name="name">Pre-Sales</field>
        <field name="company_id" eval="False" />
    </record>

    <record id="work_team_member_demo_team_1" model="work.team.member">
        <field name="user_id" ref="base.user_demo" />
        <field name="work_team_id" ref="work_team.work_team_1" />
    </record>
</odoo>
