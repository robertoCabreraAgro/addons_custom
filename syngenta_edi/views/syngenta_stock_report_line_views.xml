<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_syngenta_stock_report_line_search" model="ir.ui.view">
        <field name="name">syngenta.stock.report.line.search</field>
        <field name="model">syngenta.stock.report.line</field>
        <field name="arch" type="xml">
            <search string="Syngenta Inventory Search">
                <field name="product_id" />
                <field name="product_category_id" />
                <separator />
                <group>
                    <filter
                        name="group_by_category_id"
                        string="Category"
                        context="{'group_by': 'product_category_id'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <record id="view_syngenta_stock_report_line_list" model="ir.ui.view">
        <field name="name">syngenta.stock.report.line.list</field>
        <field name="model">syngenta.stock.report.line</field>
        <field name="arch" type="xml">
            <list string="Syngenta Inventory" editable="top" create="1" delete="1" multi_edit="1">
                <field name="product_id" options="{'no_create': True}" />
                <field name="product_category_id" />
                <field name="quantity" />
                <field name="transit_quantity" />
                <field name="date_inventory" optional="hide" />
                <field name="company_id" optional="hide" />
            </list>
        </field>
    </record>

    <record id="action_syngenta_stock_report_line" model="ir.actions.act_window">
        <field name="name">Syngenta Inventory</field>
        <field name="res_model">syngenta.stock.report.line</field>
        <field name="view_mode">list</field>
        <field name="context">{}</field>
    </record>
</odoo>
