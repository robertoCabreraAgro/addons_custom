<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_syngenta_sale_report_line_search" model="ir.ui.view">
        <field name="name">syngenta.sale.report.line.search</field>
        <field name="model">syngenta.sale.report.line</field>
        <field name="arch" type="xml">
            <search string="Sale Lines Search">
                <field name="partner_id" />
                <field name="product_id" />
                <separator />
                <group>
                    <filter name="group_by_agreement" string="Agreement" context="{'group_by': 'agreement_id'}" />
                    <filter name="group_by_document" string="Document" context="{'group_by': 'report_id'}" />
                    <filter name="group_by_partner" string="Customer" context="{'group_by': 'partner_id'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="view_syngenta_sale_report_line_list" model="ir.ui.view">
        <field name="name">syngenta.sale.report.line.list</field>
        <field name="model">syngenta.sale.report.line</field>
        <field name="arch" type="xml">
            <list string="Sale Lines" delete="1" multi_edit="1">
                <field name="agreement_id" />
                <field name="report_id" />
                <field name="product_id" />
                <field name="product_qty" />
                <field name="price_unit" />
                <field name="price_subtotal" />
                <field name="company_id" optional="hide" />
            </list>
        </field>
    </record>

    <record id="action_syngenta_sale_report_line" model="ir.actions.act_window">
        <field name="name">Sale Lines</field>
        <field name="res_model">syngenta.sale.report.line</field>
        <field name="view_mode">list</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Sale Lines
            </p>
        </field>
    </record>
</odoo>
