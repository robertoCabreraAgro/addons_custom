<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="search_product_lot_filter_marin" model="ir.ui.view">
        <field name="name">stock.lot.search</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="product_asset.search_product_lot_filter" />
        <field name="arch" type="xml">
            <field name="asset_manager_id" position="after">
                <field name="gps_device_id" />
            </field>
        </field>
    </record>

    <record id="view_list_stock_lot" model="ir.ui.view">
        <field name="name">stock.lot.list</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="product_asset.view_list_stock_lot" />
        <field name="arch" type="xml">
            <field name="service_activity" position="before">
                <field name="gps_device_id" string="GPS device" optional="hide" />
            </field>
        </field>
    </record>

    <record id="view_production_lot_form" model="ir.ui.view">
        <field name="name">stock.lot.form</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form" />
        <field name="priority" eval="200" />
        <field name="arch" type="xml">
            <xpath expr="/page[@name='vouchers']/group" position="after">
                <group>
                    <group string="IMEI">
                        <field name="gps_device_id" string="GPS device" />
                    </group>
                    <group string="Others">
                    </group>
                </group>
            </xpath>
        </field>
    </record>

</odoo>