<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_public_view_form_inherit_loan_report" model="ir.ui.view">
        <field name="name">hr.employee.public.form.inherit.loan.report</field>
        <field name="model">hr.employee.public</field>
        <field name="inherit_id" ref="hr.hr_employee_public_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='location']" position="after">
                <group string="Reports" name="reports">
                    <field name="enable_vehicle_loan"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
