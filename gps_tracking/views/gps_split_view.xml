<odoo>

    <record id="view_gps_tracking_device_search" model="ir.ui.view">
        <field name="name">gps.tracking.device.search</field>
        <field name="model">gps.tracking.device</field>
        <field name="arch" type="xml">
            <search string="Buscar Dispositivo">
                <field name="imei"/>
                <field name="address"/>
                <field name="satellite"/>
                <field name="speed"/>
            </search>
        </field>
    </record>

    <record id="action_gps_tracking_dashboard" model="ir.actions.client">
        <field name="name">GPS Tracking Dashboard</field>
        <field name="tag">gps_tracking_dashboard</field>
        <field name="target">current</field>
        <field name="params" eval="{
            'searchViewId': ref('gps_tracking.view_gps_tracking_device_search'),
            'context': {},
            }"/>
    </record>  

    <menuitem id="menu_gps_tracking_dashboard" name="GPS Tracking Device" action="action_gps_tracking_device" parent="menu_gps_tracking_device"/>

    <record id="action_gps_tracking_client_action" model="ir.actions.client">
        <field name="name">GPS Tracking Dashboard</field>
        <field name="tag">gps_tracking_client_action</field>
        <field name="target">current</field>
        <field name="params" eval="{
            'searchViewId': ref('gps_tracking.view_gps_tracking_device_search'),
            'context': {},
        }"/>
    </record>

    <menuitem id="menu_gps_tracking_dashboard_action"
        name="GPS Dashboard"
        parent="menu_gps_tracking_device"
        action="action_gps_tracking_client_action"/>

    <!-- Plantilla Timeline-->

    <record id="action_gps_tracking_client_action_timeline" model="ir.actions.client">
        <field name="name">GPS Tracking Timeline</field>
        <field name="tag">gps_tracking_client_action_timeline</field>
        <field name="target">current</field>
        <field name="params" eval="{
            'searchViewId': ref('gps_tracking.view_gps_tracking_device_search'),
            'context': {},
        }"/>
    </record>
    
    <menuitem id="menu_gps_tracking_dashboard_action_timeline"
        name="GPS Timeline"
        parent="menu_gps_tracking_device"
        action="action_gps_tracking_client_action_timeline"/>

    <!-- Plantilla QWeb -->
    <template id="gps_tracking_dashboard_template">
        <div class="o_gps_tracking_dashboard">
            <div class="o_gps_tracking_kanban">
                <!-- Aquí se renderizan las tarjetas kanban -->
            </div>
            <div class="o_gps_tracking_map">
                <!-- Aquí se renderizará el mapa -->
            </div>
        </div>
    </template>

    <record id="view_gps_geofence_list" model="ir.ui.view">
        <field name="name">gps.geofence.list</field>
        <field name="model">gps.geofence</field>
        <field name="arch" type="xml">
            <list string="Geocercas">
                <field name="name"/>
                <field name="geometry"/>
                <field name="color"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_gps_geofence_form" model="ir.ui.view">
        <field name="name">gps.geofence.form</field>
        <field name="model">gps.geofence</field>
        <field name="arch" type="xml">
            <form string="Geocerca">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="geometry"/>
                        <field name="color"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gps_geofence" model="ir.actions.act_window">
        <field name="name">Geocercas</field>
        <field name="res_model">gps.geofence</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_gps_geofence" name="Geocercas"
            parent="menu_gps_tracking_device"
            action="action_gps_geofence"/>
</odoo>