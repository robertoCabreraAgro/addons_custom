<odoo>
    <!-- Vista Geoengine para puntos de seguimiento -->
    <record id="view_tracking_log_geoengine" model="ir.ui.view">
        <field name="name">gps.tracking.log.geoengine</field>
        <field name="type">geoengine</field>
        <field name="model">gps.tracking.log</field>
        <field name="arch" type="xml">
            <geoengine>
                <field name="the_point"
                    string="Position"
                    options='{"color": "#00FF00", "opacity": 0.8}' />
                <!-- Templates para mostrar información en los puntos en el mapa -->
            </geoengine>
        </field>
    </record>
</odoo>
