<odoo>
    <!-- Vista en lista para dispositivos de GPS -->
    <record id="view_gps_tracking_device_list" model="ir.ui.view">
        <field name="name">gps.tracking.device.list</field>
        <field name="model">gps.tracking.device</field>
        <field name="arch" type="xml">
            <list string="GPS Tracking Devices">
                <field name="imei"/>
            </list>
        </field>
    </record>

    <!-- Vista Geoengine para dispositivos GPS -->
<record id="view_gps_tracking_device_geoengine" model="ir.ui.view">
    <field name="name">gps.tracking.device.geoengine</field>
    <field name="model">gps.tracking.device</field>
    <field name="type">geoengine</field>
    <field name="arch" type="xml">
        <geoengine editable="1">
            <field name="imei" invisible="1"></field>
            <field name="speed" invisible="1"></field>
            <field name="altitude" invisible="1"></field>
            <field name="timestamp" invisible="1"></field>
            <!-- Plantillas para info_box -->
            <templates>
                <t t-name="info_box">
                    <b>IMEI: <t t-esc="record.imei.value"/></b>
                    <ul>
                        <li>Timestamp: <t t-esc="record.timestamp.value"/></li>
                        <li>Speed: <t t-esc="record.speed.value"/></li>
                        <li>Altitude: <t t-esc="record.altitude.value"/></li>
                    </ul>
                </t>
            </templates>
            <!-- Mostrar la ruta histórica -->
            <field name="history_route"
                    string="History Route"
                    options='{"color": "#0000FF", "strokeWidth": 4}'/>
            <!-- Mostrar los puntos de seguimiento -->
            <field name="the_point" 
                    string="Current Position" 
                    options='{"fillColor": "#00FF00", "strokeColor": "#FF0000", "pointRadius": 8}'/>
        </geoengine>
    </field>
</record>

    <!-- Capa vectorial para 'the_point' -->
    <record id="geoengine_vector_layer_device" model="geoengine.vector.layer">
        <field name="name">Device Positions</field>
        <field name="model_id" ref="model_gps_tracking_device"/>
        <field name="geo_field_id" ref="field_gps_tracking_device__the_point"/>
        <field name="attribute_field_id" ref="field_gps_tracking_device__imei"/>
        <field name="view_id" ref="view_gps_tracking_device_geoengine"/>
        <field name="geo_repr">basic</field>
        <field name="active_on_startup">True</field>
        <field eval="1" name="sequence"/>
        <field name="layer_opacity">0.8</field>
        <field name="begin_color">#00FF00</field>
        <field name="end_color">#00FF00</field>
    </record>

    <!-- Capa vectorial para 'history_route' -->
    <record id="geoengine_vector_layer_history_route" model="geoengine.vector.layer">
        <field name="name">History Route Layer</field>
        <field name="model_id" ref="model_gps_tracking_device"/>
        <field name="geo_field_id" ref="field_gps_tracking_device__history_route"/>
        <field name="attribute_field_id" ref="field_gps_tracking_device__imei"/>
        <field name="view_id" ref="view_gps_tracking_device_geoengine"/>
        <field name="geo_repr">basic</field>
        <field name="active_on_startup">False</field>
        <field eval="2" name="sequence"/>
        <field name="layer_opacity">0.8</field>
        <field name="begin_color">#FF0000</field>
        <field name="end_color">#FF0000</field>
    </record>

    <!-- Capa raster para Google Maps utilizando 'xyz' -->
    <record id="geoengine_raster_layer_google_maps" model="geoengine.raster.layer">
        <field name="name">Google Maps Layer</field>
        <field name="view_id" ref="view_gps_tracking_device_geoengine" />
        <field name="raster_type">xyz</field>
        <field name="url">https://mt0.google.com/vt/lyrs=m&amp;x={x}&amp;y={y}&amp;z={z}&amp;key=TU_CLAVE_API_REAL</field>        
        <field eval="0" name="overlay" />
    </record>

    <!-- Vista Geoengine para puntos de seguimiento -->
    <record id="view_tracking_point_geoengine" model="ir.ui.view">
        <field name="name">gps.tracking.point.geoengine</field>
        <field name="type">geoengine</field>
        <field name="model">gps.tracking.point</field>
        <field name="arch" type="xml">
            <geoengine>
                <field name="the_point"
                    string="Position"
                    options='{"color": "#00FF00", "opacity": 0.8}'/>
                <!-- Templates para mostrar información en los puntos en el mapa -->
                
            </geoengine>
        </field>
    </record>

    <!-- Capa raster para la vista geoengine de puntos de seguimiento -->
    <record id="geoengine_raster_layer_google_maps_point" model="geoengine.raster.layer">
        <field name="name">Google Maps Layer for Tracking Points</field>
        <field name="view_id" ref="view_tracking_point_geoengine" />
        <field name="raster_type">xyz</field>
        <field name="url">https://mt0.google.com/vt/lyrs=m&amp;x={x}&amp;y={y}&amp;z={z}&amp;key=TU_CLAVE_API_REAL</field>        
        <field eval="0" name="overlay" />
    </record>

    <!-- Vista en formulario para dispositivos de GPS -->
    <record id="view_gps_tracking_device_form" model="ir.ui.view">
        <field name="name">gps.tracking.device.form</field>
        <field name="model">gps.tracking.device</field>
        <field name="arch" type="xml">
            <form string="GPS Tracking Device">
                <sheet>
                    <group>
                        <field name="imei"/>
                        <field name="last_point_id"/>
                        <field name="timestamp"/>
                    </group>
                    <notebook>
                        <page string="Tracking Points">
                            <field name="tracking_points">
                                <list>
                                    <field name="timestamp"/>
                                    <field name="latitude"/>
                                    <field name="longitude"/>
                                    <field name="altitude"/>
                                    <field name="angle"/>
                                    <field name="speed"/>
                                </list>
                            </field>
                        </page>
                        <!-- Pestaña History Route -->
                        <page string="History Route">
                            <geoengine>
                                <field name="history_route" 
                                        string="History Route" 
                                        options='{"color": "#0000FF", "strokeWidth": 4}'/>
                            </geoengine>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <!-- Acción para mostrar los dispositivos GPS en vistas list y form -->
    <record id="action_gps_tracking_device" model="ir.actions.act_window">
        <field name="name">GPS Tracking Devices</field>
        <field name="res_model">gps.tracking.device</field>
        <field name="view_mode">list,form,geoengine</field>
    </record>

    <!-- Menú para acceder a los dispositivos de rastreo GPS -->
    <menuitem id="menu_gps_tracking_device" name="GPS Tracking Devices" action="action_gps_tracking_device"/>

    <!-- Registro del dispositivo GPS -->
