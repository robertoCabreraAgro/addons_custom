<odoo>
    <menuitem id="gps_tracking_menu_root" name="GPS Tracking" sequence="130"
        groups="group_gps_tracking_user"
        web_icon="gps_tracking,static/description/icon.png">

        <menuitem id="menu_gps_tracking_dashboard"
            name="Dashboard"
            action="action_gps_tracking_client_action"
            sequence="10" />

        <menuitem id="menu_gps_tracking_timeline"
            name="Timeline"
            action="action_gps_tracking_client_action_timeline"
            groups="group_gps_tracking_reporting"
            sequence="20" />

        <menuitem id="menu_gps_tracking_operations"
            name="Operations"
            sequence="30">

            <menuitem id="menu_gps_tracking_device"
                name="Devices"
                action="action_gps_tracking_device"
                groups="group_gps_tracking_reporting"
                sequence="10" />

            <menuitem id="menu_gps_geofence"
                name="Geographic Areas"
                action="action_gps_geofence"
                sequence="20" />
        </menuitem>

        <menuitem id="menu_gps_tracking_reporting"
            name="Reporting"
            groups="group_gps_tracking_reporting"
            sequence="40">

            <menuitem id="menu_gps_tracking_report"
                name="Daily Perfomance Summary"
                action="action_gps_tracking_report"
                sequence="20" />

            <menuitem id="menu_gps_tracking_point_report"
                name="Tracking History"
                action="action_gps_tracking_point_report"
                sequence="40" />

            <menuitem id="menu_asset_loan_report"
                name="Préstamos de Vehículos"
                action="action_asset_loan_report"
                groups="group_gps_tracking_vehicle_loan"
                sequence="50" />
        </menuitem>

        <menuitem id="menu_gps_tracking_configuration"
            name="Configuration"
            groups="group_gps_tracking_manager"
            sequence="50">

            <menuitem id="menu_gps_tracking_config"
                name="Device configurations"
                action="action_gps_tracking_config"
                sequence="10" />

            <menuitem id="menu_gps_geofence_type"
                name="Area Types"
                action="action_gps_geofence_type"
                sequence="20" />
        </menuitem>
    </menuitem>
</odoo>
