<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- GPS Data Quality Validation Parameters -->

    <!-- GPS Accuracy Parameters -->
    <record id="param_gps_min_satellites" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.min_satellites</field>
        <field name="value">4</field>
    </record>

    <record id="param_gps_max_hdop" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.max_hdop</field>
        <field name="value">5.0</field>
    </record>

    <!-- Coordinate Quality Parameters -->
    <record id="param_coord_min_latitude" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.min_latitude</field>
        <field name="value">-90.0</field>
    </record>

    <record id="param_coord_max_latitude" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.max_latitude</field>
        <field name="value">90.0</field>
    </record>

    <record id="param_coord_min_longitude" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.min_longitude</field>
        <field name="value">-180.0</field>
    </record>

    <record id="param_coord_max_longitude" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.max_longitude</field>
        <field name="value">180.0</field>
    </record>

    <!-- Vehicle Parameters -->
    <record id="param_max_realistic_speed" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.max_realistic_speed</field>
        <field name="value">200.0</field>
    </record>

    <record id="param_max_fuel_level" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.max_fuel_level</field>
        <field name="value">100.0</field>
    </record>

    <record id="param_max_engine_hours" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.max_engine_hours</field>
        <field name="value">50000</field>
    </record>

    <!-- Electrical Parameters -->
    <record id="param_min_external_voltage" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.min_external_voltage</field>
        <field name="value">8.0</field>
    </record>

    <record id="param_max_external_voltage" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.max_external_voltage</field>
        <field name="value">30.0</field>
    </record>

    <record id="param_min_internal_voltage" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.min_internal_voltage</field>
        <field name="value">2.5</field>
    </record>

    <record id="param_max_internal_voltage" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.max_internal_voltage</field>
        <field name="value">5.5</field>
    </record>

    <record id="param_min_gsm_signal" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.min_gsm_signal</field>
        <field name="value">0</field>
    </record>

    <record id="param_max_gsm_signal" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.max_gsm_signal</field>
        <field name="value">31</field>
    </record>

    <!-- Speed Validation Parameters -->
    <record id="param_max_speed_change" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.max_speed_change_kmh_per_sec</field>
        <field name="value">10.0</field>
    </record>

    <record id="param_speed_validation_window" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.speed_validation_window_seconds</field>
        <field name="value">30</field>
    </record>

    <!-- Temporal Sequence Parameters -->
    <record id="param_max_time_gap" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.max_time_gap_hours</field>
        <field name="value">24</field>
    </record>

    <record id="param_min_time_interval" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.min_time_interval_seconds</field>
        <field name="value">1</field>
    </record>

    <!-- Duplicate Detection Parameters -->
    <record id="param_duplicate_time_window" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.duplicate_time_window_seconds</field>
        <field name="value">10</field>
    </record>

    <record id="param_duplicate_coordinate_tolerance" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.duplicate_coordinate_tolerance</field>
        <field name="value">0.00001</field>
    </record>

    <record id="param_duplicate_extended_window" model="ir.config_parameter">
        <field name="key">gps_tracking.validation.duplicate_extended_window_seconds</field>
        <field name="value">300</field>
    </record>

</odoo>