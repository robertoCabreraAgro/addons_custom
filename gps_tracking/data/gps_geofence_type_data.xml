<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Predefined Area Types -->
        <record id="geofence_type_property" model="gps.geofence.type">
            <field name="name">Property</field>
            <field name="code">property</field>
            <field name="color">#00008B</field>
            <field name="sequence">10</field>
            <field name="description">Main property or estate area</field>
        </record>

        <record id="geofence_type_cultivation_zone" model="gps.geofence.type">
            <field name="name">Cultivation Zone</field>
            <field name="code">cultivation_zone</field>
            <field name="color">#008000</field>
            <field name="sequence">11</field>
            <field name="description">Agricultural cultivation and farming areas</field>
        </record>

        <record id="geofence_type_warehouse" model="gps.geofence.type">
            <field name="name">Warehouse</field>
            <field name="code">warehouse</field>
            <field name="color">#FF0000</field>
            <field name="sequence">12</field>
            <field name="description">Storage and warehouse facilities</field>
        </record>

        <record id="geofence_type_corral" model="gps.geofence.type">
            <field name="name">Corral</field>
            <field name="code">corral</field>
            <field name="color">#FF0000</field>
            <field name="sequence">12</field>
            <field name="description">Livestock containment areas</field>
        </record>

        <record id="geofence_type_other" model="gps.geofence.type">
            <field name="name">Other</field>
            <field name="code">other</field>
            <field name="color">#808080</field>
            <field name="sequence">13</field>
            <field name="description">Other miscellaneous areas</field>
        </record>

        <!-- Additional area types for backward compatibility -->
        <record id="geofence_type_parcel" model="gps.geofence.type">
            <field name="name">Parcel</field>
            <field name="code">parcel</field>
            <field name="color">#90EE90</field>
            <field name="sequence">11</field>
            <field name="description">Land parcel subdivision</field>
        </record>
    </data>
</odoo>