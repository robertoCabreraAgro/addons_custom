<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.product</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@id='product_general_settings']" position="inside">
                <setting id="product_lenght_in_yd" string="Lenght"
                    help="Define your lenght unit of measure">
                    <field name="product_lenght_in_yd" class="o_light_label" widget="radio"
                        options="{'horizontal': true}" />
                </setting>
                <setting id="product_odometer_in_mi" string="Odometer"
                    help="Define your odometer unit of measure">
                    <field name="product_odometer_in_mi" class="o_light_label" widget="radio"
                        options="{'horizontal': true}" />
                </setting>
                <setting id="product_area_in_square_ft" string="Area"
                    help="Define your area unit of measure">
                    <field name="product_area_in_square_ft" class="o_light_label" widget="radio"
                        options="{'horizontal': true}" />
                </setting>
            </xpath>
        </field>
    </record>

</odoo>
