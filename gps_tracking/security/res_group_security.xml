<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <record id="module_category_gps_tracking" model="ir.module.category">
        <field name="name">GPS Tracking</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_gps_tracking_user" model="res.groups">
        <field name="name">User: Salesperson</field>
        <field name="category_id" ref="module_category_gps_tracking" />
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
        <field name="sequence">10</field>
    </record>

    <record id="group_gps_tracking_reporting" model="res.groups">
        <field name="name">User: Sales Manager</field>
        <field name="category_id" ref="module_category_gps_tracking" />
        <field name="implied_ids" eval="[(4, ref('group_gps_tracking_user'))]" />
        <field name="sequence">20</field>
    </record>

    <record id="group_gps_tracking_vehicle_loan" model="res.groups">
        <field name="name">User: Fleet Manager</field>
        <field name="category_id" ref="module_category_gps_tracking" />
        <field name="implied_ids" eval="[(4, ref('group_gps_tracking_reporting'))]" />
        <field name="sequence">30</field>
    </record>

    <record id="group_gps_tracking_private" model="res.groups">
        <field name="name">User: Board</field>
        <field name="category_id" ref="module_category_gps_tracking" />
        <field name="implied_ids" eval="[(4, ref('group_gps_tracking_vehicle_loan'))]" />
        <field name="sequence">40</field>
    </record>

    <record id="group_gps_tracking_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_gps_tracking" />
        <field name="implied_ids" eval="[(4, ref('group_gps_tracking_private'))]" />
        <field name="sequence">50</field>
    </record>
</odoo>
