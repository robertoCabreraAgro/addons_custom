<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit res.config.settings to add forecast configuration -->
    <record id="res_config_settings_view_form_forecast" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos.product.forecast</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_connected_devices_section']" position="inside">
                <div class="col-12 col-lg-6 o_setting_box">
                        <field name="show_product_forecast"/>
                        <field name="pos_config_id" required="1"/>
                        <div class="content-group mt16" invisible="not show_product_forecast or not pos_config_id">
                            <div>
                                <label for="forecast_warehouse_ids" string="Selected Warehouses" class="fw-normal"/>
                                <field name="forecast_warehouse_ids"
                                    widget="many2many_tags"
                                    domain="[('company_id', '=', company_id)]"
                                    context="{'default_pos_config_id': pos_config_id, 'pos_config_id': pos_config_id}"
                                    placeholder="All Warehouses"
                                />
                            </div>
                        </div>
                    </div>

            </xpath>
        </field>
    </record>
</odoo>
