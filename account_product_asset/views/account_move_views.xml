<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="account_move_view_tree" model="ir.ui.view">
        <field name="name">account.move.list.inherit.product_asset</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree" />
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date']" position="after">
                <field name="invoice_date"
                    readonly="state != 'draft'"
                    optional="show" />
            </xpath>
        </field>
    </record>

    <record id="view_move_form" model="ir.ui.view">
        <field name="name">account.move.form.product_asset</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='line_ids']//field[@name='account_id']" position="after">
                <field name='need_asset'
                    column_invisible="True" />
                <field name='asset_id'
                    required="need_asset and parent.move_type in ('in_invoice', 'in_refund')"
                    column_invisible="parent.move_type not in ('in_invoice', 'in_refund')"
                    optional='hidden' />
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='account_id']" position="after">
                <field name='need_asset'
                    column_invisible="True" />
                <field name='asset_id'
                    required="need_asset and parent.move_type in ('in_invoice', 'in_refund')"
                    column_invisible="parent.move_type not in ('in_invoice', 'in_refund')"
                    optional='hidden' />
            </xpath>
        </field>
    </record>
</odoo>