<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- This view extends the existing button to show the count_bill field -->
    <record id="stock_lot_view_form" model="ir.ui.view">
        <field name="name">stock.lot.form.account_product_asset</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="product_asset.view_production_lot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_bills"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-credit-card">
                    <field name="count_bill" string="Bills" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>