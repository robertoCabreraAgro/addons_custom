<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record Rules for marin.ai.agent -->
    

    <!-- AI Agents: Only active agents visible to users -->
    <record id="marin_ai_agent_active_rule" model="ir.rule">
        <field name="name">Active AI Agents for Users</field>
        <field name="model_id" ref="model_marin_ai_agent"/>
        <field name="domain_force">[('active', '=', True)]</field>
        <field name="groups" eval="[(4, ref('group_marin_ai_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- AI Agents: Admins can see all agents -->
    <record id="marin_ai_agent_admin_rule" model="ir.rule">
        <field name="name">All AI Agents for Admin</field>
        <field name="model_id" ref="model_marin_ai_agent"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_marin_ai_admin'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Record Rules for marin.ai.agent.model -->
    

    <!-- Record Rules for marin.ai.prompt -->
    
    <!-- AI Prompts: Users can only see their own prompts -->
    <record id="marin_ai_prompt_personal_rule" model="ir.rule">
        <field name="name">Personal AI Prompts</field>
        <field name="model_id" ref="model_marin_ai_prompt"/>
        <field name="domain_force">[('user', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_marin_ai_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- AI Prompts: Admins can see all prompts -->
    <record id="marin_ai_prompt_admin_rule" model="ir.rule">
        <field name="name">All AI Prompts for Admin</field>
        <field name="model_id" ref="model_marin_ai_prompt"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_marin_ai_admin'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Record Rules for marin.ai.prompt.template -->
    
</odoo>