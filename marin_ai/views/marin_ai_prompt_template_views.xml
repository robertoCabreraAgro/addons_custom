<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Test Template Action -->
    <record id="action_test_template" model="ir.actions.act_window">
        <field name="name">Preview Template</field>
        <field name="res_model">marin.ai.prompt</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_prompt_template_id': active_id, 'default_prompt': 'Test preview of template'}</field>
    </record>

    <!-- Prompt Template List View -->
    <record id="view_marin_ai_prompt_template_list" model="ir.ui.view">
        <field name="name">marin.ai.prompt.template.list</field>
        <field name="model">marin.ai.prompt.template</field>
        <field name="arch" type="xml">
            <list string="Prompt Templates">
                <field name="display_name"/>
                <field name="category"/>
                <field name="usage_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Prompt Template Form View -->
    <record id="view_marin_ai_prompt_template_form" model="ir.ui.view">
        <field name="name">marin.ai.prompt.template.form</field>
        <field name="model">marin.ai.prompt.template</field>
        <field name="arch" type="xml">
            <form string="Prompt Template">
                <header>
                    <button name="%(action_test_template)d" 
                            string="Preview Template" 
                            type="action" 
                            class="btn-secondary"
                            invisible="not active"/>
                    <field name="active" widget="boolean_button" 
                           options="{'terminology': {'string_true': 'Active', 'string_false': 'Inactive'}}"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_usage" icon="fa-line-chart">
                            <field string="Usage" name="usage_count" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <div class="o_row">
                            <field name="category" widget="badge" 
                                   decoration-success="category == 'orchestrator'"
                                   decoration-info="category == 'chat'"
                                   decoration-warning="category in ['inventory', 'sales']"
                                   decoration-primary="category == 'final_response'"
                                   decoration-muted="category == 'custom'"/>
                        </div>
                        <label for="name" string="Template Name"/>
                        <h1>
                            <field name="name" placeholder="e.g., Sales Query Template, Inventory Assistant"/>
                        </h1>
                    </div>
                    <group>
                        <group name="main_config" string="Configuration">
                            <field name="category" widget="selection"/>
                        </group>
                        <group name="stats" string="Statistics">
                            <field name="usage_count" readonly="1" widget="integer"/>
                        </group>
                    </group>
                    <group name="description_group" string="Description">
                        <field name="description" 
                               placeholder="Describe the purpose and usage of this template...&#10;&#10;Example:&#10;This template is designed for sales-related queries. It helps the AI understand product information and customer requirements to provide accurate sales assistance."
                               nolabel="1"/>
                    </group>
                    <group name="template_group" string="Prompt Template">
                        <div class="alert alert-info" role="alert">
                            <h6><i class="fa fa-info-circle"/> Available Placeholders:</h6>
                            <ul class="mb-0">
                                <li><code>{user_input}</code> - The user's question or request</li>
                                <li><code>{input}</code> - Alternative to user_input</li>
                                <li><code>{table_info}</code> - Database schema information (for SQL agents)</li>
                                <li><code>{context}</code> - Additional context information</li>
                                <li><code>{history}</code> - Previous conversation history</li>
                                <li><code>{question}</code> - The processed question</li>
                                <li><code>{result}</code> - Query results (for final response templates)</li>
                            </ul>
                        </div>
                        <field name="prompt" 
                               widget="ace" 
                               options="{'mode': 'markdown', 'theme': 'github', 'fontSize': 14, 'showPrintMargin': false, 'wrap': true, 'showLineNumbers': true}"
                               nolabel="1" 
                               placeholder="Enter your prompt template with placeholders...&#10;&#10;Example:&#10;You are a helpful AI assistant specialized in {category} operations.&#10;&#10;Context: {table_info}&#10;&#10;User question: {user_input}&#10;&#10;Please provide a detailed and accurate response."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Prompt Template Kanban View -->
    <record id="view_marin_ai_prompt_template_kanban" model="ir.ui.view">
        <field name="name">marin.ai.prompt.template.kanban</field>
        <field name="model">marin.ai.prompt.template</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="category"/>
                <field name="description"/>
                <field name="usage_count"/>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="text-muted">
                                    <field name="category" widget="badge"/>
                                </div>
                                <div class="o_kanban_record_subtitle text-muted mt8">
                                    <field name="description"/>
                                </div>
                                <div class="o_kanban_record_bottom mt8">
                                    <div class="oe_kanban_bottom_left">
                                        <span>Used <field name="usage_count"/> times</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Prompt Template Search View -->
    <record id="view_marin_ai_prompt_template_search" model="ir.ui.view">
        <field name="name">marin.ai.prompt.template.search</field>
        <field name="model">marin.ai.prompt.template</field>
        <field name="arch" type="xml">
            <search string="Search Prompt Templates">
                <field name="name"/>
                <field name="category"/>
                <field name="description"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Orchestrator" name="orchestrator" domain="[('category', '=', 'orchestrator')]"/>
                <filter string="Inventory" name="inventory" domain="[('category', '=', 'inventory')]"/>
                <filter string="Sales" name="sales" domain="[('category', '=', 'sales')]"/>
                <filter string="Chat" name="chat" domain="[('category', '=', 'chat')]"/>
                <filter string="Final Response" name="final_response" domain="[('category', '=', 'final_response')]"/>
                <filter string="Custom" name="custom" domain="[('category', '=', 'custom')]"/>
                <separator/>
                <filter string="Most Used" name="most_used" domain="[('usage_count', '>', 0)]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Prompt Template Action -->
    <record id="action_marin_ai_prompt_template" model="ir.actions.act_window">
        <field name="name">Prompt Templates</field>
        <field name="res_model">marin.ai.prompt.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_marin_ai_prompt_template_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Prompt Template
            </p>
            <p>
                Prompt templates help standardize AI interactions.
                Create reusable templates for different agent types and use cases.
            </p>
        </field>
    </record>

    <!-- Prompt History List View -->
    <record id="view_marin_ai_prompt_list" model="ir.ui.view">
        <field name="name">marin.ai.prompt.list</field>
        <field name="model">marin.ai.prompt</field>
        <field name="arch" type="xml">
            <list string="Prompt History" create="false">
                <field name="name"/>
                <field name="agent_id"/>
                <field name="user"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Prompt History Form View -->
    <record id="view_marin_ai_prompt_form" model="ir.ui.view">
        <field name="name">marin.ai.prompt.form</field>
        <field name="model">marin.ai.prompt</field>
        <field name="arch" type="xml">
            <form string="Prompt History" create="false" edit="false">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="agent_id" readonly="1"/>
                            <field name="user" readonly="1"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="prompt_template_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Prompt">
                        <field name="prompt" widget="ace" options="{'mode': 'text'}" readonly="1" nolabel="1"/>
                    </group>
                    <group string="Response">
                        <field name="response" widget="ace" options="{'mode': 'text'}" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Prompt History Action -->
    <record id="action_marin_ai_prompt" model="ir.actions.act_window">
        <field name="name">Prompt History</field>
        <field name="res_model">marin.ai.prompt</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No prompts have been processed yet
            </p>
            <p>
                This view shows the history of all AI prompts and their responses.
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_marin_ai_templates" name="Templates" parent="marin_ai.menu_marin_ai_root" action="action_marin_ai_prompt_template" sequence="30"/>
    <menuitem id="menu_marin_ai_history" name="Prompt History" parent="marin_ai.menu_marin_ai_root" action="action_marin_ai_prompt" sequence="40"/>
</odoo>