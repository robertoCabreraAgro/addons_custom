<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- AI Agent Model List View -->
    <record id="view_marin_ai_agent_model_list" model="ir.ui.view">
        <field name="name">marin.ai.agent.model.list</field>
        <field name="model">marin.ai.agent.model</field>
        <field name="arch" type="xml">
            <list string="AI Models">
                <field name="display_name"/>
                <field name="provider"/>
                <field name="temperature"/>
                <field name="max_tokens"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- AI Agent Model Form View -->
    <record id="view_marin_ai_agent_model_form" model="ir.ui.view">
        <field name="name">marin.ai.agent.model.form</field>
        <field name="model">marin.ai.agent.model</field>
        <field name="arch" type="xml">
            <form string="AI Model">
                <header>
                    <field name="active" widget="boolean_button" 
                           options="{'terminology': {'string_true': 'Active', 'string_false': 'Archived'}}"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <div class="o_row">
                            <field name="provider" widget="badge" 
                                   decoration-info="provider == 'google'"
                                   decoration-success="provider == 'openai'"
                                   decoration-warning="provider == 'anthropic'"/>
                        </div>
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g., gemini-1.5-flash, gpt-4, claude-3"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Basic Configuration">
                            <field name="provider"/>
                        </group>
                        <group string="Model Parameters">
                            <field name="temperature" widget="float" options="{'digits': [1, 2]}" 
                                   help="Controls randomness: 0.0 = deterministic, 1.0 = very creative"/>
                            <field name="max_tokens" help="Maximum tokens in AI response (leave empty for model default)"/>
                        </group>
                    </group>
                    <group string="API Configuration">
                        <group string="Environment Variable">
                            <field name="api_key_env_var" placeholder="e.g., GEMINI_API_KEY, OPENAI_API_KEY" 
                                   help="Environment variable name containing the API key"/>
                        </group>
                        <group string="Direct Configuration" groups="base.group_system">
                            <field name="api_key_encrypted" password="True" 
                                   help="Encrypted API key stored in database (overrides environment variable)"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" 
                               placeholder="Describe the model capabilities, use cases, and any special features...&#10;&#10;Example:&#10;Google's Gemini 1.5 Flash model optimized for fast responses and multilingual support. Good for general conversations and basic reasoning tasks."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- AI Agent Model Search View -->
    <record id="view_marin_ai_agent_model_search" model="ir.ui.view">
        <field name="name">marin.ai.agent.model.search</field>
        <field name="model">marin.ai.agent.model</field>
        <field name="arch" type="xml">
            <search string="Search AI Models">
                <field name="name"/>
                <field name="provider"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Google" name="google" domain="[('provider', '=', 'google')]"/>
                <filter string="OpenAI" name="openai" domain="[('provider', '=', 'openai')]"/>
                <filter string="Anthropic" name="anthropic" domain="[('provider', '=', 'anthropic')]"/>
                <group expand="0" string="Group By">
                    <filter string="Provider" name="group_provider" context="{'group_by': 'provider'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- AI Agent Model Action -->
    <record id="action_marin_ai_agent_model" model="ir.actions.act_window">
        <field name="name">AI Models</field>
        <field name="res_model">marin.ai.agent.model</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_marin_ai_agent_model_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure your AI Models
            </p>
            <p>
                Define the AI models available for your agents.
                Configure provider settings, API keys, and model parameters.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_marin_ai_models" name="AI Models" parent="marin_ai.menu_marin_ai_root" action="action_marin_ai_agent_model" sequence="20"/>
</odoo>