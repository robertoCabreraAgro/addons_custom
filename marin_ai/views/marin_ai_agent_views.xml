<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Test Agent Action -->
    <record id="action_test_agent" model="ir.actions.act_window">
        <field name="name">Test AI Agent</field>
        <field name="res_model">marin.ai.prompt</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_agent_id': active_id, 'default_prompt': 'Test prompt for agent'}</field>
    </record>

    <!-- AI Agent List View -->
    <record id="view_marin_ai_agent_list" model="ir.ui.view">
        <field name="name">marin.ai.agent.list</field>
        <field name="model">marin.ai.agent</field>
        <field name="arch" type="xml">
            <list string="AI Agents" multi_edit="1" sample="1">
                <field name="sequence" widget="handle"/>
                <field name="name" string="Agent Name"/>
                <field name="intent" widget="badge" 
                       decoration-success="intent == 'orchestrator'"
                       decoration-info="intent == 'chat'"
                       decoration-warning="intent in ['inventory', 'sales']"
                       decoration-muted="intent == 'custom'"/>
                <field name="agent_model_id" string="AI Model" optional="show"/>
                <field name="max_query_limit" optional="hide" groups="marin_ai.group_marin_ai_admin"/>
                <field name="queries_per_minute" optional="hide" groups="marin_ai.group_marin_ai_admin"/>
                <field name="security_violations_count" optional="hide" 
                       decoration-danger="security_violations_count > 0" 
                       groups="marin_ai.group_marin_ai_admin"/>
                <field name="last_security_check" optional="hide" groups="marin_ai.group_marin_ai_admin" 
                       widget="datetime"/>
                <field name="active" string="Status" widget="boolean_toggle" 
                       decoration-success="active == True"
                       decoration-danger="active == False"/>
                <button name="%(action_test_agent)d" 
                        string="Test" 
                        type="action" 
                        icon="fa-play-circle" 
                        class="btn-link"
                        invisible="not active"
                        context="{'default_agent_id': id}"/>
            </list>
        </field>
    </record>

    <!-- AI Agent Kanban View -->
    <record id="view_marin_ai_agent_kanban" model="ir.ui.view">
        <field name="name">marin.ai.agent.kanban</field>
        <field name="model">marin.ai.agent</field>
        <field name="arch" type="xml">
            <kanban sample="1" quick_create="false">
                <field name="id"/>
                <field name="name"/>
                <field name="intent"/>
                <field name="active"/>
                <field name="agent_model_id"/>
                <field name="sequence"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <i class="fa fa-robot fa-2x" title="AI Agent" 
                                   t-attf-style="color: #{intent == 'orchestrator' and '#28a745' or intent == 'chat' and '#17a2b8' or intent in ['inventory', 'sales'] and '#ffc107' or '#6c757d'}"/>
                            </div>
                            <div class="oe_kanban_details">
                                <div class="o_kanban_record_top mb8">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <div class="o_kanban_manage_button_section">
                                        <a class="o_kanban_manage_toggle_button" href="#">
                                            <i class="fa fa-ellipsis-v" title="Manage"/>
                                        </a>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <span class="badge badge-pill" 
                                          t-attf-class="#{intent == 'orchestrator' and 'badge-success' or intent == 'chat' and 'badge-info' or intent in ['inventory', 'sales'] and 'badge-warning' or 'badge-secondary'}">
                                        <field name="intent"/>
                                    </span>
                                    <div class="mt4">
                                        <i class="fa fa-cog" title="Configuration"/> <field name="agent_model_id"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <span class="badge" t-if="!active" style="background-color: #dc3545;">Inactive</span>
                                        <span class="badge" t-if="active" style="background-color: #28a745;">Active</span>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <button name="%(action_test_agent)d" 
                                                type="action" 
                                                class="btn btn-primary btn-sm" 
                                                t-if="active"
                                                title="Test Agent">
                                            <i class="fa fa-play"/>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_manage_button_section" dropdown-toggle="dropdown">
                                <a class="o_kanban_manage_toggle_button" href="#">
                                    <i class="fa fa-ellipsis-v" title="Menu"/>
                                </a>
                                <div class="dropdown-menu" role="menu">
                                    <a t-if="widget.editable" role="menuitem" type="edit" class="dropdown-item">Edit</a>
                                    <a t-if="widget.deletable" role="menuitem" type="delete" class="dropdown-item">Delete</a>
                                    <a role="menuitem" name="toggle_active" type="object" class="dropdown-item">
                                        <t t-if="active">Archive</t>
                                        <t t-else="">Restore</t>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- AI Agent Form View -->
    <record id="view_marin_ai_agent_form" model="ir.ui.view">
        <field name="name">marin.ai.agent.form</field>
        <field name="model">marin.ai.agent</field>
        <field name="arch" type="xml">
            <form string="AI Agent">
                <header>
                    <button name="%(action_test_agent)d" 
                            string="Test Agent" 
                            type="action" 
                            class="btn-primary"
                            invisible="not active"/>
                    <field name="active" widget="boolean_button" 
                           options="{'terminology': {'string_true': 'Active', 'string_false': 'Inactive'}}"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_prompts" icon="fa-comments-o">
                            <field string="Prompts" name="prompt_ids" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <div class="o_row">
                            <field name="intent" widget="badge" 
                                   decoration-success="intent == 'orchestrator'"
                                   decoration-info="intent == 'chat'"
                                   decoration-warning="intent in ['inventory', 'sales']"
                                   decoration-muted="intent == 'custom'"/>
                        </div>
                        <label for="name" string="Agent Name"/>
                        <h1>
                            <field name="name" placeholder="e.g., Sales Assistant, Inventory Helper"/>
                        </h1>
                    </div>
                    <group>
                        <group name="main_config" string="Main Configuration">
                            <field name="intent" widget="selection"/>
                            <field name="sequence" widget="integer"/>
                            <field name="agent_model_id" 
                                   options="{'no_create': True, 'no_open': True}"
                                   widget="many2one"/>
                        </group>
                        <group name="advanced_config" string="Advanced Settings">
                        </group>
                    </group>
                    <notebook>
                        <page string="Configuration" name="configuration">
                            <group>
                                <label for="context" string="Agent Prompt Template"/>
                                <field name="context" 
                                       widget="ace" 
                                       options="{'mode': 'markdown', 'theme': 'github', 'fontSize': 14, 'showPrintMargin': false, 'wrap': true}"
                                       placeholder="Enter the agent prompt template with placeholders like {input}, {table_info}, {user_input}, {history}, etc.&#10;&#10;Example:&#10;You are a helpful AI assistant for {intent} queries.&#10;Use the following context: {table_info}&#10;&#10;User question: {input}&#10;Please provide a clear and accurate response."/>
                            </group>
                        </page>
                        <page string="Security Settings" name="security" groups="marin_ai.group_marin_ai_admin">
                            <group>
                                <group string="Query Limits">
                                    <field name="max_query_limit" 
                                           help="Maximum number of records this agent can return in a single query"/>
                                    <field name="queries_per_minute" 
                                           help="Rate limit for queries per minute per user"/>
                                </group>
                                <group string="Security Monitoring">
                                    <field name="last_security_check" readonly="1" widget="datetime"/>
                                    <field name="security_violations_count" readonly="1" 
                                           widget="integer" 
                                           decoration-danger="security_violations_count > 0"/>
                                </group>
                            </group>
                            <div class="alert alert-warning" role="alert" invisible="security_violations_count == 0">
                                <h6><i class="fa fa-exclamation-triangle"/> Security Notice</h6>
                                <p class="mb-0">
                                    This agent has recorded <strong><field name="security_violations_count" readonly="1"/></strong> security violations. 
                                    Review the system logs for detailed information.
                                </p>
                            </div>
                            <div class="alert alert-info" role="alert">
                                <h6><i class="fa fa-info-circle"/> Security Features</h6>
                                <ul class="mb-0">
                                    <li><strong>SQL Injection Protection:</strong> Advanced pattern detection and validation</li>
                                    <li><strong>Rate Limiting:</strong> Per-user query limits to prevent abuse</li>
                                    <li><strong>Table Access Control:</strong> Restricted to authorized models only</li>
                                    <li><strong>Result Limits:</strong> Automatic LIMIT clauses on queries</li>
                                </ul>
                            </div>
                        </page>
                        <page string="Models Access" name="models_access" invisible="intent in ['chat', 'orchestrator']">
                            <field name="model_ids">
                                <list string="Accessible Models" editable="bottom">
                                    <field name="name" string="Display Name"/>
                                    <field name="model" string="Technical Name"/>
                                    <field name="info" string="Description" optional="show"/>
                                </list>
                            </field>
                            <div class="o_form_field_empty" invisible="model_ids">
                                <p class="text-muted">
                                    <i class="fa fa-info-circle"/> 
                                    No models configured. Add models that this agent can access to query data.
                                </p>
                            </div>
                        </page>
                        <page string="Prompts History" name="prompts_history">
                            <field name="prompt_ids" readonly="1">
                                <list string="Recent Prompts" limit="50" default_order="create_date desc">
                                    <field name="name" string="Reference"/>
                                    <field name="prompt" string="User Input" widget="text" optional="show"/>
                                    <field name="response" string="AI Response" widget="text" optional="hide"/>
                                    <field name="user" string="User"/>
                                    <field name="create_date" string="Date" widget="datetime"/>
                                </list>
                            </field>
                            <div class="o_form_field_empty" invisible="prompt_ids">
                                <p class="text-muted">
                                    <i class="fa fa-comments-o"/> 
                                    No prompts processed yet. Once users interact with this agent, their prompts will appear here.
                                </p>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- AI Agent Search View -->
    <record id="view_marin_ai_agent_search" model="ir.ui.view">
        <field name="name">marin.ai.agent.search</field>
        <field name="model">marin.ai.agent</field>
        <field name="arch" type="xml">
            <search string="Search AI Agents">
                <field name="name" string="Agent Name" 
                       filter_domain="['|', ('name', 'ilike', self), ('context', 'ilike', self)]"/>
                <field name="intent" string="Intent"/>
                <field name="agent_model_id" string="AI Model"/>
                <field name="context" string="Configuration" invisible="1"/>
                
                <!-- Status Filters -->
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                
                <!-- Intent Filters -->
                <filter string="Orchestrator" name="orchestrator" domain="[('intent', '=', 'orchestrator')]"/>
                <filter string="Chat" name="chat" domain="[('intent', '=', 'chat')]"/>
                <filter string="Inventory" name="inventory" domain="[('intent', '=', 'inventory')]"/>
                <filter string="Sales" name="sales" domain="[('intent', '=', 'sales')]"/>
                <filter string="Custom" name="custom" domain="[('intent', '=', 'custom')]"/>
                <separator/>
                
                <!-- Advanced Filters -->
                <filter string="SQL Enabled" name="sql_enabled" 
                        domain="[('intent', 'in', ['inventory', 'sales', 'custom'])]"
                        help="Agents that can execute SQL queries"/>
                <filter string="Has Models" name="has_models" 
                        domain="[('model_ids', '!=', False)]"
                        help="Agents with configured data models"/>
                <filter string="Has Prompts" name="has_prompts" 
                        domain="[('prompt_ids', '!=', False)]"
                        help="Agents that have processed prompts"/>
                
                <!-- My Filters -->
                <separator/>
                
                <!-- Group By Options -->
                <group expand="0" string="Group By">
                    <filter string="Intent" name="group_intent" context="{'group_by': 'intent'}"/>
                    <filter string="AI Model" name="group_model" context="{'group_by': 'agent_model_id'}"/>
                    <filter string="Status" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- AI Agent Action -->
    <record id="action_marin_ai_agent" model="ir.actions.act_window">
        <field name="name">AI Agents</field>
        <field name="res_model">marin.ai.agent</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_marin_ai_agent_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first AI Agent
            </p>
            <p>
                AI Agents help process user queries using different AI models and contexts.<br/>
                Configure agents for inventory, sales, chat, or create custom agents.
            </p>
            <p>
                <strong>Quick Start:</strong>
            </p>
            <ul>
                <li>Create an <strong>Orchestrator</strong> agent to classify user intents</li>
                <li>Add a <strong>Chat</strong> agent for general conversations</li>
                <li>Configure <strong>Inventory</strong> and <strong>Sales</strong> agents for specific queries</li>
            </ul>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_marin_ai_root" name="AI Assistant" sequence="100" web_icon="marin_ai,static/description/icon.png"/>
    <menuitem id="menu_marin_ai_agents" name="Agents" parent="menu_marin_ai_root" action="action_marin_ai_agent" sequence="10"/>
</odoo>
