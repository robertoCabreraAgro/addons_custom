<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Test Agent Form View -->
    <record id="view_marin_ai_prompt_test_form" model="ir.ui.view">
        <field name="name">marin.ai.prompt.test.form</field>
        <field name="model">marin.ai.prompt</field>
        <field name="arch" type="xml">
            <form string="Test AI Agent">
                <sheet>
                    <div class="oe_title">
                        <h1>Test AI Agent</h1>
                    </div>
                    <group>
                        <group>
                            <field name="agent_id" string="Agent" readonly="1" 
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="user" string="User" readonly="1"/>
                        </group>
                        <group>
                            <field name="create_date" string="Created on" readonly="1" invisible="1"/>
                            <field name="prompt_template_id" string="Prompt Template" readonly="1" invisible="1"/>
                        </group>
                    </group>
                    <group string="Test Prompt">
                        <field name="prompt" string="Enter your test question or prompt" 
                               widget="text" 
                               placeholder="Type your question here... e.g., 'Show me all products in stock'" 
                               nolabel="1"
                               required="1"
                               colspan="2"/>
                    </group>
                    <group string="AI Response" invisible="not response">
                        <field name="response" string="AI Response" 
                               widget="text" 
                               readonly="1" 
                               nolabel="1"
                               colspan="2"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Test Agent" name="test_agent_prompt" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Test Agent Action -->
    <record id="action_test_agent" model="ir.actions.act_window">
        <field name="name">Test AI Agent</field>
        <field name="res_model">marin.ai.prompt</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_marin_ai_prompt_test_form"/>
        <field name="target">new</field>
        <field name="context">{'default_agent_id': active_id, 'default_user': uid, 'create': True}</field>
    </record>

    <!-- Prompt History List View -->
    <record id="view_marin_ai_prompt_list" model="ir.ui.view">
        <field name="name">marin.ai.prompt.list</field>
        <field name="model">marin.ai.prompt</field>
        <field name="arch" type="xml">
            <list string="Prompt History" create="false">
                <field name="name"/>
                <field name="agent_id"/>
                <field name="user"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Prompt History Form View -->
    <record id="view_marin_ai_prompt_form" model="ir.ui.view">
        <field name="name">marin.ai.prompt.form</field>
        <field name="model">marin.ai.prompt</field>
        <field name="arch" type="xml">
            <form string="Prompt History" create="false" edit="false">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="agent_id" readonly="1"/>
                            <field name="user" readonly="1"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="prompt_template_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Prompt">
                        <field name="prompt" widget="ace" options="{'type': 'text'}" readonly="1" nolabel="1" colspan="2"/>
                    </group>
                    <group string="Response">
                        <field name="response" widget="ace" options="{'type': 'text'}" readonly="1" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Prompt History Action -->
    <record id="action_marin_ai_prompt" model="ir.actions.act_window">
        <field name="name">Prompt History</field>
        <field name="res_model">marin.ai.prompt</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No prompts have been processed yet
            </p>
            <p>
                This view shows the history of all AI prompts and their responses.
            </p>
        </field>
    </record>

</odoo>
