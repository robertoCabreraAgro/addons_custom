<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Default Sales Order Approval Category -->
        <record id="approval_category_sales_order" model="approval.category">
            <field name="name">Sales Order Approval</field>
            <field name="sequence">10</field>
            <field name="active" eval="True"/>
            <field name="automated_sequence" eval="True"/>
            <field name="sequence_code">SO-APPR-</field>
            <field name="description">Approval category for all sales orders</field>

            <!-- CORE REQUIRED FIELDS - Features we need for sales orders -->
            <field name="has_amount">required</field>
            <field name="has_partner">required</field>
            <field name="has_reference">required</field>

            <!-- ALL OTHER REQUIRED FIELDS - Set to "no" (not needed for sales orders) -->
            <field name="has_date">no</field>
            <field name="has_date_deadline">no</field>
            <field name="has_date_planned">no</field>
            <field name="has_date_range">no</field>
            <field name="has_quantity">no</field>
            <field name="has_location">no</field>
            <field name="has_product">no</field>
            <field name="has_payment_method">no</field>
            <field name="has_document">optional</field>

            <!-- EXTENDED REQUIRED FIELDS from inheriting modules (conditional) -->
            <!-- These fields might not exist in all installations, so we use try/except in code -->
            <!-- <field name="has_bsl">no</field> -->  <!-- from telegram_bot module -->
            <!-- <field name="has_operation_type">no</field> -->  <!-- from telegram_bot module -->
            <!-- <field name="has_journal">no</field> -->  <!-- from marin module -->
            <!-- <field name="has_vehicle">no</field> -->  <!-- from marin module -->
            <!-- <field name="has_odometer">no</field> -->  <!-- from marin module -->

            <!-- APPROVAL CONFIGURATION -->
            <field name="approval_minimum">1</field>
            <field name="manager_approval">required</field>
            <field name="approve_sequentially" eval="False"/>
        </record>

        <!-- Default approvers for Sales Order Approval Category -->
        <!-- Sales Manager Group as default approver -->
        <record id="approval_category_approver_sales_manager" model="approval.category.approver">
            <field name="category_id" ref="approval_category_sales_order"/>
            <field name="user_id" ref="base.user_admin"/>  <!-- Fallback to admin, should be replaced by actual sales managers -->
            <field name="required" eval="True"/>
            <field name="sequence">10</field>
        </record>

        <!-- Create sequence for approval requests -->
        <record id="sequence_approval_request" model="ir.sequence">
            <field name="name">Approval Request</field>
            <field name="code">approval.request</field>
            <field name="prefix">SO-APPR-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>