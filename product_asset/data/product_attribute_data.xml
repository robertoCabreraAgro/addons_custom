<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_attribute_fuel_type" model="product.attribute">
        <field name="name">Fuel type</field>
        <field name="sequence">10</field>
        <field name="create_variant">no_variant</field>
