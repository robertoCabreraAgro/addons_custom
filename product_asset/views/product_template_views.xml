<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Product Template Search Views -->
    <record id="product_template_search_view_asset" model="ir.ui.view">
        <field name="name">product.template.search.asset</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view" />
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="asset_type" />
            </field>
            <filter name="filter_to_sell" position="after">
                <separator />
                <filter name="filter_vehicles" string="Vehicles"
                    domain="[('asset_type', '=', 'vehicle')]" />
                <filter name="filter_equipment" string="Equipment"
                    domain="[('asset_type', '=', 'equipment')]" />
                <filter name="filter_machinery" string="Machinery"
                    domain="[('asset_type', '=', 'machinery')]" />
                <filter name="filter_property" string="Property"
                    domain="[('asset_type', '=', 'property')]" />
                <separator />
            </filter>
            <group position="inside">
                <filter name="group_asset_type" string="Asset Type"
                    context="{'group_by': 'asset_type'}" />
            </group>
        </field>
    </record>

    <!-- Product Template List Views -->
    <record id="product_template_tree_view_asset" model="ir.ui.view">
        <field name="name">product.template.tree.asset</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view" />
        <field name="arch" type="xml">
            <field name="categ_id" position="after">
                <field name="asset_type" optional="show" />
            </field>
        </field>
    </record>

    <record id="product_template_tree_view_vehicle" model="ir.ui.view">
        <field name="name">product.template.tree.asset</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <list string="Product" multi_edit="1" sample="1">
                <field name="name" />
                <field name="manufacturer_id" optional="show" />
                <field name="categ_id" />
                <field name="count_lot_ids" string="Vehicles"/>
            </list>
        </field>
    </record>

    <!-- Product Template Form Views -->
    <record id="product_template_form_view_asset" model="ir.ui.view">
        <field name="name">product.template.form.asset</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="asset_info" string="Asset Information" invisible="asset_type == 'product'">
                    <group>
                        <group string="General Asset Info">
                            <field name="asset_type" />
                        </group>
                    </group>

                    <!-- Power Information -->
                    <group name="power_group" string="Power Specifications">
                        <group>
                            <field name="power" />
                        </group>
                    </group>

                    <!-- Vehicle Specific Information -->
                    <group name="vehicle_group" string="Vehicle Specifications"
                        invisible="asset_type != 'vehicle'">
                        <group>
                            <field name="doors" />
                            <field name="seats" />
                        </group>
                        <group>
                            <field name="co2" />
                            <field name="range" />
                        </group>
                    </group>

                    <!-- Fuel Efficiency -->
                    <group name="fuel_group" string="Fuel Efficiency"
                        invisible="asset_type != 'vehicle'">
                        <group>
                            <field name="fuel_efficiency_theoretical" />
                            <field name="fuel_efficiency_min" />
                            <field name="fuel_efficiency_max" />
                        </group>
                        <group>
                            <field name="fuel_tank_capacity" />
                        </group>
                    </group>

                    <!-- Capacity Information -->
                    <group string="Capacity Specifications" name="capacity_group">
                        <group>
                            <field name="weight_capacity" />
                            <field name="weight_capacity_uom_name" readonly="1" />
                        </group>
                        <group>
                            <field name="volume_capacity" />
                            <field name="volume_capacity_uom_name" readonly="1" />
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Asset-specific Action -->
    <record id="action_product_template_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('asset_type', '!=', 'product')]</field>
        <field name="context">{}</field>
    </record>

    <!-- Vehicle-specific Action -->
    <record id="action_product_template_vehicle" model="ir.actions.act_window">
        <field name="name">Models</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('asset_type', '=', 'vehicle')]</field>
        <field name="context">{'default_asset_type': 'vehicle'}</field>
        <field name="view_ids"
            eval="[
                (5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('product_template_tree_view_vehicle')}),
                (0, 0, {'view_mode': 'form'}),
            ]" />
    </record>

    <!-- Equipment-specific Action -->
    <record id="action_product_template_equipment" model="ir.actions.act_window">
        <field name="name">Equipment</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('asset_type', '=', 'equipment')]</field>
        <field name="context">{}</field>
    </record>

</odoo>