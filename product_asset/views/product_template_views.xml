<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Product Template Search View -->
    <record id="product_template_search_view_asset" model="ir.ui.view">
        <field name="name">product.template.search.asset</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view" />
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="asset_type" />
                <field name="power" />
                <field name="doors" />
                <field name="seats" />
            </field>
            <filter name="filter_to_sell" position="after">
                <separator />
                <filter string="Vehicles" name="filter_vehicles"
                    domain="[('asset_type', '=', 'vehicle')]" />
                <filter string="Equipment" name="filter_equipment"
                    domain="[('asset_type', '=', 'equipment')]" />
                <filter string="Machinery" name="filter_machinery"
                    domain="[('asset_type', '=', 'machinery')]" />
                <filter string="Property" name="filter_property"
                    domain="[('asset_type', '=', 'property')]" />
                <separator />
                <filter string="High Power (>100)" name="filter_high_power"
                    domain="[('power', '>', 100)]" />
            </filter>
            <group position="inside">
                <filter string="Asset Type" name="group_asset_type"
                    context="{'group_by': 'asset_type'}" />
            </group>
        </field>
    </record>

    <!-- Product Template Tree View -->
    <record id="product_template_tree_view_asset" model="ir.ui.view">
        <field name="name">product.template.tree.asset</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view" />
        <field name="arch" type="xml">
            <field name="categ_id" position="after">
                <field name="asset_type" optional="show" />
                <field name="power" optional="hide" />
            </field>
        </field>
    </record>

    <!-- Product Template Form View -->
    <record id="product_template_form_view_asset" model="ir.ui.view">
        <field name="name">product.template.form.asset</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="asset_info" string="Asset Information" invisible="asset_type == 'product'">
                    <group>
                        <group string="General Asset Info">
                            <field name="asset_type" />
                        </group>
                    </group>

                    <!-- Power Information -->
                    <group name="power_group" string="Power Specifications">
                        <group>
                            <field name="power" />
                        </group>
                    </group>

                    <!-- Vehicle Specific Information -->
                    <group name="vehicle_group" string="Vehicle Specifications"
                        invisible="asset_type != 'vehicle'">
                        <group>
                            <field name="doors" />
                            <field name="seats" />
                        </group>
                        <group>
                            <field name="co2" />
                            <field name="range" />
                        </group>
                    </group>

                    <!-- Fuel Efficiency -->
                    <group name="fuel_group" string="Fuel Efficiency"
                        invisible="asset_type != 'vehicle'">
                        <group>
                            <field name="fuel_efficiency_theoretical" />
                            <field name="fuel_efficiency_min" />
                            <field name="fuel_efficiency_max" />
                        </group>
                        <group>
                            <field name="fuel_tank_capacity" />
                        </group>
                    </group>

                    <!-- Capacity Information -->
                    <group string="Capacity Specifications" name="capacity_group">
                        <group>
                            <field name="weight_capacity" />
                            <field name="weight_capacity_uom_name" readonly="1" />
                        </group>
                        <group>
                            <field name="volume_capacity" />
                            <field name="volume_capacity_uom_name" readonly="1" />
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Asset-specific Action and Menu Items -->
    <record id="product_template_action_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('asset_type', '!=', 'product')]</field>
        <field name="context">{
            'search_default_filter_vehicles': 1,
            'default_detailed_type': 'product'
            }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first asset!
            </p>
            <p>
                Track and manage your company assets including vehicles, equipment, machinery, and
                property.
            </p>
        </field>
    </record>

    <!-- Vehicle-specific Action -->
    <record id="product_template_action_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('asset_type', '=', 'vehicle')]</field>
        <field name="context">{
            'default_asset_type': 'vehicle',
            'default_detailed_type': 'product'
            }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first vehicle!
            </p>
            <p>
                Track your company vehicles with detailed specifications including power, fuel
                efficiency, and capacity.
            </p>
        </field>
    </record>

    <!-- Equipment-specific Action -->
    <record id="product_template_action_equipment" model="ir.actions.act_window">
        <field name="name">Equipment</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('asset_type', '=', 'equipment')]</field>
        <field name="context">{
            'default_asset_type': 'equipment',
            'default_detailed_type': 'product'
            }</field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_asset_root"
        name="Assets"
        sequence="85" />

    <menuitem id="menu_asset_management"
        name="Asset Management"
        parent="menu_asset_root"
        sequence="10" />

    <menuitem id="menu_all_assets"
        name="All Assets"
        parent="menu_asset_management"
        action="product_template_action_asset"
        sequence="10" />

    <menuitem id="menu_vehicles"
        name="Vehicles"
        parent="menu_asset_management"
        action="product_template_action_vehicle"
        sequence="20" />

    <menuitem id="menu_equipment"
        name="Equipment"
        parent="menu_asset_management"
        action="product_template_action_equipment"
        sequence="30" />

</odoo>