<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search View -->
    <record id="search_product_lot_filter" model="ir.ui.view">
        <field name="name">stock.lot.fleet.search</field>
        <field name="model">stock.lot</field>
        <field name="arch" type="xml">
            <search string="Fleet">
                <field name="name" string="Vehicle"
                    filter_domain="['|', '|', ('name', 'ilike', self), ('ref', 'ilike', self), ('license_plate', 'ilike', self)]" />
                <field name="product_id" string="Model"/>
                <field name="license_plate" />
                <field name="operator_id" />
                <field name="asset_manager_id" />
                <field name="vin_sn" />
                <field name="location" />   
                <separator />
                <filter name="has_operator" string="Has Operator"
                    domain="[('operator_id', '!=', False)]" />
                <filter name="no_operator" string="No Operator"
                    domain="[('operator_id', '=', False)]" />
                <separator />
                <filter name="service_overdue" string="Service Overdue"
                    domain="[('service_activity', '=', 'overdue')]" />
                <filter name="service_today" string="Service Today"
                    domain="[('service_activity', '=', 'today')]" />
                <separator />
                <filter name="contract_due_soon" string="Contract Due Soon"
                    domain="[('contract_renewal_due_soon', '=', True)]" />
                <filter name="contract_overdue" string="Contract Overdue"
                    domain="[('contract_renewal_overdue', '=', True)]" />
                <filter name="active_contracts" string="Active Contracts"
                    domain="[('contract_state', '=', 'open')]" />
                <filter name="expired_contracts" string="Expired Contracts"
                    domain="[('contract_state', '=', 'expired')]" />
                <group>
                    <filter name="group_by_product" string="Model"
                        domain="[]"
                        context="{'group_by': 'product_id'}" />
                    <filter name="group_by_operator" string="Operator"
                        domain="[]"
                        context="{'group_by': 'operator_id'}" />
                    <filter name="group_by_manager" string="Manager"
                        domain="[]"
                        context="{'group_by': 'asset_manager_id'}" />
                    <filter name="group_by_model_year" string="Model Year"
                        domain="[]"
                        context="{'group_by': 'model_year'}" />
                    <filter name="group_by_contract_state" string="Contract State"
                        domain="[]"
                        context="{'group_by': 'contract_state'}" />
                    <filter name="group_by_service_activity" string="Service Activity"
                        domain="[]"
                        context="{'group_by': 'service_activity'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- List View -->
    <record id="view_list_stock_lot" model="ir.ui.view">
        <field name="name">stock.lot.fleet.tree</field>
        <field name="model">stock.lot</field>
        <field name="arch" type="xml">
            <list string="Fleet" multi_edit="1">
                <field name="asset_type" column_invisible="1" />
                <field name="name" decoration-bf="1" />
                <field name="license_plate" optional="show" />
                <field name="product_id" string="Model" readonly="1" optional="show"/>
                <field name="operator_id" optional="show" />
                <field name="future_operator_id" optional="show" />
                <field name="asset_manager_id" optional="hide" />
                <field name="odometer" optional="show" />
                <field name="model_year" optional="hide" />
                <field name="vin_sn" optional="hide" />
                <field name="engine_sn" optional="hide" />
                <field name="date_acquisition" optional="hide" />
                <field name="date_write_off" optional="hide" />
                <field name="value_original" optional="hide" />
                <field name="value_residual" optional="hide" />
                <field name="fuel_card_balance_to_reload" string="To Reload (FC)"
                    sum="Total to reload" optional="show" />
                <field name="service_activity" widget="badge"
                    decoration-danger="service_activity == 'overdue'"
                    decoration-warning="service_activity == 'today'"
                    optional="show" />
                <field name="contract_state" widget="badge" optional="show" />
                <field name="activity_ids" widget="list_activity" optional="show" />
                <field name="company_id" optional="hide" groups="base.group_multi_company" />
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_kanban_stock_lot" model="ir.ui.view">
        <field name="name">stock.lot.kanban</field>
        <field name="model">stock.lot</field>
        <field name="arch" type="xml">
            <kanban group_create="false" group_delete="false">
                <templates>
                    <t t-name="card">
                        <field name="name" class="fw-bolder fs-5" />
                        <field name="product_id" class="small" />
                        <field name="activity_ids" widget="kanban_activity" />
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_production_lot_form" model="ir.ui.view">
        <field name="name">stock.lot.fleet.form</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="accept_operator_change"
                    string="Accept Driver Change"
                    type="object"
                    class="btn-primary"
                    invisible="not future_operator_id" />
                <field name="contract_state" widget="statusbar"
                    statusbar_visible="futur,open,expired,closed"
                    invisible="asset_type not in ('equipment', 'machinery', 'vehicle')" />
            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_logs_assignation"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-users"
                    invisible="asset_type == 'product'">
                    <field name="count_assignment" string="Assignments" widget="statbutton" />
                </button>
                <button name="action_view_logs_cost"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-wrench"
                    invisible="asset_type == 'product'">
                    <field name="count_service" string="Services" widget="statbutton" />
                </button>
                <button name="action_view_logs_contract"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-file-text-o"
                    invisible="asset_type == 'product'">
                    <field name="count_contract" string="Contracts" widget="statbutton" />
                </button>
            </xpath>

            <xpath expr="//notebook/page[@name='other_info']" position="before">
                <page name="personnel" string="Personnel" invisible="asset_type not in ('equipment', 'machinery', 'vehicle')">
                    <group>
                        <group>
                            <field name="operator_id"
                                options="{'no_create': True, 'no_create_edit': True}" />
                            <field name="future_operator_id"
                                options="{'no_create': True, 'no_create_edit': True}" />
                        </group>
                        <group>
                            <field name="asset_manager_id"
                                options="{'no_create': True, 'no_create_edit': True}" />
                        </group>
                    </group>
                </page>
                <page name="model" string="Model" invisible="asset_type not in ('equipment', 'machinery', 'vehicle')">
                    <group name="model_group">
                        <group name="left_model_group">
                            <field name="license_plate" />
                            <field name="vin_sn" />
                            <field name="model_year" />
                            <field name="brand_new" />
                            <field name="trailer_hook" />
                            <field name="location" />
                        </group>
                        <group name="right_model_group">
                            <field name="engine_sn" />
                            <field name="odometer" />
                            <field name="service_activity" />
                        </group>
                    </group>
                </page>
                <page name="contract_information" string="Contract" invisible="asset_type not in ('equipment', 'machinery', 'vehicle')">
                    <group>
                        <group>
                            <field name="contract_renewal_due_soon" />
                        </group>
                        <group>
                            <field name="contract_renewal_overdue" />
                        </group>
                    </group>
                </page>
                <page name="financial_information" string="Financial Information" invisible="asset_type not in ('equipment', 'machinery', 'vehicle')">
                    <group name="financial_information">
                        <group>
                            <field name="date_acquisition" />
                            <field name="date_write_off" />
                            <field name="date_first_contract" />
                            <field name="date_next_assignation" />
                        </group>
                        <group>
                            <field name="account_prefix" />
                            <field name="value_original" widget="monetary" />
                            <field name="value_residual" widget="monetary" />
                        </group>
                    </group>
                </page>
                <page name="vouchers" string="Vouchers" invisible="asset_type not in ('equipment', 'machinery', 'vehicle')">
                    <group>
                        <group string="Fuel Card">
                            <field name="fuel_card_id" options="{'no_create': True}" />
                            <field name="fuel_card_name" invisible="True" />
                            <field name="fuel_card_budget" string="Budget" />
                            <field name="fuel_card_balance" string="Current balance" />
                            <field name="fuel_card_balance_to_reload" string="Amount to reload" />
                        </group>
                        <group string="Highway Pass">
                            <field name="highway_pass_id" options="{'no_create': True}" />
                            <field name="highway_pass_name" invisible="True" />
                            <field name="highway_pass_budget" string="Budget" />
                            <field name="highway_pass_balance" string="Current balance" />
                            <field name="highway_pass_balance_to_reload" string="Amount to reload" />
                        </group>
                    </group>
                </page>
                <page name="logs" string="Logs" invisible="asset_type not in ('equipment', 'machinery', 'vehicle')">
                    <field name="log_ids" readonly="1">
                        <list>
                            <field name="date_start" />
                            <field name="date_end" />
                            <field name="operator_id" />
                            <field name="odometer" />
                            <field name="activity_state" optional="show" />
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_stock_lot_fleet" model="ir.actions.act_window">
        <field name="name">Fleet</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="product_asset.search_product_lot_filter" />
        <field name="view_ids"
            eval="[
                (5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('view_list_stock_lot')}),
                (0, 0, {'view_mode': 'form'}),
            ]" />
        <field name="domain">[('asset_type', '=', 'vehicle')]</field>
        <field name="context">{'search_default_available': 1}</field>
    </record>

    <!-- Dashboard Action for Vehicles with Service Due -->
    <record id="action_stock_lot_service_due" model="ir.actions.act_window">
        <field name="name">Vehicles - Service Due</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('service_activity', 'in', ['overdue', 'today'])]</field>
        <field name="context">{
            'search_default_service_overdue': 1,
            'search_default_service_today': 1
            }</field>
    </record>

    <!-- Dashboard Action for Contract Renewals -->
    <record id="action_stock_lot_contract_renewal" model="ir.actions.act_window">
        <field name="name">Vehicles - Contract Renewals</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            '|',
            ('contract_renewal_due_soon', '=', True),
            ('contract_renewal_overdue', '=', True)]</field>
        <field name="context">{
            'search_default_contract_due_soon': 1,
            'search_default_contract_overdue': 1
            }</field>
    </record>

</odoo>