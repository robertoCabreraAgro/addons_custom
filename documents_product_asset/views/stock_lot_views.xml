<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id='view_list_stock_lot' model='ir.ui.view'>
        <field name="name">stock.lot.fleet.tree</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="product_asset.view_list_stock_lot" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='fuel_card_budget']" position="before">
                <field name="fuel_card_id" options="{'no_create': True}" optional="hide" />
            </xpath>
            <xpath expr="//field[@name='highway_pass_budget']" position="before">
                <field name="highway_pass_id" options="{'no_create': True}" optional="hide" />
            </xpath>
        </field>
    </record>

    <record id='view_production_lot_form' model='ir.ui.view'>
        <field name="name">stock.production.lot.form</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="documents_settings_asset" invisible="1" />
                <button
                    name="action_view_attachments"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-file-text-o"
                    invisible="not documents_settings_asset"
                    groups="documents.group_documents_user">
                    <field name="count_document" string="Documents" widget="statinfo" />
                </button>
            </xpath>

            <xpath expr="//field[@name='fuel_card_budget']" position="before">
                <field name="fuel_card_id" options="{'no_create': True}" />
                <field name="fuel_card_name" invisible="True" />
            </xpath>

            <xpath expr="//field[@name='highway_pass_budget']" position="before">
                <field name="highway_pass_id" options="{'no_create': True}" />
                <field name="highway_pass_name" invisible="True" />
            </xpath>
        </field>
    </record>

</odoo>