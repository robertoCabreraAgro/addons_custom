<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ABC Classification Levels -->
    <record id="abc_classification_level_a_seasonal" model="abc.classification.level">
        <field name="name">A</field>
        <field name="percentage">80</field>
        <field name="percentage_products">10</field>
    </record>
    
    <record id="abc_classification_level_b_seasonal" model="abc.classification.level">
        <field name="name">B</field>
        <field name="percentage">15</field>
        <field name="percentage_products">20</field>
    </record>
    
    <record id="abc_classification_level_c_seasonal" model="abc.classification.level">
        <field name="name">C</field>
        <field name="percentage">5</field>
        <field name="percentage_products">70</field>
    </record>

    <!-- ABC Profiles for Warehouses -->
    
    <!-- High central valleys Spring - Summer -->
    <record id="abc_profile_codagem_high_central_spring_summer" model="abc.classification.profile">
        <field name="name">CODAGEM | High central valleys | spring - summer</field>
        <field name="profile_type">sale_stock</field>
        <field name="warehouse_id" ref="warehouse_104"/>
        <field name="interval_type">seasons</field>
        <field name="date_range_ids" eval="[(6,0,[ref('date_range_28'), ref('date_range_32')])]"/>
        <field name="level_ids" eval="[(6,0,[ref('abc_classification_level_a_seasonal'), ref('abc_classification_level_b_seasonal'), ref('abc_classification_level_c_seasonal')])]"/>
    </record>
</odoo>
