msgid ""
"Format pattern for lot naming. Available placeholders:\n"
"%(yy)s: 2-digit year\n"
"%(yyyy)s: 4-digit year\n"
"%(mm)s: 2-digit month\n"
"%(dd)s: 2-digit day\n"
"%(product_code)s: Product code placeholder\n"
"Example: '%(yy)s%(mm)s-%(product_code)s' creates '2502-ABC123'"
