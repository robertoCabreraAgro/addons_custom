<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
        
    <record id="stock_lot_rule_yymm" model="stock.lot.rule">
        <field name="name">YYMM|PRODUCT_ID</field>
        <field name="format_pattern">%(yy)s%(mm)s|%(product_id)s</field>
        <field name="expiration_time">730</field>
        <field name="use_time">730</field>
        <field name="removal_time">730</field>
        <field name="alert_time">730</field>
        <field name="active">True</field>
    </record>

    <record id="stock_lot_rule_yymmdd" model="stock.lot.rule">
        <field name="name">YYMMDD|PRODUCT_ID</field>
        <field name="format_pattern">%(yy)s%(mm)s%(dd)s|%(product_id)s</field>
        <field name="expiration_time">730</field>
        <field name="use_time">730</field>
        <field name="removal_time">730</field>
        <field name="alert_time">730</field>
        <field name="active">True</field>
    </record>

    <record id="stock_lot_rule_yymmdd_vendor" model="stock.lot.rule">
        <field name="name">YYMMDD|PRODUCT_ID - VENDOR_LOT_NUMBER</field>
        <field name="format_pattern">%(yy)s%(mm)s%(dd)s|%(product_id)s - %(ref)s</field>
        <field name="expiration_time">730</field>
        <field name="use_time">730</field>
        <field name="removal_time">730</field>
        <field name="alert_time">730</field>
        <field name="active">True</field>
    </record>

</odoo>
