<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- View discuss.channel form -->
    <record id="view_discuss_channel_form" model="ir.ui.view">
        <field name="name">view.discuss.channel.form</field>
        <field name="model">discuss.channel</field>
        <field name="inherit_id" ref="mail.discuss_channel_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='active']" position="after">
                <field name="is_alert_channel" widget="boolean_toggle" />
            </xpath>
            <xpath expr="//page[@name='privacy']" position="attributes">
                <attribute name="invisible">is_alert_channel</attribute>
            </xpath>
            <xpath expr="//page[@name='extra_info']" position="attributes">
                <attribute name="invisible">is_alert_channel</attribute>
            </xpath>

            <xpath expr="//page[@name='privacy']" position="after">
                <page string="Alert settings" groups="base.group_no_one" invisible="not is_alert_channel">
                    <field name="alert_model_id" invisible="1" />
                    <group>
                        <group>
                            <field name="alert_model_id" string="Model" required="is_alert_channel" />
                            <field
                                name="alert_domain"
                                string="Domain"
                                widget="domain"
                                options="{'foldable': True, 'model': 'alert_model_id'}"
                            />
                        </group>
                        <group>
                            <field name="alert_frequency" string="Frequency" required="is_alert_channel" />
                        </group>
                    </group>
                    <group>
                        <field name="alert_last_execution" readonly="0" />
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
