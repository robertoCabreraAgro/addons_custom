<odoo>
    <record id="mx_edi_to_record_wizard_view_form" model="ir.ui.view">
        <field name="name">documents.mx_edi_to_record_wizard.form</field>
        <field name="model">documents.mx_edi_to_record_wizard</field>
        <field name="arch" type="xml">
            <form string="Create Vendor Bills from XML">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Select a journal to review the document lines. If candidates are found, you can select an existing vendor bill or leave empty to create a new one.
                    </div>
                    <group>
                        <group>
                            <field name="company_id" invisible="1" />
                            <field name="journal_id" required="1" />
                        </group>
                        <group>
                            <div class="text-muted">
                        Total documents: <span class="badge badge-primary"><field name="count_lines" /></span>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Documents" name="document_lines">
                            <field name="line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="document_id" widget="many2one_avatar_document" force_save="1" />
                                    <field name="partner_id" />
                                    <field name="journal_id" column_invisible="1" />
                                    <field name="allowed_move_ids" column_invisible="1" />
                        <field name="action" />
                                    <field
                                        name="move_id"
                                        options="{'no_create': True}"
                                        required="action == 'assign'"
                                        readonly="action != 'assign'"
                                    />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button
                        string="Create &amp; Assign"
                        name="create_records"
                        type="object"
                        class="btn-primary"
                        data-hotkey="q"
                    />
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z" />
                </footer>
            </form>
        </field>
    </record>
</odoo>
