<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
    <record id="ir_cron_automatic_fetch_cfdi_invoices" model="ir.cron">
        <field name="name">Auto Import CFDI SAT</field>
        <field name="model_id" ref="model_l10n_mx_edi_session" />
        <field name="user_id" ref="base.user_root" />
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="state">code</field>
        <field name="code">
model._cron_sync_with_sat()
        </field>
    </record>

    <record id="ir_cron_automatic_sync_sat_status" model="ir.cron">
        <field name="name">Auto Sync SAT status</field>
        <field name="model_id" ref="model_documents_document" />
        <field name="user_id" ref="base.user_root" />
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="state">code</field>
        <field name="code">
model._cron_sync_with_sat()
        </field>
    </record>
</odoo>
