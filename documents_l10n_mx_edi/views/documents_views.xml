<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="x_my_module_documents_view_list_inherit" model="ir.ui.view">
        <field name="name">documents.document.list.inherit.res_name</field>
        <field name="model">documents.document</field>
        <field name="inherit_id" ref="documents.documents_view_list_main"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='res_model']" position="after">
                <field name="show_res_name" string="Related Record" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>