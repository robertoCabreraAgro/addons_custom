<odoo>
    <record id="l10n_mx_edi_session_view_list" model="ir.ui.view">
        <field name="name">l10n_mx_edi.session.view.list</field>
        <field name="model">l10n_mx_edi.session</field>
        <field name="arch" type="xml">
            <list string="MX SAT Sessions">
                <field name="name" />
                <field name="token_expiration" />
                <field name="range_type" />
                <field name="date_from" />
                <field name="date_to" />
                <field name="file_count" />
                <field name="request" />
                <field name="request_status_code" />
                <field
                    name="request_state"
                    widget="badge"
                    decoration-info="request_state=='2'"
                    decoration-success="request_state=='3'"
                    decoration-danger="request_state in ('4', '5', '6')"
                />
                <field name="company_id" />
                <field name="download_type"
                    widget="badge"
                    decoration-info="download_type == 'uuid'"
                    decoration-muted="download_type == 'massive'"/>
                <field name="uuid" optional="hide"/>
                <field name="document_ids" column_invisible="1" />
                <button
                    name="action_request_cfdi"
                    type="object"
                    string="Request Download"
                    class="btn-primary"
                    invisible="request_state != '0'"
                />
                <button
                    name="action_verify_cfdi"
                    type="object"
                    string="Verify Request"
                    class="btn-primary"
                    invisible="request_state != '1'"
                />
                <button
                    name="action_download_cfdi"
                    type="object"
                    string="Download"
                    class="btn-primary"
                    invisible="request_state != '3' or request_status_code == '5008' or document_ids"
                />
            </list>
        </field>
    </record>

    <record id="l10n_mx_edi_session_view_form" model="ir.ui.view">
        <field name="name">l10n_mx_edi.session.view.form</field>
        <field name="model">l10n_mx_edi.session</field>
        <field name="arch" type="xml">
            <form string="MX SAT Session">
                <header>
                    <button
                        name="action_request_cfdi"
                        type="object"
                        string="Request Download"
                        class="btn-primary"
                        invisible="request_state != '0'"
                    />
                    <button
                        name="action_verify_cfdi"
                        type="object"
                        string="Verify Request"
                        class="btn-primary"
                        invisible="request_state != '1'"
                    />
                    <button
                        name="action_download_cfdi"
                        type="object"
                        string="Download"
                        class="btn-primary"
                        invisible="request_state != '3' or request_status_code == '5008' or document_ids"
                    />
                    <field name="request_state" widget="statusbar" statusbar_visible="1,2,3" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="download_type"
                                readonly="request_state != '0'"
                                widget="radio"/>

                            <!-- Date fields - only visible for massive download -->
                            <field name="request_mode"
                                invisible="download_type != 'massive'"
                                readonly="request_state != '0'"/>
                            <field name="range_type"
                                invisible="download_type != 'massive' or request_mode != 'playwright'"
                                readonly="request_state != '0'"
                                required="download_type == 'massive' and request_mode == 'playwright'"/>
                            <field name="date_from"
                                invisible="download_type != 'massive' or request_mode != 'api'"
                                readonly="request_state != '0'"
                                required="download_type == 'massive' and request_mode == 'api'"/>
                            <field name="date_to"
                                invisible="download_type != 'massive'"
                                readonly="request_state != '0'"
                                required="download_type == 'massive'"/>

                            <!-- UUID field - only visible for UUID download -->
                            <field name="uuid"
                                invisible="download_type != 'uuid'"
                                readonly="request_state != '0'"
                                required="download_type == 'uuid'"
                                placeholder="XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"/>
                        </group>
                        <group>
                            <field name="uuid" invisible="1" />
                            <field name="request_type" />
                            <field name="company_id" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Documents">
                            <field name="document_ids" nolabel="1">
                                <list>
                                    <field name="name" />
                                    <field name="tag_ids" widget="many2many_tags" />
                                    <field name="partner_id" />
                                    <field name="vendor_bill_name" />
                                </list>
                             </field>
                        </page>
                        <page string="Information">
                            <group>
                                <group string="Request">
                                    <field name="file_count" />
                                    <field name="request" />
                                    <field name="request_message" />
                                    <field name="request_status_code" />
                                </group>
                                <group string="Token">
                                    <field name="token_expiration" />
                                    <field name="token" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="view_l10n_mx_edi_session_search" model="ir.ui.view">
        <field name="name">l10n_mx_edi.session.search</field>
        <field name="model">l10n_mx_edi.session</field>
        <field name="arch" type="xml">
            <search string="SAT Sessions">
                <!-- Basic search -->
                <field name="name" filter_domain="[('name', 'ilike', self)]" />
                <field name="request" filter_domain="[('request', 'ilike', self)]" />

                <!-- Filters by date -->
                <filter
                    string="Today"
                    name="today"
                    domain="[
                    ('date_to', '>=', context_today().strftime('%Y-%m-%d 00:00:00')),
                    ('date_to', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"
                />
                <separator />
                <filter
                    string="Yesterday"
                    name="yesterday"
                    domain="[
                    ('date_to', '>=', (context_today() + relativedelta(days=-1)).strftime('%Y-%m-%d 00:00:00')),
                    ('date_to', '&lt;=', (context_today() + relativedelta(days=-1)).strftime('%Y-%m-%d 23:59:59'))]"
                />
                <filter
                    string="This Week"
                    name="this_week"
                    domain="[
                    ('date_to', '>=', (context_today() + relativedelta(weeks=-1, days=1, weekday=0)).strftime('%Y-%m-%d 00:00:00')),
                    ('date_to', '&lt;=', (context_today() + relativedelta(weekday=6)).strftime('%Y-%m-%d 23:59:59'))]"
                />
                <filter
                    string="Last Week"
                    name="last_week"
                    domain="[
                    ('date_to', '>=', (context_today() + relativedelta(weeks=-2, days=1, weekday=0)).strftime('%Y-%m-%d 00:00:00')),
                    ('date_to', '&lt;=', (context_today() + relativedelta(weeks=-1, weekday=6)).strftime('%Y-%m-%d 23:59:59'))]"
                />
                <filter
                    string="This Month"
                    name="this_month"
                    domain="[
                    ('date_to', '>=', (context_today().replace(day=1)).strftime('%Y-%m-%d 00:00:00')),
                    ('date_to', '&lt;=', (context_today() + relativedelta(months=1, day=1, days=-1)).strftime('%Y-%m-%d 23:59:59'))]"
                />
                <filter
                    string="Last Month"
                    name="last_month"
                    domain="[
                    ('date_to', '>=', (context_today() + relativedelta(months=-1, day=1)).strftime('%Y-%m-%d 00:00:00')),
                    ('date_to', '&lt;=', (context_today() + relativedelta(day=1, days=-1)).strftime('%Y-%m-%d 23:59:59'))]"
                />

                <!-- Filters by state -->
                <separator />
                <filter string="Token inválido" name="token_invalid" domain="[('request_state', '=', '0')]" />
                <filter string="Aceptada" name="accepted" domain="[('request_state', '=', '1')]" />
                <filter string="En proceso" name="in_process" domain="[('request_state', '=', '2')]" />
                <filter string="Terminada" name="finished" domain="[('request_state', '=', '3')]" />
                <filter string="Error" name="error" domain="[('request_state', '=', '4')]" />
                <filter string="Rechazada" name="rejected" domain="[('request_state', '=', '5')]" />
                <filter string="Vencida" name="expired" domain="[('request_state', '=', '6')]" />

                <!-- Monitoring -->
                <separator />
                <filter string="No documents" name="no_documents" domain="[('document_ids', '=', False)]" />
                <filter
                    string="Ready to download"
                    name="ready_to_download"
                    domain="[
                    ('request_state', '=', '3'),
                    ('request_status_code', '!=', '5008'),
                    ('document_ids', '=', False)]"
                />
                <!-- filters for download type -->
                <filter string="Descarga Masiva"
                        name="massive_download"
                        domain="[('download_type', '=', 'massive')]"/>
                <filter string="Por UUID"
                        name="uuid_download"
                        domain="[('download_type', '=', 'uuid')]"/>
                <separator/>
                <!-- Group -->
                <group expand="0" string="Group By">
                    <filter string="Date" name="group_by_date_to" context="{'group_by': 'date_to'}" />
                    <filter string="State" name="group_by_state" context="{'group_by': 'request_state'}" />
                    <filter string="Tipo de Descarga"
                            name="group_by_download_type"
                            context="{'group_by': 'download_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="l10n_mx_edi_session_action" model="ir.actions.act_window">
        <field name="name">MX SAT Sessions</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">l10n_mx_edi.session</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_sat_sync"
        name="Sync with SAT"
        parent="documents.menu_root"
        sequence="5"
        groups="documents_l10n_mx_edi.group_documents_l10n_mx_edi"
    />

    <menuitem
        id="menu_sat_sessions"
        name="Sessions"
        parent="menu_sat_sync"
        sequence="10"
        groups="documents_l10n_mx_edi.group_documents_l10n_mx_edi"
        action="l10n_mx_edi_session_action"
    />
</odoo>
