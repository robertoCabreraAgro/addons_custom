<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="0">
    <!-- Create the privilege for MX EDI Documents -->
    <record id="res_groups_privilege_documents_l10n_mx_edi" model="res.groups.privilege">
        <field name="name">MX EDI Documents</field>
        <field name="description">Privilege for MX EDI Documents functionality</field>
        <field name="category_id" ref="base.module_category_extra"/>
    </record>

    <record id="group_documents_l10n_mx_edi" model="res.groups">
        <field name="name">Access to MX EDI documents</field>
        <field name="privilege_id" ref="res_groups_privilege_documents_l10n_mx_edi" />
    </record>

    <record id="group_documents_l10n_mx_edi_manager" model="res.groups">
        <field name="name">Access to MX EDI documents Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_documents_l10n_mx_edi" />
        <field
            name="implied_ids"
            eval="[
                (4, ref('documents_l10n_mx_edi.group_documents_l10n_mx_edi')),
            ]"
        />
    </record>
</odoo>
