<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="workflow_template_action_tree" model="ir.ui.view">
        <field name="name">workflow.template.action.tree</field>
        <field name="model">workflow.template.action</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="action" />
                <field name="workflow_template_id" invisible="1" />
                <field name="template_id" readonly="action != 'move'" />
                <field name="company_ids" invisible="1" />
            </list>
        </field>
    </record>

    <record id="workflow_template_action_form" model="ir.ui.view">
        <field name="name">workflow.template.action.form</field>
        <field name="model">workflow.template.action</field>
        <field name="arch" type="xml">
            <form string="Account Operation Action">
                <sheet>
                    <group name="main">
                        <group>
                            <field name="name" />
                            <field name="action" />
                            <field name="workflow_template_id" invisible="1" />
                            <field name="template_id" invisible="action != 'move'" />
                            <field name="date_last_document" invisible="action != 'move'" />
                            <field name="diff_partner" invisible="action != 'move'" />
                            <field name="journal_id" invisible="action != 'pay'" />
                            <field name="workflow_template_ids" invisible="action != 'operation'" />
                            <field name="auto" invisible="action == 'info' or not action" />
                            <field name="company_ids" invisible="1" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
