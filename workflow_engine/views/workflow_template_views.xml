<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="workflow_template_search" model="ir.ui.view">
        <field name="name">workflow.template.search</field>
        <field name="model">workflow.template</field>
        <field name="arch" type="xml">
            <search string="Account Operation Type">
                <filter name="inactive" string="Archived"
                    domain="[('active','=',False)]" />
                <field name="name" />
            </search>
        </field>
    </record>

    <record id="workflow_template_tree" model="ir.ui.view">
        <field name="name">workflow.template.tree</field>
        <field name="model">workflow.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="company_ids" widget="many2many_tags" readonly="True" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="workflow_template_form" model="ir.ui.view">
        <field name="name">workflow.template.form</field>
        <field name="model">workflow.template</field>
        <field name="arch" type="xml">
            <form string="Account Operation Type">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group name="main">
                        <group>
                            <field name="company_id" invisible="1" />
                            <field name="company_ids"
                                widget="many2many_tags"
                                options="{'no_create': True}"
                                groups="base.group_multi_company" />
                            <field name="sub_operation" invisible="from_bank_statement" />
                            <field name="from_bank_statement" invisible="sub_operation" />
                        </group>
                    </group>
                    <group name="lines">
                        <field name="action_ids" nolabel="1" colspan="2" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="workflow_template_action" model="ir.actions.act_window">
        <field name="name">Accounting Operations Types</field>
        <field name="res_model">workflow.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
    </record>

    <menuitem
        id="workflow_template_menu"
        parent="account.account_account_menu"
        action="workflow_template_action"
        sequence="300" />
</odoo>
