<odoo>

    <!-- Vista lista de propiedades -->
    <record id="view_estate_property_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="property_type_id"/>
                <field name="expected_price"/>
                <field name="bedrooms"/>
                <field name="living_area"/>
                <field name="state"/>
                <field name="salesperson_id"/>
            </list>
        </field>
    </record>

    <!-- Vista formulario de propiedades -->
    <record id="view_estate_property_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sold" string="Sell" type="object" class="btn-primary"/>
                    <button name="action_canceled" string="Cancel" type="object"/>
                    <button name="action_view_offers" string="View Offers" type="object" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,offer_received,offer_accepted,sold,canceled"/>
                </header>

                <sheet>

                    <group string="Property Details">
                        <field name="name"/>
                        <field name="property_type_id"/>
                        <field name="expected_price"/>
                        <field name="selling_price"/>
                    </group>

                    <notebook>
                        <page string="Description">
                            <group string="Description">
                                <field name="bedrooms"/>
                                <field name="living_area"/>
                                <field name="facades"/>
                                <field name="garage"/>
                                <field name="garden"/>
                                <field name="garden_area" invisible="not show_garden_fields"/>
                                <field name="garden_orientation" invisible="not show_garden_fields"/>
                                <field name="total_area"/>
                            </group>
                        </page>

                    
                    <group string="Location">
                        <field name="postcode"/>
                        <field name="date_availability"/>
                    </group>

                        <page string="Offers">
                            <group string="Offers">
                                <field name="offer_ids" context="{'default_property_id': id}">
                                    <list editable="bottom">
                                        <field name="partner_id" placeholder="Elige un comprador"/>
                                        <field name="price"/>
                                        <field name="validity"/>
                                        <field name="date_deadline"/>
                                        <field name="status" placeholder="Elige el estatus"/>
                                    </list>
                                </field>
                                <field name="best_price"/>
                                <field name="offer_count"/>
                            </group>
                        </page>

                        <page string="Other Info">
                            <group string="Other Info">
                                <field name="tag_ids"/>
                                <field name="salesperson_id"/>
                                <field name="buyer_id"/>
                                <field name="description"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción principal de propiedades -->
    <record id="action_estate_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No properties found. Create a new one!
            </p>
        </field>
    </record>

    <!-- Asociación de la acción con la vista lista -->
    <record id="action_estate_property_list" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="action_estate_property"/>
        <field name="view_id" ref="view_estate_property_list"/>
        <field name="view_mode">list</field>
        <field name="sequence" eval="1"/>
    </record>
    

</odoo>
