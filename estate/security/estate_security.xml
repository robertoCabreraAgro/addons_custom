<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_estate" model="ir.module.category">
            <field name="name">Real Estate</field>
            <field name="sequence">20</field>
        </record>

        <!-- Grupo de Usuario Estate Manager -->
        <record id="group_estate_manager" model="res.groups">
            <field name="name">Estate Manager</field>
            <field name="category_id" ref="base.module_category_sales"/>
            <field name="implied_ids" eval="[(4, ref('group_estate_user'))]"/>
        </record>

        <!-- Grupo de Usuario Estate User -->
        <record id="group_estate_user" model="res.groups">
            <field name="name">Estate User</field>
            <field name="category_id" ref="base.module_category_sales"/>
        </record>

        <!-- Reglas de acceso para Estate Property -->
        <record id="estate_property_rule_user" model="ir.rule">
            <field name="name">Estate Property User Rule</field>
            <field name="model_id" ref="model_estate_property"/>
            <field name="domain_force">[('salesperson_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_estate_user'))]"/>
        </record>

        <record id="estate_property_rule_manager" model="ir.rule">
            <field name="name">Estate Property Manager Rule</field>
            <field name="model_id" ref="model_estate_property"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_estate_manager'))]"/>
        </record>

        <!-- Reglas de acceso para Estate Property Offer -->
        <record id="estate_offer_rule_user" model="ir.rule">
            <field name="name">Estate Offer User Rule</field>
            <field name="model_id" ref="model_estate_property_offer"/>
            <field name="domain_force">[('property_id.salesperson_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_estate_user'))]"/>
        </record>

        <record id="estate_offer_rule_manager" model="ir.rule">
            <field name="name">Estate Offer Manager Rule</field>
            <field name="model_id" ref="model_estate_property_offer"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_estate_manager'))]"/>
        </record>
    </data>
</odoo>