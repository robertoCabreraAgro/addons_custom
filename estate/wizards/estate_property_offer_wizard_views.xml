<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_estate_offer_wizard_form" model="ir.ui.view">
        <field name="name">estate.property.offer.wizard.form</field>
        <field name="model">estate.property.offer.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Multiple Offers">
                <sheet>
                    <group>
                        <group string="Offer Details">
                            <field name="price" required="1"/>
                            <field name="partner_id" required="1"/>
                            <field name="validity"/>
                        </group>
                        <group string="Information">
                            <div class="alert alert-info" role="alert">
                                <strong>Note:</strong> This will create offers for all selected properties.
                            </div>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_create_offers" string="Create Offers" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <act_window id="action_estate_offer_wizard"
                name="Create Multiple Offers"
                res_model="estate.property.offer.wizard"
                view_mode="form"
                target="new"
                context="{'default_price': 100000}"/>
</odoo>