<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_estate_property">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="container">
                        <h2 class="text-center">Property Report: <span t-esc="object.name"/></h2>
                        
                        <div class="row mt-4">
                            <div class="col-6">
                                <div class="card">
                                    <div class="card-header">
                                        <h5>Property Details</h5>
                                    </div>
                                    <div class="card-body">
                                        <table class="table table-sm">
                                            <tr>
                                                <td><strong>Name:</strong></td>
                                                <td><span t-esc="object.name"/></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Type:</strong></td>
                                                <td><span t-esc="object.property_type_id.name or 'N/A'"/></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Expected Price:</strong></td>
                                                <td><span t-esc="'$%.2f' % object.expected_price"/></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Selling Price:</strong></td>
                                                <td>
                                                    <t t-if="object.selling_price">
                                                        <span t-esc="'$%.2f' % object.selling_price"/>
                                                    </t>
                                                    <t t-else="">N/A</t>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td><strong>State:</strong></td>
                                                <td><span t-esc="object.state"/></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-6">
                                <div class="card">
                                    <div class="card-header">
                                        <h5>Features</h5>
                                    </div>
                                    <div class="card-body">
                                        <table class="table table-sm">
                                            <tr>
                                                <td><strong>Bedrooms:</strong></td>
                                                <td><span t-esc="object.bedrooms"/></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Living Area:</strong></td>
                                                <td><span t-esc="'%s sqm' % object.living_area"/></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Total Area:</strong></td>
                                                <td><span t-esc="'%s sqm' % object.total_area"/></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Garden:</strong></td>
                                                <td><span t-esc="'Yes' if object.garden else 'No'"/></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Garage:</strong></td>
                                                <td><span t-esc="'Yes' if object.garage else 'No'"/></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5>Description</h5>
                                    </div>
                                    <div class="card-body">
                                        <p t-esc="object.description or 'No description available'"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <t t-if="object.offer_ids">
                            <div class="row mt-4">
                                <div class="col-12">
                                    <div class="card">
                                        <div class="card-header">
                                            <h5>Offers</h5>
                                        </div>
                                        <div class="card-body">
                                            <table class="table table-bordered">
                                                <thead>
                                                    <tr>
                                                        <th>Customer</th>
                                                        <th>Price</th>
                                                        <th>Validity (Days)</th>
                                                        <th>Deadline</th>
                                                        <th>Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <t t-foreach="object.offer_ids" t-as="offer">
                                                        <tr>
                                                            <td><span t-esc="offer.partner_id.name"/></td>
                                                            <td><span t-esc="'$%.2f' % offer.price"/></td>
                                                            <td><span t-esc="offer.validity"/></td>
                                                            <td><span t-esc="offer.date_deadline"/></td>
                                                            <td><span t-esc="offer.status or 'Pending'"/></td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>