<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Reporte PDF para propiedades -->
    <report
        id="action_estate_property_report"
        string="Property Report"
        model="estate.property"
        report_type="qweb-pdf"
        name="estate.report_estate_property"
        file="estate.report_estate_property"
        attachment_use="False"
        paperformat="a4"
    />


    <!-- Acción de servidor para el reporte -->
    <record id="action_server_estate_property_report" model="ir.actions.server">
        <field name="name">Generate Property Report</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="binding_model_id" ref="model_estate_property"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
            action = report.with_context(active_ids=env.context.get('active_ids')).action_estate_property_report()
        </field>
    </record>

    <!-- Acción de ventana para reportes -->
    <record id="view_estate_property_report" model="ir.actions.act_window">
        <field name="name">Property Reports</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
    </record>
</odoo>